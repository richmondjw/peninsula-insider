{
  "site": "Peninsula Insider",
  "version": "2026-04-27",
  "status": "active-design",
  "timezone": "UTC",
  "dispatchCadence": {
    "rule": "Peninsula This Weekend dispatches every Sunday for the weekend ahead. The dispatch is researched, shaped, drafted, reviewed, and published on Sunday (UTC), covering the Saturday and Sunday of the immediately following calendar week.",
    "publishDay": "Sunday",
    "publishTimeUTC": "11:30",
    "weekendCovered": "Saturday and Sunday of the week immediately following the Sunday publish date (i.e. publish-date + 6 days = Saturday, publish-date + 7 days = Sunday)",
    "titleConvention": "Peninsula This Weekend — D[D] to D[D] Month (Saturday and Sunday dates of the upcoming weekend, e.g. Sunday 26 April publish → 'Peninsula This Weekend — 2 to 3 May')",
    "lockedAt": "2026-04-27"
  },
  "jobs": [
    {
      "name": "pi-daily-accuracy-scan",
      "cadence": "daily 20:20 UTC",
      "type": "accuracy-scan",
      "owner": "PI-accuracy-desk",
      "inputs": [
        "homepage",
        "whats-on surface",
        "current dispatch",
        "event source files",
        "live build output"
      ],
      "outputs": [
        "reports/peninsula-accuracy-scan-YYYY-MM-DD.md"
      ],
      "surfaces": [
        "index.html",
        "whats-on/index.html",
        "journal/peninsula-this-weekend-*/index.html",
        "next/src/content/events",
        "next/src/content/articles"
      ]
    },
    {
      "name": "pi-daily-accuracy-autofix",
      "cadence": "daily 20:35 UTC",
      "type": "accuracy-autofix",
      "owner": "PI-accuracy-desk + PI-publisher",
