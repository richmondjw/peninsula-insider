---
/**
 * Peninsula Insider — Homepage
 *
 * Editorial cover page. Sections in order:
 *   1. Masthead + navigation
 *   2. Cover hero (editorial lead)
 *   3. Pillar navigation strip
 *   4. Featured article block
 *   5. Curated venues strip
 *   6. Places spotlight
 *   7. Newsletter CTA
 *   8. Footer
 *
 * Pulls live data from content collections. Zero client-side JS.
 * Fonts: Cormorant Garamond (display) + Outfit (body) — matching live site.
 * Palette: Wine Country at Golden Hour — matching live site design system.
 */

import { getCollection } from 'astro:content';

const venues   = await getCollection('venues');
const articles = await getCollection('articles', ({ data }) => data.status === 'published');
const places   = await getCollection('places');

const featured  = articles.find(a => a.data.featured) ?? articles[0];
const showcase  = venues.slice(0, 3);

const formatLabel: Record<string, string> = {
  'editors-letter':        "Editor's Letter",
  'long-lunch-list':       'Long Lunch List',
  'cellar-door-dispatch':  'Cellar Door Dispatch',
  'stay-notes':            'Stay Notes',
  'slow-peninsula':        'Slow Peninsula',
  'insider-edit':          'Insider Edit',
  'interview':             'Interview',
  'investigation':         'Investigation',
  'service':               'Service',
};

const typeLabel: Record<string, string> = {
  restaurant:  'Restaurant',
  winery:      'Winery',
  cafe:        'Café',
  bakery:      'Bakery',
  pub:         'Pub',
  brewery:     'Brewery',
  distillery:  'Distillery',
  producer:    'Producer',
  market:      'Market',
  hotel:       'Hotel',
  villa:       'Villa',
  cottage:     'Cottage',
  glamping:    'Glamping',
  'farm-stay': 'Farm Stay',
  spa:         'Spa',
};

const now = new Date();
const issueDate = now.toLocaleDateString('en-AU', { month: 'long', year: 'numeric' });
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Outfit:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />
  <title>Peninsula Insider — The Mornington Peninsula, as insiders know it</title>
  <meta
    name="description"
    content="The independent editorial guide to eating, drinking, staying, and escaping on the Mornington Peninsula. No advertisers. No press trips. Just honest coverage."
  />
  <style>
    /* =========================================================
       DESIGN TOKENS — matching live site (css/styles.css)
       ========================================================= */
    :root {
      --bg:        #F5F1EB;
      --bg-alt:    #EBE6DD;
      --bg-dark:   #1E1B18;
      --text:      #2B2520;
      --soft:      #7A726A;
      --accent:    #8B4E3B;
      --acc-h:     #6D3A2B;
      --gold:      #B69A6B;
      --dark:      #1E1B18;
      --white:     #FDFCFA;
      --border:    #D8D1C7;
      --sage:      #7A8B6D;
      --max-w:     1100px;
      --prose-w:   680px;
      --ease:      cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    /* =========================================================
       RESET
       ========================================================= */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }

    body {
      font-family: 'Outfit', system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.75;
      font-size: 0.95rem;
      font-weight: 300;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }

    /* Subtle grain texture — matches live site */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 9999;
      opacity: 0.022;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 128px;
    }

    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; transition: color .22s var(--ease); }

    h1, h2, h3, h4, h5 {
      font-family: 'Cormorant Garamond', Georgia, serif;
      line-height: 1.06;
      color: var(--dark);
      text-rendering: optimizeLegibility;
    }

    .container {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 clamp(1.25rem, 4vw, 3rem);
    }

    .label {
      font-family: 'Outfit', sans-serif;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--soft);
    }

    .label--accent { color: var(--accent); }

    hr.rule {
      border: none;
      border-top: 1px solid var(--border);
    }

    /* =========================================================
       MASTHEAD
       ========================================================= */
    .masthead {
      border-bottom: 1px solid var(--border);
      background: var(--bg);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .masthead__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
      gap: 1rem;
    }

    .masthead__logo {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.35rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: var(--dark);
      white-space: nowrap;
      flex-shrink: 0;
    }

    .masthead__logo span {
      color: var(--accent);
    }

    .masthead__nav {
      display: flex;
      align-items: center;
      gap: clamp(1rem, 2.5vw, 2rem);
      list-style: none;
    }

    .masthead__nav a {
      font-size: 0.78rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--soft);
      transition: color .2s var(--ease);
    }

    .masthead__nav a:hover { color: var(--accent); }

    .masthead__cta {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      border: 1px solid var(--accent);
      padding: 0.45rem 1rem;
      transition: background .2s var(--ease), color .2s var(--ease);
      white-space: nowrap;
      flex-shrink: 0;
    }

    .masthead__cta:hover {
      background: var(--accent);
      color: var(--white);
    }

    /* =========================================================
       COVER HERO
       ========================================================= */
    .cover {
      padding: clamp(4rem, 10vw, 7rem) 0 0;
      border-bottom: 1px solid var(--border);
    }

    .cover__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(3rem, 6vw, 6rem);
      align-items: end;
      padding-bottom: clamp(3rem, 6vw, 5rem);
    }

    .cover__meta {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.75rem;
    }

    .cover__meta .label { color: var(--accent); }

    .cover__meta-rule {
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .cover__headline {
      font-size: clamp(3rem, 6.5vw, 5.5rem);
      font-weight: 600;
      line-height: 0.97;
      letter-spacing: -0.025em;
      color: var(--dark);
      margin-bottom: 1.75rem;
    }

    .cover__headline em {
      font-style: italic;
      color: var(--accent);
    }

    .cover__dek {
      font-size: 1.1rem;
      line-height: 1.65;
      color: var(--soft);
      max-width: 42ch;
      font-weight: 300;
    }

    /* Landscape colour panel — editorial visual anchor */
    .cover__visual {
      position: relative;
      border-radius: 2px;
      overflow: hidden;
      aspect-ratio: 4 / 3;
      background: linear-gradient(
        160deg,
        #C9B99A 0%,
        #B8A885 25%,
        #7A8B6D 55%,
        #4E6B52 80%,
        #3A5240 100%
      );
    }

    .cover__visual-fog {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(245, 241, 235, 0.18) 0%,
        transparent 40%,
        rgba(30, 27, 24, 0.25) 100%
      );
    }

    .cover__visual-label {
      position: absolute;
      bottom: 1.25rem;
      left: 1.25rem;
      color: rgba(253, 252, 250, 0.75);
      font-size: 0.6rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 500;
    }

    /* Landscape band below the two-column header */
    .cover__band {
      height: clamp(80px, 14vw, 160px);
      background: linear-gradient(
        90deg,
        #EBE6DD 0%,
        #C9B99A 20%,
        #8B7B62 45%,
        #7A8B6D 68%,
        #4E6B52 85%,
        #3A5240 100%
      );
      opacity: 0.55;
    }

    /* =========================================================
       PILLAR NAVIGATION
       ========================================================= */
    .pillars {
      border-bottom: 1px solid var(--border);
      background: var(--bg);
    }

    .pillars__inner {
      display: flex;
    }

    .pillar {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.35rem;
      padding: 1.4rem 0.5rem;
      border-right: 1px solid var(--border);
      cursor: default;
      transition: background .2s var(--ease);
    }

    .pillar:last-child { border-right: none; }
    .pillar:hover { background: var(--bg-alt); }

    .pillar__icon {
      font-size: 1.1rem;
      opacity: 0.6;
      line-height: 1;
    }

    .pillar__name {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1rem;
      font-weight: 600;
      color: var(--dark);
    }

    .pillar__sub {
      font-size: 0.6rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--soft);
    }

    /* =========================================================
       FEATURED ARTICLE
       ========================================================= */
    .feature {
      padding: clamp(4rem, 8vw, 6rem) 0;
      border-bottom: 1px solid var(--border);
    }

    .feature__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(3rem, 6vw, 6rem);
      align-items: center;
    }

    .feature__image-block {
      position: relative;
      aspect-ratio: 3 / 2;
      border-radius: 2px;
      overflow: hidden;
      background: linear-gradient(
        135deg,
        #C9B99A 0%,
        #A89278 30%,
        #8B7055 60%,
        #6E5440 100%
      );
    }

    .feature__image-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(30, 27, 24, 0.5) 0%,
        transparent 60%
      );
    }

    .feature__image-tag {
      position: absolute;
      top: 1.25rem;
      left: 1.25rem;
      background: var(--accent);
      color: var(--white);
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 0.3rem 0.7rem;
    }

    .feature__content {}

    .feature__label {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 1.25rem;
    }

    .feature__label::before {
      content: '';
      display: block;
      width: 2rem;
      height: 1px;
      background: var(--accent);
    }

    .feature__title {
      font-size: clamp(2rem, 3.5vw, 3rem);
      font-weight: 600;
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--dark);
      margin-bottom: 1.1rem;
    }

    .feature__title a:hover { color: var(--accent); }

    .feature__dek {
      font-size: 1.05rem;
      line-height: 1.65;
      color: var(--soft);
      margin-bottom: 1.75rem;
      font-style: italic;
    }

    .feature__byline {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 2rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
    }

    .feature__byline-name {
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--text);
    }

    .feature__byline-dot {
      width: 3px;
      height: 3px;
      background: var(--border);
      border-radius: 50%;
    }

    .feature__byline-meta {
      font-size: 0.78rem;
      color: var(--soft);
    }

    .feature__cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      transition: gap .2s var(--ease);
    }

    .feature__cta:hover { gap: 0.85rem; color: var(--acc-h); }

    /* =========================================================
       VENUES STRIP
       ========================================================= */
    .venues {
      padding: clamp(4rem, 8vw, 6rem) 0;
      background: var(--bg-alt);
      border-bottom: 1px solid var(--border);
    }

    .venues__header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 2.5rem;
      gap: 1rem;
    }

    .venues__title {
      font-size: clamp(1.6rem, 2.8vw, 2.1rem);
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    .venues__link {
      font-size: 0.73rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      white-space: nowrap;
      transition: color .2s var(--ease);
    }

    .venues__link:hover { color: var(--acc-h); }

    .venues__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5px;
    }

    .venue-card {
      background: var(--white);
      padding: 2rem 1.75rem 1.75rem;
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .venue-card__top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    .venue-card__type {
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .venue-card__price {
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--soft);
      letter-spacing: 0.04em;
    }

    .venue-card__name {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.55rem;
      font-weight: 600;
      line-height: 1.1;
      letter-spacing: -0.015em;
      color: var(--dark);
      margin-bottom: 0.35rem;
    }

    .venue-card__place {
      font-size: 0.72rem;
      color: var(--soft);
      letter-spacing: 0.04em;
      margin-bottom: 1.25rem;
    }

    .venue-card__signature {
      font-size: 0.9rem;
      font-style: italic;
      color: var(--soft);
      line-height: 1.55;
      flex: 1;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
      margin-bottom: 1.5rem;
    }

    .venue-card__hats {
      display: flex;
      gap: 0.2rem;
      margin-bottom: 1.25rem;
    }

    .venue-card__hat {
      width: 10px;
      height: 10px;
      background: var(--gold);
      clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
      opacity: 0.8;
    }

    .venue-card__cta {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-top: auto;
      transition: gap .18s var(--ease), color .18s var(--ease);
    }

    .venue-card__cta:hover { gap: 0.65rem; color: var(--acc-h); }

    /* =========================================================
       PLACES
       ========================================================= */
    .places {
      padding: clamp(4rem, 8vw, 6rem) 0;
      border-bottom: 1px solid var(--border);
    }

    .places__header {
      margin-bottom: 2.5rem;
    }

    .places__label {
      margin-bottom: 0.6rem;
    }

    .places__title {
      font-size: clamp(1.6rem, 2.8vw, 2.1rem);
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    .places__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .place-card {
      position: relative;
      overflow: hidden;
      border-radius: 2px;
    }

    .place-card:nth-child(1) .place-card__image {
      background: linear-gradient(135deg, #8B7B62 0%, #7A8B6D 50%, #4E6B52 100%);
    }

    .place-card:nth-child(2) .place-card__image {
      background: linear-gradient(135deg, #B8D4E8 0%, #7BACCB 40%, #4A7FA3 100%);
    }

    .place-card__image {
      aspect-ratio: 16 / 9;
    }

    .place-card__body {
      padding: 1.5rem 0 0;
    }

    .place-card__zone {
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.4rem;
    }

    .place-card__name {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.6rem;
      font-weight: 600;
      letter-spacing: -0.015em;
      color: var(--dark);
      margin-bottom: 0.75rem;
    }

    .place-card__intro {
      font-size: 0.9rem;
      line-height: 1.65;
      color: var(--soft);
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* =========================================================
       NEWSLETTER
       ========================================================= */
    .newsletter {
      background: var(--dark);
      color: var(--white);
      padding: clamp(4rem, 8vw, 7rem) 0;
    }

    .newsletter__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(3rem, 6vw, 6rem);
      align-items: center;
    }

    .newsletter__label {
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    .newsletter__title {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: clamp(2rem, 3.5vw, 3rem);
      font-weight: 600;
      line-height: 1.08;
      letter-spacing: -0.02em;
      color: var(--white);
      margin-bottom: 1rem;
    }

    .newsletter__body {
      font-size: 0.95rem;
      line-height: 1.75;
      color: rgba(253, 252, 250, 0.65);
    }

    .newsletter__form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .newsletter__disclaimer {
      font-size: 0.72rem;
      color: rgba(253, 252, 250, 0.4);
      line-height: 1.6;
    }

    .newsletter__field {
      display: flex;
      gap: 0;
    }

    .newsletter__input {
      flex: 1;
      padding: 0.85rem 1.1rem;
      background: rgba(255, 255, 255, 0.07);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-right: none;
      color: var(--white);
      font-family: 'Outfit', sans-serif;
      font-size: 0.9rem;
      font-weight: 300;
      outline: none;
      transition: background .2s var(--ease), border-color .2s var(--ease);
    }

    .newsletter__input::placeholder { color: rgba(253, 252, 250, 0.35); }

    .newsletter__input:focus {
      background: rgba(255, 255, 255, 0.11);
      border-color: rgba(255, 255, 255, 0.3);
    }

    .newsletter__submit {
      padding: 0.85rem 1.5rem;
      background: var(--accent);
      border: 1px solid var(--accent);
      color: var(--white);
      font-family: 'Outfit', sans-serif;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background .2s var(--ease);
      white-space: nowrap;
    }

    .newsletter__submit:hover { background: var(--acc-h); }

    /* Proof points */
    .newsletter__proofs {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .proof {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
    }

    .proof__icon {
      font-size: 1.1rem;
      opacity: 0.5;
      flex-shrink: 0;
      margin-top: 0.1rem;
    }

    .proof__text {
      font-size: 0.9rem;
      line-height: 1.6;
      color: rgba(253, 252, 250, 0.6);
    }

    .proof__text strong {
      color: rgba(253, 252, 250, 0.85);
      font-weight: 500;
      display: block;
    }

    /* =========================================================
       FOOTER
       ========================================================= */
    .footer {
      background: var(--bg);
      border-top: 1px solid var(--border);
      padding: 2.5rem 0;
    }

    .footer__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      flex-wrap: wrap;
    }

    .footer__logo {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--dark);
    }

    .footer__logo span { color: var(--accent); }

    .footer__links {
      display: flex;
      gap: 1.5rem;
      list-style: none;
    }

    .footer__links a {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--soft);
      transition: color .2s var(--ease);
    }

    .footer__links a:hover { color: var(--accent); }

    .footer__copy {
      font-size: 0.72rem;
      color: var(--soft);
    }

    /* =========================================================
       RESPONSIVE
       ========================================================= */
    @media (max-width: 768px) {
      .cover__inner { grid-template-columns: 1fr; }
      .cover__visual { aspect-ratio: 16 / 9; }
      .feature__inner { grid-template-columns: 1fr; }
      .venues__grid { grid-template-columns: 1fr; }
      .places__grid { grid-template-columns: 1fr; }
      .newsletter__inner { grid-template-columns: 1fr; }
      .masthead__nav { display: none; }
      .footer__inner { flex-direction: column; align-items: flex-start; }
    }

    @media (max-width: 480px) {
      .pillars__inner { flex-wrap: wrap; }
      .pillar { flex-basis: 33.33%; }
    }
  </style>
</head>

<body>

  <!-- ===================== MASTHEAD ===================== -->
  <header class="masthead">
    <div class="container">
      <div class="masthead__inner">
        <a href="/" class="masthead__logo">
          Peninsula <span>Insider</span>
        </a>
        <nav aria-label="Primary">
          <ul class="masthead__nav">
            <li><a href="/eat">Eat &amp; Drink</a></li>
            <li><a href="/stay">Stay</a></li>
            <li><a href="/explore">Explore</a></li>
            <li><a href="/wine">Wine Country</a></li>
            <li><a href="/escape">Escape</a></li>
          </ul>
        </nav>
        <a href="#newsletter" class="masthead__cta">Newsletter</a>
      </div>
    </div>
  </header>

  <!-- ===================== COVER HERO ===================== -->
  <section class="cover" aria-label="Cover story">
    <div class="container">
      <div class="cover__inner">
        <div class="cover__copy">
          <div class="cover__meta">
            <span class="label label--accent">{issueDate}</span>
            <span class="cover__meta-rule" aria-hidden="true"></span>
            <span class="label">The Mornington Peninsula</span>
          </div>
          <h1 class="cover__headline">
            Where Victoria<br />
            eats, drinks,<br />
            and <em>stays put.</em>
          </h1>
          <p class="cover__dek">
            An independent editorial guide to the Peninsula — the long lunches,
            the cellar doors, the beaches worth the drive, and the places only
            locals know about. No advertisers. No press trips. Just honest coverage.
          </p>
        </div>
        <div class="cover__visual" aria-hidden="true">
          <div class="cover__visual-fog"></div>
          <span class="cover__visual-label">Red Hill Plateau · Hinterland</span>
        </div>
      </div>
    </div>
    <div class="cover__band" aria-hidden="true"></div>
  </section>

  <!-- ===================== PILLAR NAV ===================== -->
  <nav class="pillars" aria-label="Sections">
    <div class="container" style="padding: 0;">
      <div class="pillars__inner">
        <a href="/eat" class="pillar">
          <span class="pillar__icon" aria-hidden="true">◇</span>
          <span class="pillar__name">Eat &amp; Drink</span>
          <span class="pillar__sub">Restaurants · Cellar Doors</span>
        </a>
        <a href="/stay" class="pillar">
          <span class="pillar__icon" aria-hidden="true">◇</span>
          <span class="pillar__name">Stay</span>
          <span class="pillar__sub">Hotels · Villas · Escapes</span>
        </a>
        <a href="/explore" class="pillar">
          <span class="pillar__icon" aria-hidden="true">◇</span>
          <span class="pillar__name">Explore</span>
          <span class="pillar__sub">Walks · Beaches · Markets</span>
        </a>
        <a href="/wine" class="pillar">
          <span class="pillar__icon" aria-hidden="true">◇</span>
          <span class="pillar__name">Wine Country</span>
          <span class="pillar__sub">Wineries · Producers</span>
        </a>
        <a href="/escape" class="pillar">
          <span class="pillar__icon" aria-hidden="true">◇</span>
          <span class="pillar__name">Escape</span>
          <span class="pillar__sub">Itineraries · Slow Travel</span>
        </a>
      </div>
    </div>
  </nav>

  <!-- ===================== FEATURED ARTICLE ===================== -->
  {featured && (
    <section class="feature">
      <div class="container">
        <div class="feature__inner">
          <div class="feature__image-block" aria-hidden="true">
            <div class="feature__image-overlay"></div>
            <span class="feature__image-tag">
              {formatLabel[featured.data.format] ?? featured.data.format}
            </span>
          </div>
          <div class="feature__content">
            <div class="feature__label">
              <span class="label label--accent">From the Journal</span>
            </div>
            <h2 class="feature__title">
              <a href={`/journal/${featured.slug ?? featured.data.slug}`}>{featured.data.title}</a>
            </h2>
            <p class="feature__dek">{featured.data.dek}</p>
            <div class="feature__byline">
              <span class="feature__byline-name">
                {featured.data.houseByline ? 'By The Peninsula Insider' : `By ${String((featured.data.author as any)?.id ?? featured.data.author)}`}
              </span>
              {featured.data.readingTimeMinutes && (
                <>
                  <span class="feature__byline-dot" aria-hidden="true"></span>
                  <span class="feature__byline-meta">{featured.data.readingTimeMinutes} min read</span>
                </>
              )}
            </div>
            <a href={`/journal/${featured.slug ?? featured.data.slug}`} class="feature__cta">
              Read the full piece &nbsp;→
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ===================== VENUES STRIP ===================== -->
  {showcase.length > 0 && (
    <section class="venues">
      <div class="container">
        <div class="venues__header">
          <h2 class="venues__title">Editor's Table</h2>
          <a href="/eat" class="venues__link">All venues →</a>
        </div>
        <div class="venues__grid">
          {showcase.map((venue) => (
            <article class="venue-card">
              <div class="venue-card__top">
                <span class="venue-card__type">
                  {typeLabel[venue.data.type] ?? venue.data.type} · {String(venue.data.place.id ?? venue.data.place).replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase())}
                </span>
                <span class="venue-card__price">{venue.data.priceBand}</span>
              </div>
              <h3 class="venue-card__name">
                <a href={`/eat/${venue.id ?? venue.data.slug}`}>{venue.data.name}</a>
              </h3>
              <p class="venue-card__place">{venue.data.address.split(',').slice(-2).join(',').trim()}</p>
              {venue.data.authority?.hats && venue.data.authority.hats > 0 && (
                <div class="venue-card__hats" aria-label={`${venue.data.authority.hats} Good Food Guide hat${venue.data.authority.hats > 1 ? 's' : ''}`}>
                  {Array.from({ length: venue.data.authority.hats }).map(() => (
                    <span class="venue-card__hat" aria-hidden="true"></span>
                  ))}
                </div>
              )}
              <p class="venue-card__signature">{venue.data.signature}</p>
              <a href={`/eat/${venue.id ?? venue.data.slug}`} class="venue-card__cta">
                Editor's notes →
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===================== PLACES ===================== -->
  {places.length > 0 && (
    <section class="places">
      <div class="container">
        <div class="places__header">
          <p class="label label--accent places__label">Know the terrain</p>
          <h2 class="places__title">The Peninsula, place by place</h2>
        </div>
        <div class="places__grid">
          {places.map((place) => (
            <article class="place-card">
              <div class="place-card__image" aria-hidden="true"></div>
              <div class="place-card__body">
                <p class="place-card__zone">
                  {place.data.zone.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase())} · {place.data.kind}
                </p>
                <h3 class="place-card__name">
                  <a href={`/places/${place.id ?? place.data.slug}`}>{place.data.name}</a>
                </h3>
                <p class="place-card__intro">{place.data.intro}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===================== NEWSLETTER ===================== -->
  <section class="newsletter" id="newsletter" aria-label="Newsletter signup">
    <div class="container">
      <div class="newsletter__inner">
        <div>
          <p class="newsletter__label">The Insider's Dispatch</p>
          <h2 class="newsletter__title">The Peninsula in your inbox,<br />every fortnight.</h2>
          <p class="newsletter__body">
            New openings, cellar door dispatches, and the places we're quietly recommending
            this season. Written by editors who live here.
          </p>
        </div>
        <div class="newsletter__proofs-form-wrap">
          <form class="newsletter__form" aria-label="Email signup">
            <div class="newsletter__field">
              <input
                type="email"
                class="newsletter__input"
                placeholder="your@email.com"
                aria-label="Email address"
                autocomplete="email"
              />
              <button type="submit" class="newsletter__submit">Subscribe</button>
            </div>
            <p class="newsletter__disclaimer">
              No spam. Unsubscribe any time. We publish fortnightly during autumn and winter,
              weekly from October through March.
            </p>
          </form>
          <div class="newsletter__proofs" style="margin-top: 2rem;">
            <div class="proof">
              <span class="proof__icon" aria-hidden="true">◆</span>
              <p class="proof__text">
                <strong>Independent editorial</strong>
                No advertiser relationships. No sponsored content. Just places worth knowing.
              </p>
            </div>
            <div class="proof">
              <span class="proof__icon" aria-hidden="true">◆</span>
              <p class="proof__text">
                <strong>Written by locals</strong>
                Every recommendation is from someone who lives on the Peninsula.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FOOTER ===================== -->
  <footer class="footer">
    <div class="container">
      <div class="footer__inner">
        <span class="footer__logo">Peninsula <span>Insider</span></span>
        <ul class="footer__links">
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
          <li><a href="/sitemap.xml">Sitemap</a></li>
        </ul>
        <p class="footer__copy">&copy; {new Date().getFullYear()} Peninsula Insider</p>
      </div>
    </div>
  </footer>

</body>
</html>
