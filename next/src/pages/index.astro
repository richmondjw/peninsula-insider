---
/**
 * Peninsula Insider — Homepage
 * Refactored into shared layout + reusable editorial components.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CoverHero from '../components/CoverHero.astro';
import PillarNav from '../components/PillarNav.astro';
import FeatureArticle from '../components/FeatureArticle.astro';
import VenueCard from '../components/VenueCard.astro';
import PlaceCard from '../components/PlaceCard.astro';
import NewsletterBlock from '../components/NewsletterBlock.astro';

const venues = await getCollection('venues');
const articles = await getCollection('articles', ({ data }) => data.status === 'published');
const places = await getCollection('places');

const featured = articles.find((a) => a.data.featured) ?? articles[0];
const showcase = venues
  .filter((venue) => ['restaurant', 'winery'].includes(venue.data.type))
  .slice(0, 3);

const now = new Date();
const issueDate = now.toLocaleDateString('en-AU', { month: 'long', year: 'numeric' });
---

<BaseLayout
  title="Peninsula Insider — The Mornington Peninsula, as insiders know it"
  description="The independent editorial guide to eating, drinking, staying, and escaping on the Mornington Peninsula. No advertisers. No press trips. Just honest coverage."
  section="home"
>
  <CoverHero issueDate={issueDate} />

  <PillarNav />

  {featured && <FeatureArticle article={featured} />}

  {showcase.length > 0 && (
    <section class="venues">
      <div class="container">
        <div class="venues__header">
          <h2 class="venues__title">Editor's Table</h2>
          <a href="/eat" class="venues__link">All venues →</a>
        </div>
        <div class="venues__grid">
          {showcase.map((venue) => <VenueCard venue={venue} hrefPrefix="/eat" />)}
        </div>
      </div>
    </section>
  )}

  {places.length > 0 && (
    <section class="places">
      <div class="container">
        <div class="places__header">
          <p class="label label--accent places__label">Know the terrain</p>
          <h2 class="places__title">The Peninsula, place by place</h2>
        </div>
        <div class="places__grid">
          {places.slice(0, 4).map((place, index) => (
            <PlaceCard
              place={place}
              variant={index % 3 === 1 ? 'bay' : index % 3 === 2 ? 'sand' : 'vineyard'}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <NewsletterBlock />
</BaseLayout>
