---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ExperienceCard from '../../components/ExperienceCard.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { routeSlug } from '../../lib/editorial';

const experiences = await getCollection('experiences');
const walks = experiences
  .filter((e) => e.data.type === 'walk')
  .sort((a, b) => (b.data.durationMinutes ?? 0) - (a.data.durationMinutes ?? 0));

const shortWalks = walks.filter((e) => (e.data.durationMinutes ?? 999) <= 60);
const longWalks = walks.filter((e) => (e.data.durationMinutes ?? 0) > 60);

const allArticles = await getCollection('articles', ({ data }) => data.status === 'published');
const walkArticles = allArticles
  .filter((a) => a.data.tags?.some((t) => ['walks', 'hiking', 'walk', 'hikes'].includes(t)))
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Walks' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What are the best walks on the Mornington Peninsula?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The Bushrangers Bay walk from Cape Schanck is the best short walk — 5km return, basalt cliffs, and a sand-and-creek bay that most visitors do not expect. The Coppins Track from Sorrento to Diamond Bay is the strongest clifftop walk near a town. Greens Bush (Baldrys Long Circuit) is the best bush walk, with ancient grasstrees and real wildlife. The Two Bays Walking Trail (26km) is the Peninsula\'s best full-day or two-day challenge. Point Nepean (full 13.5km) is the best walk for history and coastal scenery combined.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are dogs allowed on Mornington Peninsula walks?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Dogs are explicitly banned from Mornington Peninsula National Park, which includes Cape Schanck, Point Nepean, the Coastal Walk corridor, and Two Bays Walking Trail sections within the national park. Dogs are also banned from Greens Bush and Arthurs Seat State Park. Dogs on leads are generally allowed on bay-side foreshore paths including Mornington and Mount Martha. Always check current Parks Victoria rules before your visit, as conditions change.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long is the Two Bays Walking Trail?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The Two Bays Walking Trail is 26km from Dromana on Port Phillip Bay to Bushrangers Bay near Cape Schanck. Most walkers complete it in 8–10 hours as a full one-day effort, or over two days with overnight camping at the Lightwood Creek Camping Area. The trail passes through Arthurs Seat State Park and Mornington Peninsula National Park, traversing eucalypt forest, ancient grasstrees, fern gullies, and grassland.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is the Cape Schanck walk difficult?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The Cape Schanck boardwalk to the lighthouse is short and accessible — most people complete it in 20 minutes return. The Bushrangers Bay walk from Cape Schanck carpark is 5km return and takes approximately 2 hours — easy to moderate, with some steep sections near the bay. The Coastal Walk section from Cape Schanck is a multi-day route requiring navigation and fitness. Which "Cape Schanck walk" you mean matters significantly.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the best walk near Sorrento?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The Coppins Track from Sorrento Ocean Beach to Diamond Bay is the best walk near Sorrento — 4km one way, clifftop walking with dramatic Bass Strait views and a genuine endpoint at Diamond Bay. The Farnsworth Track to Portsea Ocean Beach is shorter (1.5km one way) but equally impressive. Both depart from or near Sorrento and work well combined with a coffee before or after at Sorrento town.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the easiest walk on the Mornington Peninsula?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The Cape Schanck boardwalk is the easiest good walk — 20 minutes return, accessible, and genuinely spectacular at the clifftop platform. The Mornington foreshore walk is flat, accessible, and a good length for families or casual walkers. Greens Bush Baldrys Short Circuit (1.6km) is the easiest proper bush walk. The Arthurs Seat TC McKeller Walk is short, shaded, and suitable for all fitness levels.',
      },
    },
  ],
};

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Walks and Hikes on the Mornington Peninsula',
  description: 'A selective guide to the best walks and hikes on the Mornington Peninsula — from short clifftop tracks to the 100km circuit, with honest difficulty notes, seasonal guidance, and what to do after.',
  url: 'https://peninsulainsider.com.au/walks',
  about: {
    '@type': 'Thing',
    name: 'Mornington Peninsula walks and hiking tracks',
  },
};
---

<BaseLayout
  title="Walks on the Mornington Peninsula: The Insider Guide · Peninsula Insider"
  description="The best walks on the Mornington Peninsula — Bushrangers Bay, Cape Schanck, Two Bays, Greens Bush, Point Nepean, and more. Honest difficulty notes, seasonal guidance, and what to do after each walk."
  section="explore"
  canonical="https://peninsulainsider.com.au/walks"
  modifiedTime="2026-04-19"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />

  <Breadcrumbs items={breadcrumbItems} />

  <section class="section-hero">
    <div class="container">
      <div class="section-hero__inner">
        <div class="section-hero__content">
          <p class="label label--accent">Walks &amp; Hikes</p>
          <h1 class="section-hero__title">Walks on the Mornington Peninsula</h1>
          <p class="section-hero__dek">People are not just looking for a track to walk. They are looking for a Peninsula experience anchored by a walk. This section matches you to the right walk for the day you are trying to have — and tells you what to do before and after.</p>
        </div>
        <div class="section-hero__visual" aria-hidden="true" style="background-image: url(/images/sourced/explore-hub-hero-01.webp); background-size: cover; background-position: center;">
          <div class="section-hero__visual-fog"></div>
          <span class="section-hero__visual-label">Coastal walks · Clifftop tracks · Bushland</span>
        </div>
      </div>
    </div>
  </section>

  <section class="format-nav">
    <div class="container">
      <p class="label label--accent format-nav__label">Find your walk</p>
      <div class="format-nav__chips">
        {longWalks.length > 0 && <a href="#long-walks" class="format-chip"><span class="format-chip__name">Coastal &amp; full-day</span><span class="format-chip__count">{longWalks.length}</span></a>}
        {shortWalks.length > 0 && <a href="#short-walks" class="format-chip"><span class="format-chip__name">Under an hour</span><span class="format-chip__count">{shortWalks.length}</span></a>}
        <a href="#walk-selector" class="format-chip"><span class="format-chip__name">Which walk suits me?</span></a>
        <a href="#experience-linked" class="format-chip"><span class="format-chip__name">Walk + food / wine / spa</span></a>
        <a href="#specific-trails" class="format-chip"><span class="format-chip__name">Specific trails</span></a>
        <a href="#audience" class="format-chip"><span class="format-chip__name">Dog-friendly &amp; families</span></a>
        <a href="#faq" class="format-chip"><span class="format-chip__name">Common questions</span></a>
      </div>
    </div>
  </section>

  <section class="editorial-promise">
    <div class="container">
      <div class="editorial-promise__inner">
        <div>
          <p class="label label--accent">The Peninsula Insider approach to walks</p>
          <h2 class="editorial-promise__title">Editorial voice, not a trail database.</h2>
        </div>
        <div>
          <p>Parks Victoria has the official facts. AllTrails has user reviews. This section has something neither of them offers: honest characterisation of what each walk is actually like, who it suits, when to go, and how to make it part of a better Peninsula day. We are not neutral about the walks. The Bushrangers Bay walk is exceptional. The Long Point Circuit in Greens Bush is one of the Peninsula's most undervisited good walks. The Cape Schanck boardwalk is short but not to be dismissed. We say so.</p>
          <p>Dogs are banned from Mornington Peninsula National Park — including most of the clifftop and trail network. We note this clearly rather than burying it. Accurate is more useful than aspirational.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="venues venues--plain" id="walk-selector">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Walk selector</p>
          <h2 class="venues__title">Which walk belongs to the day you're trying to have?</h2>
          <p class="venues__sub">Match yourself to the right walk before you start driving.</p>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Short · Spectacular</span>
            <span class="venue-card__price">Under 2 hrs</span>
          </div>
          <h3 class="venue-card__name">Best short walk with a proper payoff</h3>
          <p class="venue-card__signature"><strong>Bushrangers Bay walk</strong> — 5km return from Cape Schanck, 2 hours. Basalt cliffs, a creek-to-sea bay, almost no one after 11am on weekdays. The walk that most consistently surprises first-timers. Finish at Cape Schanck Lighthouse.</p>
          <a href="/explore/bushrangers-bay-walk" class="venue-card__cta">Read the guide →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Clifftop · Views</span>
            <span class="venue-card__price">2–3 hrs</span>
          </div>
          <h3 class="venue-card__name">Best clifftop walk near a town</h3>
          <p class="venue-card__signature"><strong>Coppins Track, Sorrento to Diamond Bay</strong> — 4km one way, 1.5 hours. Start at Sorrento Ocean Beach, walk the clifftop above Bass Strait to Diamond Bay. One of the Peninsula's most dramatic middle-distance walks. Coffee in Sorrento before, or at Sorrento back after.</p>
          <a href="/explore/coppins-track" class="venue-card__cta">Read the guide →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Bush · Wildlife</span>
            <span class="venue-card__price">1.5–3 hrs</span>
          </div>
          <h3 class="venue-card__name">Best bush walk away from the crowds</h3>
          <p class="venue-card__signature"><strong>Greens Bush, Baldrys Long Circuit</strong> — 3.6km, 1.5 hours. Victoria's largest surviving coastal heathland remnant. Ancient grasstrees, fern gullies, and a consistent chance of kangaroos at dusk. One of the Peninsula's most undervisited good walks. Dogs not permitted.</p>
          <a href="/explore" class="venue-card__cta">See all experiences →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">History · Coastal</span>
            <span class="venue-card__price">Half day</span>
          </div>
          <h3 class="venue-card__name">Best walk for history and views combined</h3>
          <p class="venue-card__signature"><strong>Point Nepean walk</strong> — 13.5km, 4–5 hours. Military fortifications from 1878, the quarantine station, Cheviot Beach where Prime Minister Harold Holt disappeared, and a walking track built by convicts. The history competes with the view for your attention, which is the highest compliment you can pay a walk.</p>
          <a href="/explore/point-nepean-fort-walk" class="venue-card__cta">Read the guide →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Multi-day</span>
            <span class="venue-card__price">8–10 hrs one-way</span>
          </div>
          <h3 class="venue-card__name">Best full challenge</h3>
          <p class="venue-card__signature"><strong>Two Bays Walking Trail</strong> — 26km from Dromana to Bushrangers Bay. Ancient grasstrees possibly 200+ years old, eucalypt forest, fern gullies, grassland, and two coasts at either end. Can be done in a single very long day or over two days with camping at Lightwood Creek. The Peninsula's definitive long walk.</p>
          <a href="/explore/two-bays-walking-track" class="venue-card__cta">Read the guide →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Quick · Accessible</span>
            <span class="venue-card__price">20–45 min</span>
          </div>
          <h3 class="venue-card__name">Best walk when time is short</h3>
          <p class="venue-card__signature"><strong>Cape Schanck boardwalk</strong> — 20 minutes return, fully accessible, and genuinely spectacular. The lighthouse platform above Bass Strait is the best short-stop on the southern Peninsula. Underestimated because it is short. Do not skip it.</p>
          <a href="/explore/cape-schanck-boardwalk" class="venue-card__cta">Read the guide →</a>
        </div>
      </div>
    </div>
  </section>

  {longWalks.length > 0 && (
    <section class="experience-index" id="long-walks">
      <div class="container">
        <div class="venues__header">
          <div>
            <p class="label label--accent">Coastal &amp; full-day walks</p>
            <h2 class="venues__title">The walks worth clearing an afternoon for</h2>
            <p class="venues__sub">Cape Schanck, Bushrangers Bay, the Two Bays, the Coastal Walk corridor. These are the Peninsula walks that define the region — the ones people come back to.</p>
          </div>
          <a href="/explore/best-walks" class="venues__link">All walks guide →</a>
        </div>
        <div class="experience-grid">
          {longWalks.map((experience) => <ExperienceCard experience={experience} />)}
        </div>
      </div>
    </section>
  )}

  {shortWalks.length > 0 && (
    <section class="experience-index experience-index--plain" id="short-walks">
      <div class="container">
        <div class="venues__header">
          <div>
            <p class="label label--accent">Under an hour</p>
            <h2 class="venues__title">Between lunch and dinner. Or before coffee. Or both.</h2>
            <p class="venues__sub">Walks that fit in the gaps of a Peninsula day without needing to be planned around. All genuinely worth doing — not the short version because the real walk was too far.</p>
          </div>
        </div>
        <div class="experience-grid">
          {shortWalks.map((experience) => <ExperienceCard experience={experience} />)}
        </div>
      </div>
    </section>
  )}

  <section class="venues" id="experience-linked">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Walk + something</p>
          <h2 class="venues__title">Peninsula walks linked to what comes before and after</h2>
          <p class="venues__sub">The best Peninsula walk days are not just about the walk. These are the combinations that make a walk into a proper day out.</p>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Walk + Hot Springs</span>
          </div>
          <h3 class="venue-card__name">Bushrangers Bay → Peninsula Hot Springs</h3>
          <p class="venue-card__signature">The Cape Schanck corridor's best full-day combination. Walk Bushrangers Bay in the morning — 2 hours, back by 11am. Drive 15 minutes to Peninsula Hot Springs for a midday thermal session. Lunch at the springs café or drive to Fingal for options. The walk and the hot springs are both best on weekdays; avoid summer Saturday peak for both.</p>
          <a href="/spa" class="venue-card__cta">Hot springs guide →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Walk + Wine</span>
          </div>
          <h3 class="venue-card__name">Arthurs Seat → Red Hill Cellar Doors</h3>
          <p class="venue-card__signature">The Summit Circuit at Arthurs Seat in the morning — 1.8km, 1 hour, with views to Melbourne on a clear day. Then drop into the Red Hill cellar door circuit for the afternoon. Montalto, Pt. Leo Estate, and a dozen others within 15 minutes of the summit. The day structure works perfectly: active morning, wine afternoon.</p>
          <a href="/wine/best-cellar-doors" class="venue-card__cta">Cellar door guide →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Walk + Lunch</span>
          </div>
          <h3 class="venue-card__name">Coppins Track → Sorrento lunch</h3>
          <p class="venue-card__significance">Start at Sorrento Ocean Beach, walk the Coppins Track to Diamond Bay (4km, 90 minutes), return, and walk into Sorrento town for lunch. Multiple good options on Ocean Beach Road and the main strip. The walk earns the meal, and the timing works: finish the track by 12:30pm, lunch at 1pm, out by 3pm.</p>
          <a href="/eat/best-restaurants" class="venue-card__cta">Restaurant guide →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Walk + Stay</span>
          </div>
          <h3 class="venue-card__name">Two Bays Walking Trail → overnight</h3>
          <p class="venue-card__significance">The Two Bays is best broken into two days with overnight camping at Lightwood Creek, or as a point-to-point with a stay at either Dromana or Cape Schanck end. Walking 26km in a single day is possible but compresses the experience into a time trial. The overnight version lets you get the morning light in Greens Bush — the part of the walk most day-walkers miss.</p>
          <a href="/stay/best-accommodation" class="venue-card__cta">Where to stay →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Walk + Sunset</span>
          </div>
          <h3 class="venue-card__name">Farnsworth Track → Portsea for sunset</h3>
          <p class="venue-card__significance">The Farnsworth Track from London Bridge carpark is 1.5km one way — do it in the late afternoon, 4pm in autumn or winter. Arrive at the Portsea Ocean Beach lookout by 5pm. The light on Bass Strait at that hour is extraordinary. Walk back, drive 10 minutes to Portsea Hotel for a drink on the terrace while the sky settles.</p>
          <a href="/explore/farnsworth-track" class="venue-card__cta">Read the guide →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Walk + Dog</span>
          </div>
          <h3 class="venue-card__name">Dog-friendly foreshore walks</h3>
          <p class="venue-card__significance">Dogs are banned from the National Park and most major Peninsula walking tracks. The best dog-friendly walks are on the bay-side foreshore: Mornington foreshore, Mount Martha clifftop sections, and the Safety Beach to Dromana route. All on-lead, all accessible, and all within 15 minutes of good cafés. Check current local-council rules before visiting, as off-lead zones change seasonally.</p>
          <a href="/dog-friendly" class="venue-card__cta">Dog-friendly guide →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="venues venues--plain" id="specific-trails">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Specific trails</p>
          <h2 class="venues__title">The Peninsula's major walks, properly characterised</h2>
          <p class="venues__sub">Beyond the walk stats — what each track is actually like, when to go, and who it suits.</p>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <h3 class="venue-card__name">The Mornington Peninsula Walk (97.5km)</h3>
          <p class="venue-card__signature">The Peninsula's full circuit walk — Eight to ten days, combining the Two Bays Trail, the Coastal Walk, the Point Nepean Walk, and the Bay Trail. Often talked about as a challenge to "complete." The more enjoyable version is to walk it in pieces across several Peninsula visits, so the familiarity accumulates. Not a race. Dogs not permitted on most sections. Grade: Moderate.</p>
          <a href="/explore/mornington-peninsula-walk" class="venue-card__cta">Read the guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">The Two Bays Walking Trail (26km)</h3>
          <p class="venue-card__signature">Dromana to Bushrangers Bay. Ancient grasstrees (possibly 200+ years old), eucalypt forest, fern gullies. Two days with camping is better than a single-day push. The grasstrees alone are worth the walk — nothing else on the Peninsula looks like the Two Bays section through Greens Bush in the early morning. Grade: Moderate.</p>
          <a href="/explore/two-bays-walking-track" class="venue-card__cta">Read the guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">The Coastal Walk (26–30km)</h3>
          <p class="venue-card__signature">Cape Schanck to London Bridge. Two days. The Peninsula's wildest walking — Bass Strait clifftops, Bay of Islands, St Paul's, Diamond Bay, Jubilee Point. Exposed and demanding; go prepared. Best in autumn and spring. Summer brings heat and more walkers than the track is designed for. Grade: Moderate–Hard.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Bushrangers Bay Walk (5km return)</h3>
          <p class="venue-card__signature">The walk that consistently surprises. Cape Schanck carpark to the bay where Main Creek meets the sea — 40 minutes each way, basalt cliffs framing a sandy bay, usually quiet except on summer weekends. Photography walk, easy-to-moderate difficulty, no dogs. Extend to the Two Bays trailhead for an extra 2km. Grade: Easy–Moderate.</p>
          <a href="/explore/bushrangers-bay-walk" class="venue-card__cta">Read the guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Greens Bush</h3>
          <p class="venue-card__signature">Victoria's largest surviving coastal heathland remnant. Multiple circuits from Baldry Crossing — the Short (1.6km, 45 min) and Long (3.6km, 1.5 hrs) Baldrys circuits are the entry points. The Long Point Circuit (4km) is the best undervisited walk on the Peninsula. Kangaroos at dusk are a reasonable bet. No dogs. Grade: Easy–Moderate.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Point Nepean Walk (13.5km)</h3>
          <p class="venue-card__significance">London Bridge to the tip of the Peninsula. Military fortifications from 1878. The quarantine station established 1852. Cheviot Beach where PM Harold Holt disappeared in 1967. The history competes with the view for your attention — which is the highest compliment you can pay a walk. Shuttle bus available. Grade: Easy–Moderate.</p>
          <a href="/explore/point-nepean-fort-walk" class="venue-card__cta">Read the guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Coppins Track (4km one-way)</h3>
          <p class="venue-card__significance">Sorrento Ocean Beach to Diamond Bay. The Peninsula's best town-adjacent clifftop walk. Start at Sorrento, walk to Diamond Bay, come back the same way or arrange a pickup. The view from the clifftop above Diamond Bay is one of the Peninsula's most dramatic short-walk rewards. Grade: Easy.</p>
          <a href="/explore/coppins-track" class="venue-card__cta">Read the guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Arthurs Seat (1.8km summit circuit)</h3>
          <p class="venue-card__significance">Matthew Flinders Cairn, William Ricketts sculptures, and views that — on a clear day — reach Melbourne, the You Yangs, and Mt Macedon. Moderate difficulty with formed steps. Can combine with the Arthurs Seat Eagle gondola for a one-way walk to the top. Grade: Moderate.</p>
          <a href="/explore/arthurs-seat-lookout" class="venue-card__cta">Read the guide →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="venues" id="audience">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Who's walking</p>
          <h2 class="venues__title">Walks matched to who's coming</h2>
          <p class="venues__sub">Not every walk suits every group. The Peninsula's access rules, terrain, and crowd patterns mean the right walk depends on who is making the trip.</p>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Families</span>
          </div>
          <h3 class="venue-card__name">Family Walks</h3>
          <p class="venue-card__signature">The Cape Schanck boardwalk (20 min, fully accessible) is the best family-appropriate short walk with genuine drama. Mornington foreshore is flat and long enough for varying energy levels. Arthurs Seat TC McKeller Walk is shaded and short. Baldrys Short Circuit in Greens Bush works for older children ready for a proper bush walk. Avoid the clifftop tracks and Coastal Walk section with young children — the exposure and length are not appropriate.</p>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Dog owners</span>
          </div>
          <h3 class="venue-card__name">Dog-Friendly Walks</h3>
          <p class="venue-card__signature">Dogs are banned from Mornington Peninsula National Park (including Cape Schanck, Point Nepean, Two Bays, Coastal Walk) and from Greens Bush and Arthurs Seat State Park. On-lead dogs are generally allowed on bay-side foreshore paths. The Mornington foreshore, Mount Martha clifftop sections, and Rosebud foreshore are your primary options. Verify current conditions with Parks Victoria and local councils before visiting — rules are enforced and change seasonally.</p>
          <a href="/dog-friendly" class="venue-card__cta">Dog-friendly guide →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Walkers seeking a challenge</span>
          </div>
          <h3 class="venue-card__name">Harder Walks</h3>
          <p class="venue-card__signature">The Two Bays Walking Trail (26km) is the Peninsula's definitive full-day challenge. The Coastal Walk section (Cape Schanck to London Bridge, 26–30km) is exposed, demanding, and best done over two days. The full Mornington Peninsula Walk (97.5km) is a multi-day circuit requiring serious planning. Single-day hard options include the full Point Nepean walk (13.5km) combined with the Lifesaving Track (11km) as a long day out.</p>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Wildlife watchers</span>
          </div>
          <h3 class="venue-card__name">Wildlife Walks</h3>
          <p class="venue-card__signature">Greens Bush at dawn or dusk for kangaroos, wallabies, and echidnas. The Coastal Walk corridor for Hooded Plovers (nesting season, spring — stay on the track). Mount Martha clifftop between June and September for whale watching vantage points. The Fingal Beach Track for coastal birds in a quieter setting than the main Cape Schanck corridor. Early morning anywhere in the national park for birdlife.</p>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">History interest</span>
          </div>
          <h3 class="venue-card__name">Historical Walks</h3>
          <p class="venue-card__signature">Point Nepean for military fortifications, the quarantine station, and the Harold Holt memorial. The Lifesaving Track through the National Park for the 1890s context — the track was built after a series of devastating Bass Strait shipwrecks. Arthurs Seat for William Ricketts sculptures and colonial observation history. Each walk carries a historical layer most visitors do not know to look for.</p>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Photographers</span>
          </div>
          <h3 class="venue-card__name">Walks for Photography</h3>
          <p class="venue-card__signature">Bushrangers Bay for basalt cliff and creek-mouth compositions. Coppins Track for clifftop and Bass Strait light. Diamond Bay from above (access via Coppins or Coastal Walk) for the aerial view down into the bay. Farnsworth Track at low sun for the London Bridge stone arch. Cape Schanck boardwalk at dawn for lighthouse and Bass Strait moody conditions. Greens Bush for grasstree subjects.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="venues venues--plain">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Practical notes</p>
          <h2 class="venues__title">Before you go</h2>
          <p class="venues__sub">The Peninsula walks landscape has some consistent conditions that matter regardless of which walk you choose.</p>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <h3 class="venue-card__name">Snakes</h3>
          <p class="venue-card__signature">The Peninsula has Eastern Brown Snakes and Tiger Snakes, both dangerous. Warm months (October to April) require alertness on all bushy and coastal tracks. Stick to the marked track, wear closed shoes, and do not put your hands in grass or under logs. Snake sightings on Greens Bush and the Coastal Walk corridor are not unusual in warm weather.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Sun and Water</h3>
          <p class="venue-card__signature">The Peninsula's exposed clifftop walks have no shade. In summer, midday is not the right time. Early morning or late afternoon are the better windows — and the light is better for photography. Carry at least 500ml per person for any walk over an hour; none of the major walks have water access en route.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Mobile Coverage</h3>
          <p class="venue-card__signature">Coverage is variable across the national park. The Coastal Walk corridor and remote sections of Two Bays have dead zones. Download offline maps before you go if you are walking anything more than an out-and-back on a marked track. In an emergency, the parks have emergency contact points at key carparks and trailheads.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Parking</h3>
          <p class="venue-card__significance">Cape Schanck and London Bridge carparks are busy on summer weekends — arrive before 9am or after 2pm. Parks Victoria charges entry fees at some locations. The Mornington Peninsula National Park entry fee applies across the relevant carparks. Free parking is available at some Greens Bush access points and foreshore locations.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Tide and Conditions</h3>
          <p class="venue-card__significance">The Coastal Walk section and some beach access points require timing around tides. Check conditions before departing for any walk that involves beach crossings or foreshore sections. Bass Strait weather changes quickly — if conditions look uncertain at the carpark, they are likely worse on an exposed clifftop.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Dogs Banned</h3>
          <p class="venue-card__significance">Mornington Peninsula National Park (including Cape Schanck, Bushrangers Bay, Point Nepean, Coastal Walk, Two Bays NP sections) — no dogs at all, including in carparks. Greens Bush and Arthurs Seat State Park — no dogs. Bay foreshore areas — generally on-lead permitted. This is the most common planning error for first-time visitors with dogs. Check before you go.</p>
          <a href="/dog-friendly" class="venue-card__cta">Dog-friendly alternatives →</a>
        </div>
      </div>
    </div>
  </section>

