  ],
});

const faqSchema = buildFaqSchema([
  {
    q: 'What is the best golf course on the Mornington Peninsula?',
    a: "The National's Ocean Course is the most cited for prestige. Moonah Links' Open Course delivers better value and a more enjoyable round for most visiting golfers.",
  },
  {
    q: 'Can you play golf on the Mornington Peninsula without a club membership?',
