const collectionSchema = buildCollectionPageSchema({
  name: 'Mornington Peninsula Golf Courses — Peninsula Insider',
  description: 'All 11 Mornington Peninsula golf courses ranked. Public vs private, what to book, best value, best views.',
  path: '/explore/golf',
  dateModified: '2026-04-23',
});

const itemListSchema = buildItemListSchema({
  name: 'Mornington Peninsula Golf Courses',
  description: '11 Mornington Peninsula golf courses ranked by editorial value.',
  listPath: '/explore/golf',
  items: [
    { name: 'Moonah Links', path: '/explore/moonah-links', itemType: 'GolfCourse', addressLocality: 'Fingal' },
    { name: 'The National Golf Club', path: '/explore/the-national-golf-club', itemType: 'GolfCourse', addressLocality: 'Cape Schanck' },
    { name: 'St Andrews Beach Golf Course', path: '/explore/st-andrews-beach-golf-course', itemType: 'GolfCourse', addressLocality: 'Fingal' },
    { name: 'RACV Cape Schanck Resort Golf Course', path: '/explore/racv-cape-schanck-golf-course', itemType: 'GolfCourse', addressLocality: 'Cape Schanck' },
    { name: 'Flinders Golf Club', path: '/explore/flinders-golf-club', itemType: 'GolfCourse', addressLocality: 'Flinders' },
    { name: 'Eagle Ridge Golf Course', path: '/explore/eagle-ridge-golf-course', itemType: 'GolfCourse', addressLocality: 'Merricks North' },
    { name: 'Mornington Golf Club', path: '/explore/mornington-golf-club', itemType: 'GolfCourse', addressLocality: 'Mornington' },
