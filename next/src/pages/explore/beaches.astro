---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ExperienceCard from '../../components/ExperienceCard.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import {
  buildCollectionPageSchema,
  buildItemListSchema,
  buildFaqSchema,
  buildBreadcrumbSchema,
} from '../../lib/schema';

const experiences = await getCollection('experiences');
const beaches = experiences
  .filter((e) => e.data.type === 'beach')
  .sort((a, b) => (b.data.durationMinutes ?? 0) - (a.data.durationMinutes ?? 0));

const collectionSchema = buildCollectionPageSchema({
  name: 'Best Beaches on the Mornington Peninsula',
  description: "Ranked editorial guide to the Mornington Peninsula's best beaches — bay and ocean, family, surf, dog, and sunset.",
  path: '/explore/beaches',
  dateModified: '2026-04-23',
});

const itemListSchema = buildItemListSchema({
  name: 'Best Beaches on the Mornington Peninsula',
  description: "Ranked editorial guide to the Mornington Peninsula's best beaches.",
  listPath: '/explore/beaches',
  items: [
    { name: 'Balnarring Beach', path: '/explore/balnarring-beach', itemType: 'Beach', addressLocality: 'Balnarring' },
    { name: 'Mount Martha Beach', path: '/explore/mount-martha-beach', itemType: 'Beach', addressLocality: 'Mount Martha' },
    { name: 'Safety Beach foreshore', path: '/explore/safety-beach-foreshore', itemType: 'Beach', addressLocality: 'Safety Beach' },
    { name: 'Dromana Beach', path: '/explore/dromana-beach', itemType: 'Beach', addressLocality: 'Dromana' },
    { name: 'Portsea Front Beach', path: '/explore/portsea-front-beach', itemType: 'Beach', addressLocality: 'Portsea' },
    { name: 'Sorrento Front Beach', path: '/places/sorrento', itemType: 'Beach', addressLocality: 'Sorrento' },
    { name: 'Sorrento Back Beach', path: '/explore/sorrento-back-beach', itemType: 'Beach', addressLocality: 'Sorrento' },
    { name: 'Rye Ocean Beach', path: '/explore/rye-ocean-beach', itemType: 'Beach', addressLocality: 'Rye' },
    { name: 'Gunnamatta Ocean Beach', path: '/explore/gunnamatta-ocean-beach', itemType: 'Beach', addressLocality: 'Rye' },
    { name: 'Portsea Back Beach', path: '/places/portsea', itemType: 'Beach', addressLocality: 'Portsea' },
    { name: 'Balnarring Beach — off-leash section', path: '/explore/balnarring-beach', itemType: 'Beach', addressLocality: 'Balnarring' },
    { name: 'Sorrento Back Beach — off-leash national park section', path: '/explore/sorrento-back-beach', itemType: 'Beach', addressLocality: 'Sorrento' },
    { name: 'Mount Martha Beach — off-leash zones', path: '/explore/mount-martha-beach', itemType: 'Beach', addressLocality: 'Mount Martha' },
  ],
});

const faqSchema = buildFaqSchema([
  {
    q: 'What is the difference between bay beaches and ocean beaches on the Mornington Peninsula?',
    a: 'Bay beaches (Port Phillip side) are calm, warm, and family-appropriate for swimming. Ocean beaches (Bass Strait side) face open water, have surf and rips, and are not recommended for swimming unless you have strong ocean experience and can identify rips. They are worth visiting for scenery and walking.',
  },
  {
    q: 'Which beach is best for families with young children?',
    a: 'Balnarring Beach and Mount Martha Beach. Both have shallow, calm bay water, easy parking, and low-pressure atmospheres. Safety Beach is a solid third option.',
  },
  {
    q: 'Which beach is best for surfing on the Mornington Peninsula?',
    a: 'Gunnamatta Ocean Beach for power and space. Sorrento Back Beach and Rye Ocean Beach for more accessible options. Gunnamatta has no patrol outside summer; experienced surfers only.',
  },
  {
    q: 'Are any beaches dog-friendly on the Mornington Peninsula?',
    a: 'Yes. Several beaches have designated off-leash foreshore sections. Policies are set by Mornington Peninsula Shire and change. Check the current map on the Shire website before visiting.',
  },
  {
    q: 'Is Sorrento Back Beach safe for swimming?',
    a: 'Generally not, without ocean swimming experience and rip recognition skills. It is a surf beach with significant rip activity. It is excellent for walking, sunset-watching, and photography.',
  },
]);

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: 'https://peninsulainsider.com.au/' },
  { name: 'Explore', url: 'https://peninsulainsider.com.au/explore/' },
  { name: 'Beaches' },
]);

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Explore', href: '/explore' },
  { label: 'Beaches' },
];
---

<BaseLayout
  title="Best Beaches on the Mornington Peninsula · Peninsula Insider"
  description="Ranked editorial guide to the Mornington Peninsula's best beaches — bay swimming, ocean surf, family, dog-friendly, and sunset. 13 beaches reviewed."
  section="explore"
  canonical="https://peninsulainsider.com.au/explore/beaches/"
>
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Breadcrumbs items={breadcrumbItems} />

  <article class="article">
    <div class="container">
      <h1 class="article__title">Mornington Peninsula Beaches</h1>

      <div class="prose">
        <blockquote>
          <p><strong>TL;DR</strong></p>
          <ul>
            <li>The Peninsula has two completely different beach types: calm bay (Port Phillip) and surf ocean (Bass Strait / national park).</li>
            <li>Bay beaches suit swimming, families, and toddlers. Ocean beaches suit surfers, walkers, and dramatic scenery.</li>
            <li>Never swim unpatrolled at an ocean beach unless you are an experienced open-water swimmer.</li>
            <li>Best family bay beach: Balnarring or Mount Martha. Best ocean experience: Sorrento Back Beach or Gunnamatta.</li>
          </ul>
        </blockquote>

        <p>The Mornington Peninsula is bounded on its eastern side by Port Phillip Bay and on its western and southern sides by Bass Strait and the Southern Ocean. These are not interchangeable. Port Phillip is enclosed and calm — reliable swimming, shallow entry, minimal wave action. The ocean side is open coast: rip-heavy, surge-prone, and in places genuinely dangerous. Knowing which side you're on is the most important beach-planning decision you'll make.</p>

        <h2>The bay vs back-beach frame</h2>

        <p><strong>Bay beaches</strong> — Port Phillip side: Run from Mount Martha in the north to Portsea and Sorrento at the tip. Generally: calm water, sandy entry, good for families with young children, warmer water in summer, accessible parking.</p>

        <p><strong>Ocean beaches</strong> — Bass Strait / national park side: Run from Rye Ocean Beach through Gunnamatta, Sorrento Back Beach, and Portsea Back Beach to Cape Schanck. Generally: surf, rips, cold water year-round, dramatic cliffs and dunes, far less crowded. Patrols are seasonal and not universal. Experienced swimmers only for ocean entry; everyone else walks and looks.</p>

        <h2>The 13 beaches ranked</h2>

        <h3>Bay beaches</h3>

        <h4>1. <a href="/explore/balnarring-beach/">Balnarring Beach</a> — Balnarring</h4>
        <p>The Peninsula's best shallow-entry family beach. Shallow gradient, rock pools, calm water, a low-key atmosphere that never quite hits the peak-season chaos of Sorrento's bay side. Drive-in parking direct to the foreshore. The Balnarring Farmers Market runs nearby on third Saturdays.</p>
        <p><em>Best for:</em> Families with toddlers. Swimming. Dogs (off-leash section at north end).</p>

        <h4>2. <a href="/explore/mount-martha-beach/">Mount Martha Beach</a> — Mount Martha</h4>
        <p>Good sand, solid café access within walking distance, reliable calm water, and a long foreshore esplanade that rewards the afternoon walk. The Martha Cove end has boat ramp and shallow entry popular with families.</p>
        <p><em>Best for:</em> Families. Swimming. Those staying in the Mornington corridor.</p>

        <h4>3. <a href="/explore/safety-beach-foreshore/">Safety Beach foreshore</a> — Safety Beach</h4>
        <p>Long bay-side foreshore near Dromana — quieter than beaches further south, good birdlife, easy parking. Pairs well with an <a href="/explore/arthurs-seat-lookout/">Arthurs Seat</a> gondola trip (3 km away).</p>
        <p><em>Best for:</em> Families. Early-morning walks. Those based in Dromana.</p>

        <h4>4. <a href="/explore/dromana-beach/">Dromana Beach</a> — Dromana</h4>
        <p>Central location, calm water, decent foreshore strip with food options nearby. The gondola is 3 km up the hill.</p>
        <p><em>Best for:</em> Convenience swimmers. Families combining with <a href="/explore/arthurs-seat-lookout/">Arthurs Seat Eagle</a>.</p>

        <h4>5. <a href="/explore/portsea-front-beach/">Portsea Front Beach</a> — Portsea</h4>
        <p>Calm bay swimming at the Peninsula's tip. Smaller and less hectic than its Sorrento equivalent. The Portsea Hotel is a 2-minute walk. Parking at the tip is limited.</p>
        <p><em>Best for:</em> Tip-of-the-Peninsula swimming. A quiet afternoon drink at the Hotel.</p>

        <h4>6. Sorrento Front Beach — Sorrento</h4>
        <p><a href="/places/sorrento/">Sorrento</a> has a bay-side beach with calm water but this stretch gets crowded in summer from late morning. The Sorrento Ocean Baths — an enclosed tidal pool on the bay side — is a better option if the beach is packed.</p>
        <p><em>Best for:</em> Bay swimming combined with the Sorrento town experience. Early mornings.</p>

        <h3>Ocean beaches</h3>

        <h4>7. <a href="/explore/sorrento-back-beach/">Sorrento Back Beach</a> — Sorrento</h4>
        <p>The best-known ocean beach on the Peninsula. Bass Strait facing, dramatic sandstone cliff backdrop, consistent surf, and clear sightlines to the horizon. No swimming unless you know rip recognition. The car park on Ocean Beach Road fills by 10am on summer weekends.</p>
        <p><em>Best for:</em> Sunsets. Surfers. Clifftop walking. Photographers.</p>

        <h4>8. <a href="/explore/rye-ocean-beach/">Rye Ocean Beach</a> — Rye</h4>
        <p>The most accessible ocean beach for those in the peninsula's middle section. Life-saving patrol in summer season makes this the closest thing to a safe ocean swimming option on the back beach — though rips are still present.</p>
        <p><em>Best for:</em> Supervised surf swimming. Those staying around Rye and Blairgowrie.</p>

        <h4>9. <a href="/explore/gunnamatta-ocean-beach/">Gunnamatta Ocean Beach</a> — Rye / Fingal</h4>
        <p>The Peninsula's most powerful, least-populated ocean beach. Long dune systems, exposed Bass Strait swell, minimal facilities. A patrol operates in summer. Not a family swimming beach without strong surf skills. The walk along the dune ridge is excellent.</p>
        <p><em>Best for:</em> Experienced surfers. Long walks. Anyone wanting a genuinely empty beach.</p>

        <h4>10. Portsea Back Beach — Portsea</h4>
        <p>Rocky, exposed, adjacent to the cliffs of the national park. More dramatic and less visited than Sorrento Back Beach. Cold water year-round.</p>
        <p><em>Best for:</em> Rock platforms. Snorkelling (experienced). Wild weather visits.</p>

        <h3>Dog-friendly highlights</h3>
        <p>The Peninsula has a number of off-leash foreshore areas. Policy changes regularly — always check the local council's current off-leash map before arriving. See the full <a href="/journal/dog-friendly-mornington-peninsula/">dog-friendly Peninsula guide</a>.</p>
        <ul>
          <li><a href="/explore/balnarring-beach/">Balnarring Beach</a> — off-leash section at north end</li>
          <li><a href="/explore/sorrento-back-beach/">Sorrento Back Beach</a> — off-leash areas in national park foreshore (seasonally restricted in areas)</li>
          <li><a href="/explore/mount-martha-beach/">Mount Martha Beach</a> — check Mornington Peninsula Shire current off-leash zones</li>
        </ul>

        <h2>Swim safety</h2>
        <p>Ocean rips are the primary risk on all back beaches. The rule: if in doubt, don't enter the water. Swim between the flags at any patrolled beach. Life-saving patrols operate on Rye Ocean Beach and Gunnamatta in summer.</p>

        <h2>Also read</h2>
        <ul>
          <li><a href="/journal/mornington-peninsula-beach-guide/">The Peninsula beach swimming guide</a></li>
          <li><a href="/journal/dog-friendly-mornington-peninsula/">Dog-friendly Peninsula guide</a></li>
          <li><a href="/explore/walks/">Coastal walks and hinterland tracks</a> — many beaches connect to walks</li>
          <li><a href="/explore/family-friendly/">Family-friendly things to do</a></li>
        </ul>

        <p><em>Last fact-verified 23 April 2026</em></p>

        <h2>FAQ</h2>

        <h3>What is the difference between bay beaches and ocean beaches on the Mornington Peninsula?</h3>
        <p>Bay beaches (Port Phillip side) are calm, warm, and family-appropriate for swimming. Ocean beaches (Bass Strait side) face open water, have surf and rips, and are not recommended for swimming unless you have strong ocean experience and can identify rips. They are worth visiting for scenery and walking.</p>

        <h3>Which beach is best for families with young children?</h3>
        <p>Balnarring Beach and Mount Martha Beach. Both have shallow, calm bay water, easy parking, and low-pressure atmospheres. Safety Beach is a solid third option.</p>

        <h3>Which beach is best for surfing on the Mornington Peninsula?</h3>
        <p>Gunnamatta Ocean Beach for power and space. Sorrento Back Beach and Rye Ocean Beach for more accessible options. Gunnamatta has no patrol outside summer; experienced surfers only.</p>

        <h3>Are any beaches dog-friendly on the Mornington Peninsula?</h3>
        <p>Yes. Several beaches have designated off-leash foreshore sections. Policies are set by Mornington Peninsula Shire and change. Check the current map on the Shire website before visiting.</p>

        <h3>Is Sorrento Back Beach safe for swimming?</h3>
        <p>Generally not, without ocean swimming experience and rip recognition skills. It is excellent for walking, sunset-watching, and photography.</p>
      </div>
    </div>
  </article>

  {beaches.length > 0 && (
    <section class="experience-index">
      <div class="container">
        <div class="venues__header">
          <div>
            <p class="label label--accent">All beaches · {beaches.length} tracked</p>
            <h2 class="venues__title">All beaches on the Mornington Peninsula</h2>
            <p class="venues__sub">Every beach tracked in our collection — with beach type, best-for notes, and an honest editor rating.</p>
          </div>
          <a href="/explore/" class="venues__link">All experiences →</a>
        </div>
        <div class="experience-grid">
          {beaches.map((beach) => <ExperienceCard experience={beach} />)}
        </div>
      </div>
    </section>
  )}

  <NewsletterBlock />
</BaseLayout>
