---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHero from '../../components/SectionHero.astro';
import ExperienceCard from '../../components/ExperienceCard.astro';
import PlaceCard from '../../components/PlaceCard.astro';
import ItineraryCard from '../../components/ItineraryCard.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { routeSlug, currentSeason, seasonBlurb, experienceInSeason, heroBackgroundStyle } from '../../lib/editorial';

const experiences = (await getCollection('experiences'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
const places = await getCollection('places');
const itinerariesAll = await getCollection('itineraries');
const itinerarySlugs = [
  'flinders-and-cape-reset',
  'ridge-to-sea-two-night-escape',
  'sorrento-off-season-weekend',
];
const itineraries = itinerarySlugs
  .map((slug) => itinerariesAll.find((itinerary) => routeSlug(itinerary) === slug))
  .filter((itinerary): itinerary is NonNullable<typeof itinerary> => Boolean(itinerary));
const articlesAll = (await getCollection('articles', ({ data }) => data.status === 'published'))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const season = currentSeason();
const blurb = seasonBlurb[season];

const featured = experiences.find((entry) => routeSlug(entry) === 'bushrangers-bay-walk') ?? experiences[0];

// Split experiences by type so the hub is a real navigation surface.
const walks = experiences.filter((e) => e.data.type === 'walk');
const beaches = experiences.filter((e) => e.data.type === 'beach');
const lookouts = experiences.filter((e) => e.data.type === 'lookout');
const markets = experiences.filter((e) => e.data.type === 'market');
const wellness = experiences.filter((e) => e.data.type === 'wellness');
const galleriesAttractions = experiences.filter((e) => ['gallery', 'attraction', 'park', 'tour'].includes(e.data.type));

// Short walks under 60 min  -  "between meals" layer.
const shortWalks = walks.filter((e) => (e.data.durationMinutes ?? 999) <= 60).slice(0, 4);
// Proper coastal walks  -  anything 60+ minutes, tagged a walk.
const longWalks = walks.filter((e) => (e.data.durationMinutes ?? 0) > 60).slice(0, 6);

// Seasonal experiences that actually match right now.
const seasonal = experiences.filter((e) => experienceInSeason(e, season)).slice(0, 8);

const featuredPlaces = places.filter((place) => ['cape-schanck', 'point-nepean', 'sorrento', 'red-hill'].includes(routeSlug(place)));

const companionSlugs = [
  'the-point-nepean-half-day',
  'the-peninsula-beach-swimming-guide',
  'the-market-saturday',
  'the-peninsulas-best-late-afternoon-walks',
  'the-rainy-day-peninsula-without-a-booking',
  'the-peninsula-with-kids',
];
const companionReads = companionSlugs
  .map((slug) => articlesAll.find((a) => routeSlug(a) === slug))
  .filter((a): a is NonNullable<typeof a> => Boolean(a));

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Explore' },
];
---

<BaseLayout
  title="Things to Do on the Mornington Peninsula · Peninsula Insider"
  description="The best things to do on the Mornington Peninsula — coastal walks, swimming beaches, lookouts, hot springs, markets, and the experiences that earn the weekend. Updated April 2026."
  section="explore"
  canonical="https://peninsulainsider.com.au/explore"
  modifiedTime="2026-04-13"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org', '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'What are the best things to do on the Mornington Peninsula?',
        acceptedAnswer: { '@type': 'Answer', text: 'The essentials: walk Bushrangers Bay or Cape Schanck boardwalk, swim at Sorrento Back Beach or Mornington foreshore, visit Peninsula Hot Springs, explore cellar doors on the Red Hill plateau, eat a vineyard lunch, and catch Red Hill Market (first Saturday of the month). For a full day, combine a morning walk with an afternoon cellar door visit and a sunset beach.' }},
      { '@type': 'Question', name: 'What are the best beaches on the Mornington Peninsula?',
        acceptedAnswer: { '@type': 'Answer', text: 'Bay side (calm, family-friendly): Mornington, Mount Martha, Safety Beach. Ocean side (surf, dramatic): Sorrento Back Beach, Gunnamatta, Rye Back Beach, Point Nepean. The two coasts feel completely different — the bay is sheltered and warm, the ocean is wild Southern Ocean. Most visitors underestimate how close they are (15–20 minutes apart).' }},
      { '@type': 'Question', name: 'Is Peninsula Hot Springs worth it?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes — but book a weekday or early morning session. Weekend afternoons are crowded and the experience suffers. The hilltop pools with bay views are the highlight. Family sessions are time-limited and must be booked in advance. Alba Thermal Springs near Red Hill is a quieter alternative with dedicated silent bathing circuits.' }},
    ],
  })} />
  <Breadcrumbs items={breadcrumbItems} />
  <SectionHero
    eyebrow="Explore"
    subEyebrow="Walks · beaches · lookouts · markets"
    title="The Peninsula gets better once you leave the <em>table.</em>"
    dek="The strongest weekends here are not built on bookings alone. They need coastline, weather, a market detour, or one good walk between lunch and sunset. This section maps those moves properly."
    gradient="bay"
    visualLabel="Cape Schanck walking trail"
    heroImage="/images/sourced/explore-hub-hero-01.webp"
  />

  <section class="format-nav">
    <div class="container">
      <p class="label label--accent format-nav__label">Pick a move</p>
      <div class="format-nav__chips">
        {longWalks.length > 0 && <a href="#long-walks" class="format-chip"><span class="format-chip__name">Coastal walks</span><span class="format-chip__count">{longWalks.length}</span></a>}
        {shortWalks.length > 0 && <a href="#short-walks" class="format-chip"><span class="format-chip__name">Between-meal walks</span><span class="format-chip__count">{shortWalks.length}</span></a>}
        {beaches.length > 0 && <a href="#beaches" class="format-chip"><span class="format-chip__name">Beaches</span><span class="format-chip__count">{beaches.length}</span></a>}
        {lookouts.length > 0 && <a href="#lookouts" class="format-chip"><span class="format-chip__name">Lookouts</span><span class="format-chip__count">{lookouts.length}</span></a>}
        {markets.length > 0 && <a href="#markets" class="format-chip"><span class="format-chip__name">Markets</span><span class="format-chip__count">{markets.length}</span></a>}
        {wellness.length > 0 && <a href="#wellness" class="format-chip"><span class="format-chip__name">Wellness</span><span class="format-chip__count">{wellness.length}</span></a>}
        {galleriesAttractions.length > 0 && <a href="#culture" class="format-chip"><span class="format-chip__name">Galleries & attractions</span><span class="format-chip__count">{galleriesAttractions.length}</span></a>}
        <a href="#all" class="format-chip"><span class="format-chip__name">All experiences</span><span class="format-chip__count">{experiences.length}</span></a>
      </div>
    </div>
  </section>

  {featured && (
    <section class="feature feature--compact">
      <div class="container">
        <div class="feature__inner">
          <div class="feature__image-block feature__image-block--bay" aria-hidden="true" style={heroBackgroundStyle(featured.data)}>
            <div class="feature__image-overlay"></div>
            <span class="feature__image-tag">Editor's pick</span>
          </div>
          <div class="feature__content">
            <div class="feature__label">
              <span class="label label--accent">Start here</span>
            </div>
            <h2 class="feature__title">
              <a href={`/explore/${routeSlug(featured)}`}>{featured.data.name}</a>
            </h2>
            <p class="feature__dek">{featured.data.editorNote}</p>
            <div class="feature__byline">
              {featured.data.durationMinutes && (
                <>
                  <span class="feature__byline-name">{featured.data.durationMinutes} min return</span>
                  <span class="feature__byline-dot" aria-hidden="true"></span>
                </>
              )}
              <span class="feature__byline-meta">{String(featured.data.difficulty ?? 'easy').replace(/\b\w/g, (l) => l.toUpperCase())}</span>
            </div>
            <a href={`/explore/${routeSlug(featured)}`} class="feature__cta">Read the guide →</a>
          </div>
        </div>
      </div>
    </section>
  )}

  {seasonal.length > 0 && (
    <section class="experience-index experience-index--plain">
      <div class="container">
        <div class="split-intro">
          <div>
            <p class="label label--accent">{blurb.label}</p>
            <h2 class="split-intro__title">What the Peninsula is best at right now</h2>
          </div>
          <p class="split-intro__body">{blurb.line}</p>
        </div>
        <div class="experience-grid">
          {seasonal.map((experience) => <ExperienceCard experience={experience} />)}
        </div>
      </div>
    </section>
  )}

  {longWalks.length > 0 && (
    <section class="experience-index" id="long-walks">
      <div class="container">
        <div class="venues__header">
          <div>
            <p class="label label--accent">Coastal walks</p>
            <h2 class="venues__title">The proper walks that reset the weekend</h2>
            <p class="venues__sub">Cape Schanck, Bushrangers Bay, the Two Bays. These are the walks worth clearing an afternoon for.</p>
          </div>
          <a href="/journal/the-peninsulas-best-late-afternoon-walks" class="venues__link">Read the walks piece →</a>
        </div>
        <div class="experience-grid">
          {longWalks.map((experience) => <ExperienceCard experience={experience} />)}
        </div>
      </div>
    </section>
  )}

  {shortWalks.length > 0 && (
    <section class="experience-index experience-index--plain" id="short-walks">
      <div class="container">
        <div class="venues__header">
          <div>
            <p class="label label--accent">Between-meal walks</p>
            <h2 class="venues__title">Under an hour · good between lunch and dinner</h2>
            <p class="venues__sub">For the gap in the weekend when a long walk is too much and doing nothing feels wrong.</p>
          </div>
        </div>
        <div class="experience-grid">
          {shortWalks.map((experience) => <ExperienceCard experience={experience} />)}
        </div>
      </div>
    </section>
  )}

  {beaches.length > 0 && (
    <section class="experience-index" id="beaches">
      <div class="container">
        <div class="venues__header">
          <div>
            <p class="label label--accent">Beaches</p>
            <h2 class="venues__title">Which beach, and why</h2>
            <p class="venues__sub">The bay calm versus the back beaches  -  pick the one that matches the weather, not the one closest to the car.</p>
          </div>
          <a href="/journal/the-peninsula-beach-swimming-guide" class="venues__link">Beach guide →</a>
        </div>
        <div class="experience-grid">
          {beaches.map((experience) => <ExperienceCard experience={experience} />)}
        </div>
      </div>
    </section>
  )}

  {lookouts.length > 0 && (
    <section class="experience-index experience-index--plain" id="lookouts">
      <div class="container">
        <div class="venues__header">
          <div>
            <p class="label label--accent">Lookouts</p>
            <h2 class="venues__title">Where the Peninsula lays itself out for you</h2>
            <p class="venues__sub">Short stops, long views  -  the moments that make the drive home feel considered.</p>
          </div>
        </div>
        <div class="experience-grid">
          {lookouts.map((experience) => <ExperienceCard experience={experience} />)}
        </div>
      </div>
    </section>
  )}

  {markets.length > 0 && (
    <section class="experience-index" id="markets">
      <div class="container">
        <div class="venues__header">
          <div>
            <p class="label label--accent">Markets</p>
            <h2 class="venues__title">Saturday mornings that shape the rest of the trip</h2>
            <p class="venues__sub">Farmers' markets, makers' days, and the produce-first way into a Peninsula weekend.</p>
          </div>
          <a href="/journal/the-market-saturday" class="venues__link">Market guide →</a>
        </div>
        <div class="experience-grid">
          {markets.map((experience) => <ExperienceCard experience={experience} />)}
        </div>
      </div>
    </section>
  )}

  {wellness.length > 0 && (
    <section class="experience-index experience-index--plain" id="wellness">
      <div class="container">
        <div class="venues__header">
          <div>
            <p class="label label--accent">Wellness</p>
            <h2 class="venues__title">Springs, sauna, and the slow layer</h2>
            <p class="venues__sub">When the weekend needs to reset, not perform.</p>
          </div>
        </div>
        <div class="experience-grid">
          {wellness.map((experience) => <ExperienceCard experience={experience} />)}
        </div>
      </div>
    </section>
  )}

  {galleriesAttractions.length > 0 && (
    <section class="experience-index" id="culture">
      <div class="container">
        <div class="venues__header">
          <div>
            <p class="label label--accent">Galleries & attractions</p>
            <h2 class="venues__title">Non-beach, non-cellar-door afternoons</h2>
            <p class="venues__sub">The culture layer  -  useful when the weather turns or the weekend needs a quieter pace.</p>
          </div>
        </div>
        <div class="experience-grid">
          {galleriesAttractions.map((experience) => <ExperienceCard experience={experience} />)}
        </div>
      </div>
    </section>
  )}

  <section class="experience-index experience-index--plain" id="all">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Every explore entry</p>
          <h2 class="venues__title">All {experiences.length} Peninsula moves, alphabetical</h2>
          <p class="venues__sub">For when you already know what you're looking for.</p>
        </div>
      </div>
      <div class="experience-grid">
        {experiences.map((experience) => <ExperienceCard experience={experience} />)}
      </div>
    </div>
  </section>

  {featuredPlaces.length > 0 && (
    <section class="places">
      <div class="container">
        <div class="places__header">
          <p class="label label--accent places__label">By terrain</p>
          <h2 class="places__title">Explore by pocket of the Peninsula</h2>
          <p class="places__sub">Each place hub sequences walks, beaches, and lookouts into a real stretch of landscape.</p>
        </div>
        <div class="places__grid">
          {featuredPlaces.map((place, index) => (
            <PlaceCard
              place={place}
              variant={index % 3 === 1 ? 'bay' : index % 3 === 2 ? 'sand' : 'vineyard'}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {itineraries.length > 0 && (
    <section class="escape-callout">
      <div class="container">
        <div class="venues__header">
          <div>
            <p class="label label--accent">Turn it into a weekend</p>
            <h2 class="venues__title">These explore notes feed directly into our escape plans</h2>
            <p class="venues__sub">Walks and lookouts matter most when they are sequenced with the right lunch and the right bed.</p>
          </div>
          <a href="/escape" class="venues__link">See all escapes →</a>
        </div>
        <div class="itinerary-grid">
          {itineraries.map((itinerary) => <ItineraryCard itinerary={itinerary} />)}
        </div>
      </div>
    </section>
  )}

  {companionReads.length > 0 && (
    <section class="venues venues--plain">
      <div class="container">
        <div class="venues__header">
          <div>
            <p class="label label--accent">From the Journal</p>
            <h2 class="venues__title">Further reading for the afternoon half of the trip</h2>
          </div>
          <a href="/journal" class="venues__link">Journal →</a>
        </div>
        <div class="venues__grid">
          {companionReads.map((article) => <ArticleCard article={article} />)}
        </div>
      </div>
    </section>
  )}

  <section class="venues venues--plain">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Go deeper</p>
          <h2 class="venues__title">Guides for getting outside on the Peninsula</h2>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card"><h3 class="venue-card__name"><a href="/explore/best-walks">Best Walks on the Peninsula</a></h3><p class="venue-card__signature">Coastal boardwalks, cliff-top traverses, and short hinterland loops — the ten walks that define the region.</p><a href="/explore/best-walks" class="venue-card__cta">Read the guide →</a></div>
        <div class="venue-card"><h3 class="venue-card__name"><a href="/journal/free-things-to-do-mornington-peninsula">Free Things to Do</a></h3><p class="venue-card__signature">Beaches, walks, lookouts, markets — the experiences that cost nothing and deliver everything.</p><a href="/journal/free-things-to-do-mornington-peninsula" class="venue-card__cta">Read the guide →</a></div>
        <div class="venue-card"><h3 class="venue-card__name"><a href="/journal/mornington-peninsula-hot-springs-guide">Hot Springs Guide</a></h3><p class="venue-card__signature">Peninsula Hot Springs vs Alba — when to go, which session, and what most guides get wrong.</p><a href="/journal/mornington-peninsula-hot-springs-guide" class="venue-card__cta">Read the guide →</a></div>
        <div class="venue-card"><h3 class="venue-card__name"><a href="/journal/mornington-peninsula-with-kids">Peninsula With Kids</a></h3><p class="venue-card__signature">The honest family-weekend playbook. What actually works with under-10s, and the places that pretend to be kid-friendly but aren't.</p><a href="/journal/mornington-peninsula-with-kids" class="venue-card__cta">Read the guide →</a></div>
        <div class="venue-card"><h3 class="venue-card__name"><a href="/journal/dog-friendly-mornington-peninsula">Dog-Friendly Peninsula</a></h3><p class="venue-card__signature">Off-leash beaches, cafés that say yes, and the stays that actually want a labrador in the lounge.</p><a href="/journal/dog-friendly-mornington-peninsula" class="venue-card__cta">Read the guide →</a></div>
        <div class="venue-card"><h3 class="venue-card__name"><a href="/golf">Best Golf Courses</a></h3><p class="venue-card__signature">St Andrews Beach, Moonah Links, The Dunes — tier-ranked public and private courses, with weekend-planning guidance.</p><a href="/golf" class="venue-card__cta">Read the guide →</a></div>
      </div>
    </div>
  </section>

  <NewsletterBlock />
</BaseLayout>
