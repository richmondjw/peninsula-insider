---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { routeSlug } from '../../lib/editorial';

const allArticles = await getCollection('articles', ({ data }) => data.status === 'published');
const corporateArticles = allArticles
  .filter((a) => a.data.tags?.some((t) => ['corporate', 'corporate-events', 'retreats', 'offsite'].includes(t)))
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Corporate Events' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What are the best corporate retreat venues on the Mornington Peninsula?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'For executive retreats: Jackalope (Merricks North), Lancemore Lindenderry Red Hill, and boutique hinterland properties in the Flinders and Shoreham corridor. For larger conference-scale events: RACV Cape Schanck Resort and The Continental Sorrento. For a winery-led offsite with dining at the centre: Montalto and properties in the Red Hill corridor. The best venue depends on group size, format, and whether you need structured meeting infrastructure or a retreat-feel environment.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is the Mornington Peninsula good for corporate retreats?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes — it sits at the right distance from Melbourne for a reset (90 minutes, far enough to feel different), has strong hospitality infrastructure, and can serve groups from 6 to 200 depending on the venue. The Peninsula\'s combination of wineries, spa, golf, and coastal experiences gives a retreat meaningful downtime without resorting to contrived team-building activities.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the difference between an executive retreat and a conference on the Mornington Peninsula?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'An executive retreat is typically a smaller senior-team gathering (6–30 people) at a boutique or private property focused on strategy, culture, or reset. A conference is a larger structured event (40–200+ people) requiring delegate logistics, AV infrastructure, breakout rooms, and catering at scale. The Peninsula handles both, but different venues serve each format. Do not send an executive retreat group to a large conference venue — the size ratio undermines the retreat feel.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which Mornington Peninsula areas are best for a corporate retreat?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Red Hill for a food-and-wine retreat texture with quality dining built into the programme. Sorrento for a polished coastal town feel where the entire group can walk between venues. Cape Schanck for resort-scale infrastructure with accommodation, golf, and spa in one location. Flinders and Shoreham for quiet, private, high-focus retreats with a natural setting. Mornington for the easiest access logistics from Melbourne.',
      },
    },
    {
      '@type': 'Question',
      name: 'How far is the Mornington Peninsula from Melbourne for a corporate event?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most Peninsula corporate venues are 75 to 105 minutes from Melbourne CBD. Mornington is closest at 60–75 minutes. Red Hill and the hinterland is 80–90 minutes. Sorrento, Cape Schanck, and the southern tip is 90–105 minutes. The distance is an asset — far enough that participants mentally leave the office, close enough that it is manageable without flights.',
      },
    },
  ],
};

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Mornington Peninsula Corporate Events and Retreats Guide',
  description: 'A selective guide to corporate retreats, executive offsites, and premium business events on the Mornington Peninsula — venue intelligence, programme planning, and locality guidance.',
  url: 'https://peninsulainsider.com.au/corporate-events',
  about: {
    '@type': 'Thing',
    name: 'Mornington Peninsula corporate retreats and offsite venues',
  },
};
---

<BaseLayout
  title="Mornington Peninsula Corporate Events &amp; Retreats: The Insider Guide · Peninsula Insider"
  description="A selective guide to corporate retreats, executive offsites, and business events on the Mornington Peninsula — venue intelligence, programme design, and the localities that suit different event formats."
  section="explore"
  canonical="https://peninsulainsider.com.au/corporate-events"
  modifiedTime="2026-04-19"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />

  <Breadcrumbs items={breadcrumbItems} />

  <section class="section-hero">
    <div class="container">
      <div class="section-hero__inner">
        <div class="section-hero__content">
          <p class="label label--accent">Corporate Events &amp; Retreats</p>
          <h1 class="section-hero__title">Mornington Peninsula Corporate Events</h1>
          <p class="section-hero__dek">Teams and planners are not only choosing a venue. They are choosing what kind of Peninsula offsite or retreat will actually work — executive retreat, leadership offsite, strategy day, or conference. This section helps you make that decision with the right information.</p>
        </div>
        <div class="section-hero__visual" aria-hidden="true" style="background-image: url(/images/sourced/stay-vineyard-01.webp); background-size: cover; background-position: center;">
          <div class="section-hero__visual-fog"></div>
          <span class="section-hero__visual-label">Corporate Retreats · Executive Offsites · Peninsula</span>
        </div>
      </div>
    </div>
  </section>

  <section class="format-nav">
    <div class="container">
      <p class="label label--accent format-nav__label">Plan your event</p>
      <div class="format-nav__chips">
        <a href="#event-formats" class="format-chip"><span class="format-chip__name">Event formats</span></a>
        <a href="#by-location" class="format-chip"><span class="format-chip__name">By location</span></a>
        <a href="#programme" class="format-chip"><span class="format-chip__name">Programme logic</span></a>
        <a href="#planning" class="format-chip"><span class="format-chip__name">Planning</span></a>
        <a href="#faq" class="format-chip"><span class="format-chip__name">Common questions</span></a>
      </div>
    </div>
  </section>

  <section class="editorial-promise">
    <div class="container">
      <div class="editorial-promise__inner">
        <div>
          <p class="label label--accent">The Peninsula Insider approach</p>
          <h2 class="editorial-promise__title">Premium hospitality lens. Zero MICE jargon.</h2>
        </div>
        <div>
          <p>Most corporate event guides choose between destination marketing and venue-sales copy. We do neither. Peninsula Insider helps planners and teams understand what kind of offsite the Peninsula can genuinely deliver — and which venues suit which groups, formats, and objectives.</p>
          <p>A strong conference venue is not automatically a strong leadership retreat venue. A brilliant lunch venue may not be a strong all-day offsite location. These distinctions matter. We make them.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="venues" id="event-formats">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Event formats</p>
          <h2 class="venues__title">Start with the format, not the venue</h2>
          <p class="venues__sub">The Peninsula can serve very different event formats. Each requires a different venue type, locality, and programme structure. Identify the format first.</p>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">6–20 people</span>
          </div>
          <h3 class="venue-card__name">Executive Retreat</h3>
          <p class="venue-card__signature">A small senior-team gathering focused on strategy, reset, or culture work. The format that benefits most from a boutique or private property where the group is not sharing space with other events. The Peninsula excels here — the hinterland and Flinders corridor have quiet, private properties that create the right conditions for focused work.</p>
          <p class="venue-card__signature"><strong>Best for:</strong> Boards, leadership teams, founding teams</p>
          <p class="venue-card__signature"><strong>Best areas:</strong> Red Hill, Flinders, Merricks North</p>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">15–60 people</span>
          </div>
          <h3 class="venue-card__name">Leadership Offsite</h3>
          <p class="venue-card__signature">A structured working retreat with a mix of sessions, activities, and shared meals. Needs space for focused work, decent AV, accommodation either onsite or within 10 minutes, and an evening programme that does not feel forced. The Peninsula handles this well at the right venue — avoid oversizing the venue to the group.</p>
          <p class="venue-card__signature"><strong>Best for:</strong> Senior leadership teams, departmental offsites</p>
          <p class="venue-card__signature"><strong>Best areas:</strong> Red Hill, Sorrento, Cape Schanck</p>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">40–200 people</span>
          </div>
          <h3 class="venue-card__name">Conference &amp; Large-Group Events</h3>
          <p class="venue-card__signature">Events that need delegate infrastructure — structured AV, breakout rooms, catering at scale, and accommodation blocks. The Peninsula's capacity here is more limited than Melbourne, but RACV Cape Schanck and The Continental Sorrento both handle genuine conference-scale groups with the right infrastructure.</p>
          <p class="venue-card__signature"><strong>Best for:</strong> Annual conferences, all-hands, large team events</p>
          <p class="venue-card__signature"><strong>Best venues:</strong> RACV Cape Schanck, The Continental Sorrento</p>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Any size</span>
          </div>
          <h3 class="venue-card__name">Winery &amp; Dining-Led Offsite</h3>
          <p class="venue-card__signature">An offsite structured around the Peninsula's food and wine identity. Morning session, vineyard lunch, afternoon cellar door visit, private dinner. The Peninsula is built for this format — the quality of the dining experience is the programme. Works best for groups who want something memorable over something productive.</p>
          <p class="venue-card__signature"><strong>Best for:</strong> Client hospitality, team rewards, agency offsites</p>
          <p class="venue-card__signature"><strong>Best areas:</strong> Red Hill, Main Ridge, Merricks</p>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Day trip</span>
          </div>
          <h3 class="venue-card__name">Daytrip Strategy Session</h3>
          <p class="venue-card__signature">Out and back from Melbourne in a day. Morning drive, structured session, working lunch, afternoon activity, drive home. Requires a venue with a strong private dining or meeting room, not a full retreat infrastructure. Mornington and Dromana are the easiest access points for a daytrip format.</p>
          <p class="venue-card__signature"><strong>Best for:</strong> Teams that cannot commit to an overnight</p>
          <p class="venue-card__signature"><strong>Best areas:</strong> Mornington, Dromana, closer Peninsula</p>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Any size</span>
          </div>
          <h3 class="venue-card__name">End-of-Year &amp; Client Events</h3>
          <p class="venue-card__signature">The Peninsula as a destination for a premium end-of-year event or client dinner. The vineyard and coastal settings are strong for this format — they feel like a gesture rather than a venue hire. Private dining rooms, cellar door exclusives, and coastal terrace events all work well here.</p>
          <p class="venue-card__signature"><strong>Best for:</strong> Client hospitality, EOY celebrations</p>
          <p class="venue-card__signature"><strong>Best venues:</strong> Montalto, Ten Minutes by Tractor, Pt. Leo Estate</p>
        </div>
      </div>
    </div>
  </section>

  <section class="venues venues--plain" id="by-location">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">By location</p>
          <h2 class="venues__title">The Peninsula localities, matched to event types</h2>
          <p class="venues__sub">Each Peninsula area has a different character, access profile, and venue type concentration. Choose the right area before choosing the venue.</p>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/places/red-hill">Red Hill &amp; Main Ridge</a></h3>
          <p class="venue-card__signature">The food-and-wine retreat territory. Best for groups where the dining programme is the centrepiece — long vineyard lunches, private cellar door sessions, and dinners at restaurants that would be difficult to book otherwise. Accommodation is scattered in villas and cottages; not the most convenient for large groups. Strong for boutique executive retreat formats and client hospitality events.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/places/sorrento">Sorrento</a></h3>
          <p class="venue-card__signature">A coastal town with a concentrated precinct feel. The Continental Sorrento handles conference-scale events with accommodation, AV, and catering under one roof. The town's restaurants and foreshore create a genuine evening programme without a coach. Best for groups where delegate walkability and town-centre access matter — the strongest coastal Peninsula base for medium-sized events.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Cape Schanck &amp; Fingal</h3>
          <p class="venue-card__signature">Resort infrastructure. RACV Cape Schanck has the largest accommodation and conference capacity on the Peninsula, with golf, spa, and recreation built in. Best for large-group events where everything needs to be on one property, or where the group is big enough to fill a resort. Less boutique; more infrastructure. An important market to understand even if you end up elsewhere.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Merricks North &amp; Balnarring</h3>
          <p class="venue-card__signature">Design-led retreat country. Jackalope in Merricks North is the Peninsula's most architecturally distinctive property — a strong choice for brands and teams where the visual context of the event matters. Limited group size but high quality. The spa at Jackalope adds a recovery dimension for multi-day retreats.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/places/flinders">Flinders &amp; Shoreham</a></h3>
          <p class="venue-card__signature">Quiet, private, away from the main Peninsula tourist corridors. Best for small senior-team retreats where focus matters more than amenity — the kind of offsite where you want participants to be unreachable from the office. Limited venue inventory, which is partly the point.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Mornington &amp; Dromana</h3>
          <p class="venue-card__signature">Easiest access from Melbourne. Best for daytrip strategy sessions and events where the primary constraint is minimising drive time. Less resort-feel than the southern Peninsula, but logistically the most practical option for Melbourne-based teams.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="venues" id="programme">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Programme logic</p>
          <h2 class="venues__title">How to build the offsite programme</h2>
          <p class="venues__sub">The Peninsula gives you real options beyond "morning session, team-building, dinner." These are the moves that make a Peninsula retreat worth leaving Melbourne for.</p>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <h3 class="venue-card__name">The One-Night Retreat Structure</h3>
          <p class="venue-card__signature">Day 1: drive down, 2-hour focused session, vineyard lunch, 90-minute afternoon session, private dinner, accommodation onsite or nearby. Day 2: morning walk or spa, 2-hour wrap session, lunch, drive back. This is the Peninsula retreat format that consistently works — enough time to disconnect, structured enough to justify the travel.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">The Vineyard Lunch Programme</h3>
          <p class="venue-card__signature">A 2-hour morning session, followed by a private vineyard lunch at a restaurant like Montalto, Ten Minutes by Tractor, or Pt. Leo Estate. The lunch is the programme. No forced activities, no team-building theatre — just a genuinely exceptional meal that creates the right conversation conditions. Strong for client events and senior-team dinners.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Walk + Workshop Structure</h3>
          <p class="venue-card__signature">A structured coastal walk in the morning (Cape Schanck, Bushrangers Bay, or the Sorrento foreshore), followed by a working session in the afternoon. The walk creates the energy shift that most conference rooms cannot. Works best for groups of 15 or fewer — larger groups are harder to move efficiently on the Peninsula's walking tracks.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Spa as Recovery Layer</h3>
          <p class="venue-card__signature">Peninsula Hot Springs or Alba Thermal Springs as the second-day recovery move for a two-night retreat. Either a morning session before the drive back, or a booked twilight session on the first evening as a group activity. The hot springs work as a natural conversation space — more useful than a bar, less performative than an activity.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Golf Add-On</h3>
          <p class="venue-card__signature">The Peninsula has world-ranked public-access golf at St Andrews Beach and Moonah Links, within 20 minutes of the main retreat corridor. For groups with golfers, a morning round followed by lunch is a strong add-on to a one-night retreat. Does not suit every group — only worth doing if most of the team plays.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Cellar Door Afternoon</h3>
          <p class="venue-card__signature">The Red Hill cellar door circuit as a structured afternoon activity — 2 or 3 cellar door stops over 3 hours, each with a private tasting and a producer conversation. More enjoyable than it sounds, even for non-wine people, when the venues are curated correctly. Works as an afternoon between sessions on a two-day programme.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="venues venues--plain" id="planning">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Planning</p>
          <h2 class="venues__title">What planners most often underestimate</h2>
          <p class="venues__sub">The Peninsula is not a difficult event destination, but it has specific planning requirements that Melbourne events do not.</p>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <h3 class="venue-card__name">Transport</h3>
          <p class="venue-card__signature">A coach from Melbourne to Red Hill or Cape Schanck is $800–$2,000 depending on size and vehicle type. For groups over 20, it is usually the right call — it removes the parking question, means everyone arrives together, and allows the group to have drinks without driving decisions. For smaller groups, self-drive with accommodation onsite often works better.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">AV and Meeting Infrastructure</h3>
          <p class="venue-card__signature">Not every Peninsula venue has strong in-room AV. Boutique properties and vineyard venues often have limited infrastructure — appropriate for retreat-format sessions but not for presentation-heavy conferences. Check AV capability explicitly before committing, especially for multi-day formats with morning and afternoon sessions that require reliable display and connectivity.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Venue vs. Format Fit</h3>
          <p class="venue-card__signature">A luxurious vineyard property is not automatically a strong working-session venue. The aesthetics that make it beautiful for a dinner may not suit a morning that needs whiteboards, reliable WiFi, and a room that does not look exactly like a wine tasting room. Match the venue to the programme requirement, not just the visual ambition.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Accommodation Block Logistics</h3>
          <p class="venue-card__signature">Unless the venue has onsite accommodation for the full group, you are managing accommodation spread across the Peninsula. Holiday houses that sleep 8–12 are the most common solution — book them in advance and assign them by internal team structure. Centralise accommodation near the venue rather than near a town; the commute to breakfast matters.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Lead Time</h3>
          <p class="venue-card__significance">Peak season (October to April) at popular retreat venues books 3 to 6 months ahead. For the most in-demand properties, longer. If the event date is fixed, confirm venue availability before committing the date to participants. The Peninsula has enough good options that a three-month lead time usually works, but the best boutique properties fill faster than you expect.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Wet Weather</h3>
          <p class="venue-card__significance">The Peninsula's weather is variable, especially in autumn and winter. If the programme includes outdoor activities — walks, vineyard sessions, golf — have an indoor backup that does not feel like a fallback. The best retreat programmes are designed to work in any weather; the outdoor elements are the bonus, not the plan.</p>
        </div>
      </div>
    </div>
  </section>

  {corporateArticles.length > 0 && (
    <section class="venues">
      <div class="container">
        <div class="venues__header">
          <div>
            <p class="label label--accent">From the Journal</p>
            <h2 class="venues__title">Peninsula corporate event guides</h2>
          </div>
          <a href="/journal" class="venues__link">All journal pieces →</a>
        </div>
        <div class="venues__grid">
          {corporateArticles.slice(0, 3).map((article) => (
            <article class="venue-card">
              <div class="venue-card__top">
                <span class="venue-card__type">Corporate Events</span>
                <span class="venue-card__price">{article.data.readingTimeMinutes ? `${article.data.readingTimeMinutes} min` : ''}</span>
              </div>
              <h3 class="venue-card__name">
                <a href={`/journal/${routeSlug(article)}`}>{article.data.title}</a>
              </h3>
              <p class="venue-card__signature">{article.data.dek}</p>
              <a href={`/journal/${routeSlug(article)}`} class="venue-card__cta">Read the piece →</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="venues venues--plain" id="faq">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Common questions</p>
          <h2 class="venues__title">What planners actually ask</h2>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <h3 class="venue-card__name">Is Red Hill or Sorrento better for a team offsite?</h3>
          <p class="venue-card__signature">Depends on the format. Red Hill is better if the dining programme is central — vineyard lunches and private dinners at serious restaurants. Sorrento is better if delegate walkability and a coastal town feel matter — everything is within walking distance, and The Continental handles conference-scale groups under one roof. For a small executive retreat, Red Hill is usually the stronger choice. For medium or large groups, Sorrento is more practical.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Which venues handle 50+ people for a Peninsula retreat?</h3>
          <p class="venue-card__signature">The Continental Sorrento (up to 200 for events), RACV Cape Schanck (the Peninsula's largest conference venue), and Montalto (up to 120) are the primary options for larger groups. Most boutique vineyard and hinterland properties max out at 30–40 for a retreat format. Be honest about group size — overfitting a small boutique property for a 60-person group undermines the retreat character the venue was chosen for.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">What team-building activities are worth doing on the Peninsula?</h3>
          <p class="venue-card__significance">The best Peninsula activities are the ones that do not feel like team-building: a coastal walk, a guided cellar door circuit, a cooking class, a golf morning. Avoid anything that requires "facilitation" to justify its existence — Peninsula hospitality creates connection conditions better than most structured activities. The dinner table at a good restaurant does more work than an afternoon activity that nobody chose freely.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Can we do a Peninsula retreat as a daytrip?</h3>
          <p class="venue-card__significance">Yes, but it compresses the value. A daytrip to Red Hill or Cape Schanck works for a focused strategy session with a vineyard lunch — leave Melbourne by 9am, arrive for a 10am session, lunch at noon, afternoon session, depart by 4pm. It does not capture the overnight reset dimension that makes Peninsula retreats genuinely useful. One night makes a large difference. If you can swing it, stay.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="venues venues--plain">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Go deeper</p>
          <h2 class="venues__title">Build the retreat around the Peninsula</h2>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/stay/best-accommodation">Where Teams Stay</a></h3>
          <p class="venue-card__signature">The Peninsula accommodation options that work for retreat groups — hotels, villas, and holiday houses that sleep 8–20 without sacrificing location.</p>
          <a href="/stay/best-accommodation" class="venue-card__cta">Accommodation guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/eat/best-restaurants">Team Dinner Venues</a></h3>
          <p class="venue-card__signature">The Peninsula's best restaurants for private group dinners — places that can seat 10–40 and deliver a meal that justifies the drive from Melbourne.</p>
          <a href="/eat/best-restaurants" class="venue-card__cta">Restaurant guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/wine/best-cellar-doors">Cellar Door Sessions</a></h3>
          <p class="venue-card__signature">The best cellar doors for a structured group tasting — producers with private tasting rooms and the ability to host 10–30 people properly.</p>
          <a href="/wine/best-cellar-doors" class="venue-card__cta">Wine guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/spa">Spa &amp; Recovery</a></h3>
          <p class="venue-card__signature">Peninsula Hot Springs and Alba Thermal Springs for the retreat recovery session — bookable as a group and genuinely more useful than most structured evening programmes.</p>
