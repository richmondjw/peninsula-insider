---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import VenueCard from '../../components/VenueCard.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { routeSlug } from '../../lib/editorial';

const allVenues = await getCollection('venues');
const slugs = ['hillview-cottages'];
const venues = slugs.map((slug) => allVenues.find((venue) => routeSlug(venue) === slug)).filter((venue): venue is NonNullable<typeof venue> => Boolean(venue));
const breadcrumbItems = [{ label: 'Home', href: '/' }, { label: 'Stay', href: '/stay/' }, { label: 'Cottages' }];
---
<BaseLayout title="Cottages Mornington Peninsula · Peninsula Insider" description="The cottage stays on the Mornington Peninsula that work best for slow hinterland weekends, fireplaces, gardens, and self-contained ease." section="stay" canonical="https://peninsulainsider.com.au/stay/cottages/" modifiedTime="2026-04-24">
  <Breadcrumbs items={breadcrumbItems} />
  <article class="article"><div class="container"><h1 class="article__title">Cottage Stays on the Mornington Peninsula</h1><div class="prose"><p>Cottage stays are a narrower Peninsula category, but the appeal is clear: fireplaces, gardens, quiet mornings, and enough privacy to let the weekend stretch out properly. This is the format for readers who want the trip to feel rural, self-contained, and lightly removed from hotel logic.</p><p style="font-size:0.8rem;color:var(--soft)">Last fact-verified: 24 April 2026</p></div></div></article><section class="venues"><div class="container"><div class="venues__header"><div><p class="label label--accent">Cottages</p><h2 class="venues__title">Cottage-style Peninsula stay</h2><p class="venues__sub">Small category, strong use case: slower couples or dog-friendly rural weekends.</p></div></div><div class="venues__grid">{venues.map((venue) => <VenueCard venue={venue} hrefPrefix="/stay" />)}</div></div></section><NewsletterBlock /></BaseLayout>
