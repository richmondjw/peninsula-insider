---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import VenueDetailTemplate from '../../components/VenueDetailTemplate.astro';
import { routeSlug } from '../../lib/editorial';

export async function getStaticPaths() {
  const stayTypes = ['hotel', 'villa', 'cottage', 'glamping', 'farm-stay', 'spa'];
  const venues = await getCollection('venues');
  return venues
    .filter((venue) => stayTypes.includes(venue.data.type))
    .map((venue) => ({
      params: { slug: routeSlug(venue) },
      props: { venue },
    }));
}

const stayTypes = ['hotel', 'villa', 'cottage', 'glamping', 'farm-stay', 'spa'];
const { venue } = Astro.props;
const slug = routeSlug(venue);

const allVenues = await getCollection('venues');
const related = allVenues
  .filter((entry) => routeSlug(entry) !== slug)
  .filter((entry) => stayTypes.includes(entry.data.type))
  .slice(0, 3);

// Cross-link articles that reference this venue
const articles = (await getCollection('articles', ({ data }) => data.status === 'published'))
  .filter((article) =>
    article.data.relatedVenues.some((entry) => String(entry.id ?? entry) === slug)
  )
  .slice(0, 3);

// Cross-link itineraries that include this venue as a stop
const itineraries = (await getCollection('itineraries'))
  .filter((itinerary) =>
    itinerary.data.stops.some((stop) => String(stop.venue?.id ?? stop.venue ?? '') === slug)
  )
  .slice(0, 2);
---

<BaseLayout
  title={`${venue.data.name} — Stay — Peninsula Insider`}
  description={venue.data.signature}
  section="stay"
>
  <VenueDetailTemplate venue={venue} section="stay" related={related} articles={articles} itineraries={itineraries} />
</BaseLayout>
