---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import VenueCard from '../../components/VenueCard.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { routeSlug } from '../../lib/editorial';

const allVenues = await getCollection('venues');
const stayTypes = ['hotel', 'villa', 'cottage', 'glamping', 'farm-stay', 'spa'];

// Coastal stays: tip, ocean-coast, back-beaches zones
const coastalZones = ['tip', 'ocean-coast', 'back-beaches'];
const coastalStays = allVenues.filter((v) =>
  stayTypes.includes(v.data.type) &&
  coastalZones.includes(v.data.zone)
);

// Preferred order: tip/Sorrento properties first
const preferredOrder = [
  'the-continental-sorrento',
  'hotel-sorrento',
  'sorrento-coastal-retreat',
  'flinders-hotel',
  'peninsula-hot-springs-glamping',
  'peninsula-hot-springs',
  'one-spa-racv-cape-schanck',
];

const sortedCoastalStays = [
  ...preferredOrder.map((s) => coastalStays.find((v) => routeSlug(v) === s)).filter((v): v is NonNullable<typeof v> => Boolean(v)),
  ...coastalStays.filter((v) => !preferredOrder.includes(routeSlug(v))),
];

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Stay', href: '/stay/' },
  { label: 'Coastal Stays' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Coastal Stays Mornington Peninsula',
  description: 'Coastal accommodation on the Mornington Peninsula — ocean-side hotels, boutique village stays, and back-beach properties in Sorrento, Flinders, and Cape Schanck.',
  url: 'https://peninsulainsider.com.au/stay/coastal-stays/',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://peninsulainsider.com.au/' },
      { '@type': 'ListItem', position: 2, name: 'Stay', item: 'https://peninsulainsider.com.au/stay/' },
      { '@type': 'ListItem', position: 3, name: 'Coastal Stays', item: 'https://peninsulainsider.com.au/stay/coastal-stays/' },
    ],
  },
  mainEntity: {
    '@type': 'ItemList',
    itemListOrder: 'https://schema.org/ItemListOrderDescending',
    numberOfItems: sortedCoastalStays.length,
    itemListElement: sortedCoastalStays.map((v, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: v.data.name,
      url: `https://peninsulainsider.com.au/stay/${routeSlug(v)}/`,
    })),
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Where is the best place to stay near the ocean on the Mornington Peninsula?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sorrento is the strongest base for a coastal stay — The Continental Sorrento and Hotel Sorrento both sit on the main street with the ocean baths a short walk away. The back beach (ocean surf beach) is 10 minutes by car. Sorrento Coastal Retreat adds a more private option close to the bay. Flinders Hotel is the south coast alternative — quieter, less tourist infrastructure, directly above the Flinders pier and fishing boats.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can you walk to the beach from the Peninsula hotels?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Hotel Sorrento and The Continental Sorrento are both within easy walking distance of the Sorrento ocean baths (bay beach). The back ocean beach is a short drive. Flinders Hotel is directly opposite the Flinders pier and a short walk to the back beach at Flinders Point. Peninsula Hot Springs Glamping is not walking distance to the beach — it is an inland thermal springs experience.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is Sorrento or Portsea better for a coastal stay?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sorrento has more dining options, accommodation variety, and village infrastructure — better for a first visit or when you want dinner options without driving. Portsea is quieter and more private — the Portsea Hotel overlooks the bay, and the area suits those who want less activity and more seclusion. The two are 8 minutes apart and you can easily use both on the same trip.',
      },
    },
  ],
};
---

<BaseLayout
  title="Coastal Stays Mornington Peninsula · Peninsula Insider"
  description="Coastal accommodation on the Mornington Peninsula — hotel stays in Sorrento, south coast options at Flinders and Cape Schanck, and back-beach properties for ocean weekends."
  section="stay"
  canonical="https://peninsulainsider.com.au/stay/coastal-stays/"
  modifiedTime="2026-04-24"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Breadcrumbs items={breadcrumbItems} />

  <article class="article">
    <div class="container">
      <h1 class="article__title">Coastal Stays on the Mornington Peninsula</h1>
      <div class="prose">
        <p>The Peninsula has two distinct coasts, and they produce quite different trips. The bay coast (Port Phillip side) is calm water, limestone cliffs, and village dining — Sorrento is the centre of this version. The ocean coast (Bass Strait side) is surf beaches, strong prevailing winds, and working fishing villages — Flinders is the centre here, Cape Schanck at the southern tip is the most dramatic.</p>
        <p>The Continental Sorrento and Hotel Sorrento sit at the village end of Sorrento's main street, with the ocean baths a short walk away. Both suit couples who want a proper hotel stay with easy restaurant access. For a quieter coastal experience, the Sorrento Coastal Retreat gives bay views without the main-street activity.</p>
        <p>Flinders Hotel is the south coast benchmark: a proper country pub with good rooms, directly opposite the pier, in a village that has resisted the temptation to become a weekend destination. That resistance is the point.</p>
        <p class="venues__sub" style="font-size:0.8rem;color:var(--soft)">Last fact-verified: 24 April 2026</p>
      </div>
    </div>
  </article>

  <section class="venues" id="sorrento-tip">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Sorrento · tip · bay coast</p>
          <h2 class="venues__title">{sortedCoastalStays.length} coastal stays across the Peninsula</h2>
          <p class="venues__sub">Village hotels, coastal retreats, and south-coast properties — Sorrento-tip properties first, then the south coast at Flinders and Cape Schanck.</p>
        </div>
        <a href="/places/sorrento/" class="venues__link">Sorrento guide →</a>
      </div>
      <div class="venues__grid">
        {sortedCoastalStays.map((venue) => <VenueCard venue={venue} hrefPrefix="/stay" />)}
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <div class="prose">
        <h2>Frequently asked questions</h2>
        <h3>Best coastal stay near the ocean?</h3>
        <p>Sorrento for dining, village atmosphere, and easy beach access — The Continental and Hotel Sorrento both work well. Flinders Hotel for the south coast version: quieter, directly above the pier, working fishing village that hasn't been completely polished for tourism.</p>
        <h3>Can you walk to the beach from the hotels?</h3>
        <p>Hotel Sorrento and The Continental are walking distance to the Sorrento ocean baths (bay side). The back ocean beach is a 10-minute drive. Flinders Hotel is a short walk to the Flinders pier and back beach at Flinders Point.</p>
        <h3>Sorrento or Portsea?</h3>
        <p>Sorrento for more dining options and village infrastructure — better for a first visit. Portsea for quieter and more private. The two are 8 minutes apart; use Sorrento as a base and Portsea as an excursion.</p>
      </div>
    </div>
  </section>

  <section class="venues venues--plain">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Related guides</p>
          <h2 class="venues__title">More for the coastal weekend</h2>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card"><h3 class="venue-card__name"><a href="/places/sorrento/">Sorrento Guide</a></h3><p class="venue-card__signature">The complete Sorrento hub — beaches, restaurants, walks, and where to stay.</p><a href="/places/sorrento/" class="venue-card__cta">Read the guide →</a></div>
        <div class="venue-card"><h3 class="venue-card__name"><a href="/explore/">Walks & Exploration</a></h3><p class="venue-card__signature">The best walking tracks, coastal paths, and lookouts across the Peninsula.</p><a href="/explore/" class="venue-card__cta">Explore →</a></div>
        <div class="venue-card"><h3 class="venue-card__name"><a href="/stay/best-accommodation/">Best Accommodation</a></h3><p class="venue-card__signature">All Peninsula stays ranked across price bands and weekend types.</p><a href="/stay/best-accommodation/" class="venue-card__cta">See the list →</a></div>
      </div>
    </div>
  </section>

  <NewsletterBlock />
</BaseLayout>
