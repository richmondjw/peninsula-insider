---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHero from '../components/SectionHero.astro';
import NewsletterBlock from '../components/NewsletterBlock.astro';
---

<BaseLayout title="Escape — Peninsula Insider" description="Itineraries and slow-travel packages are queued for the next conversion pass." section="escape">
  <SectionHero
    eyebrow="Escape"
    subEyebrow="Itineraries · slow travel · weekends"
    title="The weekend plans we want to <em>build</em> next."
    dek="The rebuild now has the routing and design system to support itineraries and escape guides. This page stays intentionally simple tonight while the core magazine surfaces come online first."
    gradient="sand"
    visualLabel="Next conversion pass · itineraries and weekend guides"
  />
  <section class="places">
    <div class="container">
      <div class="prose" style="margin: 0; max-width: 760px;">
        <p>The content schema already includes itineraries. The next pass should wire that collection into this section, with one-night and two-night escape templates linked from Stay, Wine, and Place hubs.</p>
      </div>
    </div>
  </section>
  <NewsletterBlock />
</BaseLayout>
