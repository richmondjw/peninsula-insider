---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { routeSlug } from '../../lib/editorial';

const allArticles = await getCollection('articles', ({ data }) => data.status === 'published');
const weddingArticles = allArticles
  .filter((a) => a.data.tags?.some((t) => ['weddings', 'wedding', 'wedding-venues'].includes(t)))
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Weddings' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What are the best wedding venues on the Mornington Peninsula?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The best venue depends on the wedding format. Montalto (Red Hill South) for food-led vineyard weddings up to 120 guests. Pt. Leo Estate for coastal architecture and dramatic photography up to 200 guests. The Continental Sorrento for a coastal hotel with town-centre convenience and full-service capacity. Polperro (Main Ridge) for intimate vineyard weddings under 80 guests. Jackalope (Merricks North) for a contemporary design statement. Each property serves a different style — there is no single best, only the right fit for the couple.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the best part of the Mornington Peninsula for a wedding?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Red Hill and Main Ridge for a food-and-wine-led wedding with vineyard settings. Sorrento and Portsea for coastal prestige and town-based guest convenience. Merricks and Balnarring for boutique estate properties. The right location depends on the style of wedding, guest transport logistics, and whether you need accommodation clustered nearby. Red Hill is strongest for vineyard weddings; Sorrento for a coastal weekend.',
      },
    },
    {
      '@type': 'Question',
      name: 'How far in advance do you need to book a Mornington Peninsula wedding venue?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'For peak season (October to April), book 14 to 18 months ahead. The most in-demand venues on popular Saturday dates can fill two years out. Winter weddings (May to August) are easier to secure at 6 to 12 months and come at reduced rates. Friday and Sunday weddings at any time of year are easier to book and often less expensive.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does a Mornington Peninsula wedding cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Venue hire plus catering typically runs from $15,000 to $50,000 or more depending on venue, guest count, and menu. Transport is the cost couples most often underestimate — a return coach from Melbourne for 80 guests costs $1,500 to $3,000. A Peninsula wedding typically runs 10–20% above an equivalent Melbourne venue once transport and guest accommodation are factored in.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which Mornington Peninsula wedding venues have onsite accommodation?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Jackalope (Merricks North) has onsite designer rooms. The Continental Sorrento is a full hotel. Lindenderry at Red Hill has rooms and suites on the property. RACV Cape Schanck Resort has accommodation and can manage large groups onsite. Many other venues are within 15 minutes of holiday rental houses that sleep 8–12 guests and work well for bridal parties.',
      },
    },
  ],
};

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Mornington Peninsula Weddings Guide',
  description: 'A selective guide to weddings on the Mornington Peninsula — venues, towns, planning, and wedding-weekend intelligence for couples who want to understand the Peninsula before they choose it.',
  url: 'https://peninsulainsider.com.au/weddings',
  about: {
    '@type': 'Thing',
    name: 'Mornington Peninsula wedding venues and planning',
  },
};
---

<BaseLayout
  title="Mornington Peninsula Weddings: The Insider Guide · Peninsula Insider"
  description="A selective guide to getting married on the Mornington Peninsula — vineyard estates, coastal venues, boutique hotels, and the wedding-weekend planning intelligence that most guides skip."
  section="explore"
  canonical="https://peninsulainsider.com.au/weddings"
  modifiedTime="2026-04-19"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />

  <Breadcrumbs items={breadcrumbItems} />

  <section class="section-hero">
    <div class="container">
      <div class="section-hero__inner">
        <div class="section-hero__content">
          <p class="label label--accent">Weddings</p>
          <h1 class="section-hero__title">Mornington Peninsula Weddings</h1>
          <p class="section-hero__dek">Couples are not only choosing a venue. They are choosing the kind of Peninsula wedding that fits them — vineyard, coastal, estate, intimate, or destination weekend. This section helps you make that decision properly.</p>
        </div>
        <div class="section-hero__visual" aria-hidden="true" style="background-image: url(/images/sourced/article-vineyard-villa-01.webp); background-size: cover; background-position: center;">
          <div class="section-hero__visual-fog"></div>
          <span class="section-hero__visual-label">Weddings · Vineyard Estates · Coastal Venues</span>
        </div>
      </div>
    </div>
  </section>

  <section class="format-nav">
    <div class="container">
      <p class="label label--accent format-nav__label">Find your fit</p>
      <div class="format-nav__chips">
        <a href="#venue-types" class="format-chip"><span class="format-chip__name">Venue types</span></a>
        <a href="#by-town" class="format-chip"><span class="format-chip__name">By town</span></a>
        <a href="#planning" class="format-chip"><span class="format-chip__name">Planning</span></a>
        <a href="#guest-weekend" class="format-chip"><span class="format-chip__name">Guest weekend</span></a>
        <a href="#faq" class="format-chip"><span class="format-chip__name">Common questions</span></a>
      </div>
    </div>
  </section>

  <section class="editorial-promise">
    <div class="container">
      <div class="editorial-promise__inner">
        <div>
          <p class="label label--accent">The Peninsula Insider approach</p>
          <h2 class="editorial-promise__title">Curation over volume. Decision support over directories.</h2>
        </div>
        <div>
          <p>Most wedding content shows you where you can get married. We help you understand which Peninsula wedding actually fits the couple you are. That means honest tradeoffs, specific place intelligence, and practical guidance on what the surrounding weekend looks like — not a scrollable list of venues with star ratings and enquiry buttons.</p>
          <p>The Peninsula has the raw ingredients: vineyards, boutique hotels, coastline, world-class food, destination-weekend appeal. What it needs is good guidance. That is what this vertical is for.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="venues" id="venue-types">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Venue types</p>
          <h2 class="venues__title">Choose by setting, not by search rank</h2>
          <p class="venues__sub">The Peninsula has five distinct wedding formats. Each suits a different style, scale, and guest experience. Start here.</p>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Vineyard</span>
          </div>
          <h3 class="venue-card__name">Winery Wedding Venues</h3>
          <p class="venue-card__signature">Estate grounds, long-table lunches, and cellar-door receptions. The Peninsula's strongest point of difference — wineries where the food is as serious as the setting. Best for couples where dining and wine are central, not just backdrop.</p>
          <p class="venue-card__signature"><strong>Best picks:</strong> Montalto, Polperro, Ten Minutes by Tractor, Pt. Leo Estate</p>
          <a href="/journal/mornington-peninsula-wedding-venues" class="venue-card__cta">Read the venue guide →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Coastal</span>
          </div>
          <h3 class="venue-card__name">Coastal &amp; Hotel Wedding Venues</h3>
          <p class="venue-card__signature">Bay views, clifftop terraces, and hotel precincts where guests can stay, walk to breakfast, and not think about transport. The right format when convenience and atmosphere need to share equal billing.</p>
          <p class="venue-card__signature"><strong>Best picks:</strong> The Continental Sorrento, The Portsea Hotel, RACV Cape Schanck Resort</p>
          <a href="/journal/mornington-peninsula-wedding-venues" class="venue-card__cta">Read the venue guide →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Estate</span>
          </div>
          <h3 class="venue-card__name">Boutique Estate &amp; Design Hotel Weddings</h3>
          <p class="venue-card__signature">For couples who want a Peninsula wedding that looks like nothing else. Design-led properties where the architecture is part of the brief, not just the backdrop.</p>
          <p class="venue-card__signature"><strong>Best picks:</strong> Jackalope (Merricks North), Lindenderry at Red Hill</p>
          <a href="/journal/mornington-peninsula-wedding-venues" class="venue-card__cta">Read the venue guide →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Intimate</span>
          </div>
          <h3 class="venue-card__name">Small &amp; Intimate Weddings</h3>
          <p class="venue-card__signature">Under 60 guests. The Peninsula has a handful of properties that work best at this scale — where the wedding feels like a dinner party that happens to be a wedding, not a function room filling slowly.</p>
          <p class="venue-card__signature"><strong>Best picks:</strong> Polperro, Ten Minutes by Tractor, private property buyouts</p>
          <a href="/journal/mornington-peninsula-wedding-venues" class="venue-card__cta">Read the venue guide →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">Large</span>
          </div>
          <h3 class="venue-card__name">Weddings for 120+ Guests</h3>
          <p class="venue-card__signature">Not every Peninsula property scales gracefully. These are the venues where guest flow, bathroom logistics, and reception room size were actually designed for large events.</p>
          <p class="venue-card__signature"><strong>Best picks:</strong> The Continental Sorrento, RACV Cape Schanck, Pt. Leo Estate, Montalto</p>
          <a href="/journal/mornington-peninsula-wedding-venues" class="venue-card__cta">Read the venue guide →</a>
        </div>
        <div class="venue-card">
          <div class="venue-card__top">
            <span class="venue-card__type">All-in-one</span>
          </div>
          <h3 class="venue-card__name">Ceremony &amp; Reception at One Property</h3>
          <p class="venue-card__signature">For couples who want guests to arrive once and stay for everything — ceremony, reception, and often accommodation — without moving between sites.</p>
          <p class="venue-card__signature"><strong>Best picks:</strong> Jackalope, Lindenderry, RACV Cape Schanck, The Continental Sorrento</p>
          <a href="/journal/mornington-peninsula-wedding-venues" class="venue-card__cta">Read the venue guide →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="venues venues--plain" id="by-town">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">By location</p>
          <h2 class="venues__title">Choose by place, not just venue</h2>
          <p class="venues__sub">The town shapes the guest experience as much as the venue does. Where you get married on the Peninsula determines where guests stay, how they travel, and what the day and weekend feel like.</p>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/places/red-hill">Red Hill &amp; Main Ridge</a></h3>
          <p class="venue-card__signature">The food-and-wine heartland. Best for couples who want a vineyard wedding with serious dining credentials. Guest accommodation is scattered across the plateau in cottages and villas — holiday houses sleep 8–12 and work well for bridal parties. The trade-off is that nothing is walkable; a coach is not optional, it is essential.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/places/sorrento">Sorrento &amp; Portsea</a></h3>
          <p class="venue-card__signature">Coastal village feel with enough hotel and holiday rental stock to accommodate a large wedding party within walking distance of the venues. The Continental Sorrento and Portsea Hotel are the anchors. Best for couples who want a wedding weekend where guests can arrive, walk everywhere, and not need to think about driving.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Merricks &amp; Balnarring</h3>
          <p class="venue-card__signature">Estate country. Properties here — including Jackalope — sit between the vineyard plateau and the coast, with a mix of privacy and access. Less concentrated in terms of guest accommodation than Sorrento, but the venue quality at the top end is exceptional. Works best when guests stay onsite or at a nearby property.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Cape Schanck &amp; Fingal</h3>
          <p class="venue-card__signature">Resort territory. RACV Cape Schanck handles large groups with accommodation, golf, spa, and full conference infrastructure. Best for weddings where logistics simplicity and group size matter more than boutique character.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/places/flinders">Flinders &amp; Shoreham</a></h3>
          <p class="venue-card__signature">Privacy and distance. Flinders attracts couples who want to be away from the busier Peninsula corridors. Guest accommodation is limited compared to Sorrento, which means this works best for smaller weddings with a committed guest list happy to travel and stay locally.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Mornington &amp; Dromana</h3>
          <p class="venue-card__signature">Easiest access from Melbourne. Less premium than the hinterland or the tip of the Peninsula, but logistically simpler and more affordable. Works well for larger guest lists where distance from Melbourne is a real concern.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="venues" id="planning">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Planning</p>
          <h2 class="venues__title">The questions that shape the decision</h2>
          <p class="venues__sub">Before the venue shortlist, these are the structural decisions that determine what kind of Peninsula wedding actually works for you.</p>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <h3 class="venue-card__name">Guest Count</h3>
          <p class="venue-card__signature">Under 80 guests opens up the intimate vineyard properties that don't work at larger scale. Over 120 guests narrows you to venues with genuine event infrastructure. The number is the first filter — not the aesthetic.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Transport Logic</h3>
          <p class="venue-card__signature">Melbourne to Main Ridge is 90 minutes in Saturday traffic. A coach for guests is $1,500 to $3,000 return and worth every dollar — it removes the drink-driving question and puts the timing in your hands, not your guests'. Build the transport cost into the budget before you shortlist venues.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Guest Accommodation</h3>
          <p class="venue-card__signature">The Peninsula does not have dense hotel stock in any single town. The most practical model is a mix of: onsite rooms (if the venue has them), nearby holiday houses sleeping 8–12, and Sorrento's hotel cluster for the larger coastal weddings. Work this out before you commit to a venue location.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Season</h3>
          <p class="venue-card__signature">October to April is peak season. The weather is warmest, competition for venues is highest, and prices reflect it. Winter weddings — May to July — are genuinely compelling on the Peninsula: fires lit at the cellar doors, golden low light, no crowd pressure, and rates that reflect the quieter season. A winter Saturday at Polperro is not a compromise. It is a different and better wedding.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Ceremony Location</h3>
          <p class="venue-card__signature">Most Peninsula venues handle ceremony onsite, which avoids the church-to-reception problem. The exception is couples who want a Sorrento or Portsea foreshore ceremony — beautiful, but adds a guest movement that needs coordinating. Have a weather backup for any outdoor ceremony on the Peninsula; Bass Strait weather is real.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Booking Lead Time</h3>
          <p class="venue-card__signature">For peak season Saturday dates, 14 to 18 months is standard. The most sought-after properties fill earlier. Winter and non-Saturday dates are easier across the board. If you have a fixed date in mind before a venue, check date availability before you fall in love with the property.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="venues venues--plain" id="guest-weekend">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">The guest weekend</p>
          <h2 class="venues__title">Build the weekend around the wedding, not just the day</h2>
          <p class="venues__sub">The strongest Peninsula weddings are the ones where guests want to stay Friday to Sunday — because the Peninsula gives them a real reason to. These are the links that make the surrounding weekend work.</p>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/stay/best-accommodation">Where Guests Should Stay</a></h3>
          <p class="venue-card__signature">The best Peninsula accommodation for wedding guests — by location, group size, and how close they need to be to the venue. Hotels, villas, and holiday houses with the right logistics.</p>
          <a href="/stay/best-accommodation" class="venue-card__cta">Accommodation guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/eat/best-restaurants">Rehearsal Dinner Venues</a></h3>
          <p class="venue-card__signature">Friday night before the wedding. The best Peninsula restaurants for a private room, a long table, or a buyout that sets the right tone without outshining the day itself.</p>
          <a href="/eat/best-restaurants" class="venue-card__cta">Restaurant guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/eat/best-restaurants">Recovery Brunch</a></h3>
          <p class="venue-card__signature">Sunday morning after. The best spots for a low-key recovery brunch — the format that makes guests glad they stayed the night. Sorrento and Red Hill have the best options.</p>
          <a href="/eat/best-restaurants" class="venue-card__cta">Brunch guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/wine/best-cellar-doors">Cellar Door Saturday Afternoon</a></h3>
          <p class="venue-card__signature">For guests arriving Friday and filling Saturday before the ceremony. The Red Hill and Main Ridge cellar door circuit is one of the Peninsula's best half-days.</p>
          <a href="/wine/best-cellar-doors" class="venue-card__cta">Cellar door guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/explore/best-walks">Morning-of Walks</a></h3>
          <p class="venue-card__signature">A coastal walk on the morning of the wedding day — for the bridal party or the guests clearing their heads. Cape Schanck and Sorrento both have walks within 20 minutes of most wedding venues.</p>
          <a href="/explore/best-walks" class="venue-card__cta">Walks guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/spa/index">Spa &amp; Recovery</a></h3>
          <p class="venue-card__signature">Peninsula Hot Springs and Alba Thermal Springs are both within 20 minutes of the Fingal corridor. A Sunday session for the bridal party the morning after is the recovery move most couples don't think of until someone else suggests it.</p>
          <a href="/spa" class="venue-card__cta">Spa guide →</a>
        </div>
      </div>
    </div>
  </section>

  {weddingArticles.length > 0 && (
    <section class="venues">
      <div class="container">
        <div class="venues__header">
          <div>
            <p class="label label--accent">From the Journal</p>
            <h2 class="venues__title">Peninsula wedding guides</h2>
          </div>
          <a href="/journal" class="venues__link">All journal pieces →</a>
        </div>
        <div class="venues__grid">
          {weddingArticles.slice(0, 3).map((article) => (
            <article class="venue-card">
              <div class="venue-card__top">
                <span class="venue-card__type">Weddings</span>
                <span class="venue-card__price">{article.data.readingTimeMinutes ? `${article.data.readingTimeMinutes} min` : ''}</span>
              </div>
              <h3 class="venue-card__name">
                <a href={`/journal/${routeSlug(article)}`}>{article.data.title}</a>
              </h3>
              <p class="venue-card__signature">{article.data.dek}</p>
              <a href={`/journal/${routeSlug(article)}`} class="venue-card__cta">Read the piece →</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="venues venues--plain" id="faq">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Common questions</p>
          <h2 class="venues__title">What couples actually want to know</h2>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <h3 class="venue-card__name">Are winery weddings the best fit for most couples?</h3>
          <p class="venue-card__signature">For couples where food and wine are central to the event, yes. For couples who want a hotel weekend with dancing and a large guest list, a coastal venue will work better. The vineyard format is not automatically the superior one — it is the most photographed one. Those are different things.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Which venues have the best onsite accommodation?</h3>
          <p class="venue-card__signature">Jackalope has onsite designer rooms that sleep the wedding party comfortably. The Continental Sorrento is a full-service hotel with guest rooms. Lindenderry at Red Hill has onsite rooms. RACV Cape Schanck has large accommodation capacity for groups. For most vineyard venues, the bridal party stays in nearby holiday houses — which works well if booked well in advance.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Is a winter Peninsula wedding a real option?</h3>
          <p class="venue-card__signature">Yes, and it is underrated. Cellar doors have open fires. The light in May and June is exceptional for photography. Competition for venues is lower. Rates are lower. A winter Saturday at a warm, firelit vineyard with a guest list of 60–80 people who actually wanted to be there is a better event than a crowded summer Saturday at the same property under stress. Consider it seriously.</p>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name">Do I need a wedding planner for a Peninsula wedding?</h3>
          <p class="venue-card__signature">Not necessarily, but the logistics are more complex than a Melbourne venue. Transport coordination, accommodation spread, and supplier access across the Peninsula all require more planning than in-city events. A local coordinator who knows the Peninsula's suppliers and venues is worth the cost if you are doing this without an events background.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="venues venues--plain">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Go deeper</p>
          <h2 class="venues__title">More Peninsula wedding reading</h2>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/journal/mornington-peninsula-wedding-venues">The Venue Guide</a></h3>
          <p class="venue-card__signature">Honest, venue-by-venue coverage of the Peninsula's main wedding properties — what they are actually like, not what the marketing suggests.</p>
          <a href="/journal/mornington-peninsula-wedding-venues" class="venue-card__cta">Read the guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/stay/best-accommodation">Where to Stay</a></h3>
          <p class="venue-card__signature">The best Peninsula accommodation for wedding guests and bridal parties — hotels, villas, and the holiday houses that work for groups.</p>
          <a href="/stay/best-accommodation" class="venue-card__cta">Accommodation guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/wine/best-cellar-doors">Cellar Doors for the Weekend</a></h3>
          <p class="venue-card__signature">The winery circuit for guests who arrive early and need a way to spend the Friday afternoon or Saturday before the wedding.</p>
          <a href="/wine/best-cellar-doors" class="venue-card__cta">Wine guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/eat/best-restaurants">Best Restaurants</a></h3>
          <p class="venue-card__signature">For rehearsal dinners, recovery brunches, and Saturday lunch for guests who arrive early. The Peninsula's strongest dining options.</p>
          <a href="/eat/best-restaurants" class="venue-card__cta">Eat guide →</a>
        </div>
        <div class="venue-card">
          <h3 class="venue-card__name"><a href="/journal/mornington-peninsula-in-winter">Peninsula in Winter</a></h3>
          <p class="venue-card__signature">Why winter is underrated for a Peninsula wedding — the case for fires, low light, and a guest list that stays for the weekend.</p>
