---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import VenueCard from '../../components/VenueCard.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { routeSlug } from '../../lib/editorial';

const allVenues = await getCollection('venues');
const venues = (await getCollection('venues')).filter(v=>v.data.type==='pub').sort((a,b)=>(a.data.name??'').localeCompare(b.data.name??''));

const breadcrumbItems=[{label:'Home',href:'/'},{label:'Eat & Drink',href:'/eat/'},{label:'Best Pubs'}];
const schema={'@context':'https://schema.org','@type':'CollectionPage',name:'Best Pubs Mornington Peninsula',description:'The best pubs on the Mornington Peninsula — bay-view beer gardens, village locals, and the pub bistros that do an honest meal.',url:'https://peninsulainsider.com.au/eat/pubs/',breadcrumb:{'@type':'BreadcrumbList',itemListElement:[{position:1,name:'Home',item:'https://peninsulainsider.com.au/'},{position:2,name:'Eat & Drink',item:'https://peninsulainsider.com.au/eat/'},{position:3,name:'Best Pubs',item:'https://peninsulainsider.com.au/eat/pubs/'}].map(e=>({'@type':'ListItem',...e}))},mainEntity:{'@type':'ItemList',itemListOrder:'https://schema.org/ItemListOrderDescending',numberOfItems:venues.length,itemListElement:venues.map((v,i)=>({'@type':'ListItem',position:i+1,name:v.data.name,url:`https://peninsulainsider.com.au/eat/${routeSlug(v)}/`}))}};
const faqSchema={'@context':'https://schema.org','@type':'FAQPage',mainEntity:[{'@type':'Question',name:'What is the best pub on the Mornington Peninsula?',acceptedAnswer:{'@type':'Answer',text:'Portsea Hotel has the most dramatic setting — sweeping Port Phillip Bay views from a clifftop position above Portsea beach, dog-friendly beer garden, and a pub bistro better than the building suggests. Balnarring Pub is the most genuinely local and relaxed village pub on the Peninsula. Merricks Hotel is a historic roadhouse pub that still does its job well.'}},{'@type':'Question',name:'Which pubs on the Mornington Peninsula are dog-friendly?',acceptedAnswer:{'@type':'Answer',text:'Portsea Hotel (beer garden), Balnarring Pub (beer garden), and Rye Hotel (outdoor area) are confirmed dog-friendly. Check directly with venues before visiting as policies can change.'}},{'@type':'Question',name:'Where should I go for a pub meal on the Mornington Peninsula?',acceptedAnswer:{'@type':'Answer',text:'Portsea Hotel (bay views, Ishka Restaurant for more formal dining, pub format). Balnarring Pub (local favourite, village setting). The Bay Hotel Mornington (waterfront adjacent, Mornington town). Check current kitchen hours before visiting — pub kitchens on the Peninsula can have limited midweek service.'}}]};
---
<BaseLayout title="Best Pubs Mornington Peninsula · Peninsula Insider" description="The best pubs on the Mornington Peninsula — Portsea Hotel's bay views, Balnarring Pub's village setting, and the honest pub bistros worth stopping at." section="eat" canonical="https://peninsulainsider.com.au/eat/pubs/" modifiedTime="2026-04-24">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Breadcrumbs items={breadcrumbItems} />
  <article class="article"><div class="container"><h1 class="article__title">Best Pubs on the Mornington Peninsula</h1><div class="prose"><p>The Peninsula's pub scene is spread across its towns and coastal villages rather than concentrated in one area. Portsea Hotel leads for setting — the clifftop position above Portsea beach, bay views, and a dog-friendly beer garden make it the strongest pub experience on the Peninsula. Balnarring Pub is the most local and genuinely village-feeling. The Bay Hotel Mornington works as a practical stop for anyone based in or passing through town.</p><p>Peninsula pub kitchens range from honest bistro meals to better-than-expected seasonal menus. The general rule: pub food here is not the reason to drive; the setting is. Pair any pub stop with a coastal walk or afternoon activity nearby to get the most from it.</p><p style="font-size:0.8rem;color:var(--soft)">Last fact-verified: 23 April 2026</p></div></div></article>
  <section class="venues" id="rankings"><div class="container"><div class="venues__header"><div><p class="label label--accent">Peninsula pubs</p><h2 class="venues__title">All {venues.length} Peninsula pubs</h2><p class="venues__sub">Sorted alphabetically. Location usually determines which one you visit.</p></div><a href="/eat/" class="venues__link">All dining venues →</a></div><div class="venues__grid">{venues.map(v=><VenueCard venue={v} hrefPrefix="/eat" />)}</div></div></section>
  <section class="faq-section"><div class="container"><div class="prose"><h2>Frequently asked questions</h2><h3>Best pub on the Mornington Peninsula?</h3><p>Portsea Hotel: best setting (clifftop, bay views, dog-friendly). Balnarring Pub: most genuine village local. Merricks Hotel: historic roadhouse still doing its job.</p><h3>Which pubs are dog-friendly?</h3><p>Portsea Hotel (beer garden), Balnarring Pub (beer garden), Rye Hotel (outdoor area). Verify directly before visiting.</p><h3>Best for a pub meal?</h3><p>Portsea Hotel (bay views, pub bistro, Ishka Restaurant for more formal). Balnarring Pub (local favourite). The Bay Hotel Mornington (waterfront adjacent). Check kitchen hours before visiting — midweek service can be limited.</p></div></div></section>
  <section class="venues venues--plain"><div class="container"><div class="venues__header"><div><p class="label label--accent">Related guides</p><h2 class="venues__title">More ways to eat on the Peninsula</h2></div></div><div class="venues__grid venues__grid--links"><div class="venue-card"><h3 class="venue-card__name"><a href="/eat/dog-friendly/">Dog-Friendly Dining</a></h3><p class="venue-card__signature">Confirmed dog-friendly outdoor dining — cafes, pubs, and winery casual areas.</p><a href="/eat/dog-friendly/" class="venue-card__cta">See the list →</a></div><div class="venue-card"><h3 class="venue-card__name"><a href="/eat/waterfront/">Waterfront Dining</a></h3><p class="venue-card__signature">Bay-facing restaurants at Sorrento, Mornington, and Portsea.</p><a href="/eat/waterfront/" class="venue-card__cta">See the list →</a></div><div class="venue-card"><h3 class="venue-card__name"><a href="/eat/">All Eat & Drink</a></h3><p class="venue-card__signature">The full Peninsula dining guide — restaurants, cellar doors, cafes, bakeries, and pubs.</p><a href="/eat/" class="venue-card__cta">Explore all →</a></div></div></div></section>
  <NewsletterBlock />
</BaseLayout>
