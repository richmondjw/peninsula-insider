---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import VenueCard from '../../components/VenueCard.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { routeSlug } from '../../lib/editorial';

const allVenues = await getCollection('venues');
const venues=(await getCollection('venues')).filter(v=>v.data.type==='market').sort((a,b)=>(a.data.name??'').localeCompare(b.data.name??''));

const breadcrumbItems=[{label:'Home',href:'/'},{label:'Eat & Drink',href:'/eat/'},{label:'Markets'}];
const schema={'@context':'https://schema.org','@type':'CollectionPage',name:'Best Markets Mornington Peninsula',description:'The best food markets on the Mornington Peninsula — Red Hill Market, Mornington Farmers\' Market, and the seasonal produce markets worth planning a Saturday around.',url:'https://peninsulainsider.com.au/eat/markets/',breadcrumb:{'@type':'BreadcrumbList',itemListElement:[{position:1,name:'Home',item:'https://peninsulainsider.com.au/'},{position:2,name:'Eat & Drink',item:'https://peninsulainsider.com.au/eat/'},{position:3,name:'Markets',item:'https://peninsulainsider.com.au/eat/markets/'}].map(e=>({'@type':'ListItem',...e}))},mainEntity:{'@type':'ItemList',itemListOrder:'https://schema.org/ItemListOrderDescending',numberOfItems:venues.length,itemListElement:venues.map((v,i)=>({'@type':'ListItem',position:i+1,name:v.data.name,url:`https://peninsulainsider.com.au/eat/${routeSlug(v)}/`}))}};
const faqSchema={'@context':'https://schema.org','@type':'FAQPage',mainEntity:[{'@type':'Question',name:'What is the best market on the Mornington Peninsula?',acceptedAnswer:{'@type':'Answer',text:'Red Hill Market (Red Hill Showgrounds, first Saturday of the month) is the Peninsula\'s largest and most established market — produce, local food, artisan goods, and a good coffee scene on-site. Mornington Farmers\' Market (Craig\'s Reserve, Mornington, every Wednesday) is the best for fresh local produce — smaller, focused, and less tourist-facing.'}},{'@type':'Question',name:'When is Red Hill Market?',acceptedAnswer:{'@type':'Answer',text:'Red Hill Market runs on the first Saturday of every month at the Red Hill Showgrounds. Gates open 8am, most stalls wind down by 1pm. Arrive by 9am for the best produce selection. Dogs are welcome on leashes.'}},{'@type':'Question',name:'Are Peninsula markets dog-friendly?',acceptedAnswer:{'@type':'Answer',text:'Red Hill Market (leashed dogs welcome), Balnarring Farmers\' Market (usually dog-friendly outdoors), and Mornington Farmers\' Market (outdoor area, generally dog-friendly) are the main dog-welcoming markets. Verify current policy directly before visiting.'}}]};
---
<BaseLayout title="Best Markets Mornington Peninsula · Peninsula Insider" description="The best food markets on the Mornington Peninsula — Red Hill Market on the first Saturday, Mornington Farmers' Market every Wednesday, and seasonal produce worth the detour." section="eat" canonical="https://peninsulainsider.com.au/eat/markets/" modifiedTime="2026-04-24">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Breadcrumbs items={breadcrumbItems} />
  <article class="article"><div class="container"><h1 class="article__title">Best Markets on the Mornington Peninsula</h1><div class="prose"><p>The Peninsula has three established food markets, each with a different character. Red Hill Market is the one worth planning a morning around — a large monthly market on the first Saturday of the month at Red Hill Showgrounds, with Peninsula produce, artisan food, and a coffee and brunch scene that makes the visit feel like an event rather than a shopping errand.</p><p>Mornington Farmers' Market runs every Wednesday at Craig's Reserve and is the best option for fresh local produce during the week — smaller, more focused, and less tourist-facing than Red Hill. Balnarring Farmers' Market is the most genuinely local of the three — a village-scale market with strong produce and a relaxed pace.</p><p style="font-size:0.8rem;color:var(--soft)">Last fact-verified: 23 April 2026</p></div></div></article>
  <section class="venues" id="rankings"><div class="container"><div class="venues__header"><div><p class="label label--accent">Peninsula markets</p><h2 class="venues__title">All {venues.length} Peninsula food markets</h2><p class="venues__sub">Red Hill on the first Saturday, Mornington every Wednesday, Balnarring seasonally.</p></div><a href="/eat/" class="venues__link">All dining venues →</a></div><div class="venues__grid">{venues.map(v=><VenueCard venue={v} hrefPrefix="/eat" />)}</div></div></section>
  <section class="faq-section"><div class="container"><div class="prose"><h2>Frequently asked questions</h2><h3>Best market on the Mornington Peninsula?</h3><p>Red Hill Market (first Saturday of the month, Red Hill Showgrounds). Mornington Farmers' Market (every Wednesday, Craig's Reserve) for weekday produce. Balnarring for the most local village-scale experience.</p><h3>When is Red Hill Market?</h3><p>First Saturday of every month. Gates open 8am, most stalls wind down by 1pm. Arrive by 9am for best produce. Dogs welcome on leashes.</p><h3>Are markets dog-friendly?</h3><p>Red Hill (leashed dogs welcome) and Balnarring (outdoor, generally dog-friendly). Verify before visiting.</p></div></div></section>
  <NewsletterBlock />
</BaseLayout>
