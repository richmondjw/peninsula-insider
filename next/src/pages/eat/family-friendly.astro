---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import VenueCard from '../../components/VenueCard.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { routeSlug } from '../../lib/editorial';

const allVenues = await getCollection('venues');
const slugs = ['red-gum-bbq','merricks-general-wine-store','green-olive-red-hill','montalto','johnny-ripe','balnarring-pub','rye-hotel','sorrento-gelato','commonfolk-coffee','flinders-general-store'];
const venues = slugs.map(s=>allVenues.find(v=>routeSlug(v)===s)).filter((v):v is NonNullable<typeof v>=>Boolean(v));

const breadcrumbItems=[{label:'Home',href:'/'},{label:'Eat & Drink',href:'/eat/'},{label:'Family-Friendly'}];
const schema={'@context':'https://schema.org','@type':'CollectionPage',name:'Family-Friendly Restaurants Mornington Peninsula',description:'Family-friendly dining on the Mornington Peninsula — outdoor seating, relaxed formats, and the venues where bringing kids does not require an apology.',url:'https://peninsulainsider.com.au/eat/family-friendly/',breadcrumb:{'@type':'BreadcrumbList',itemListElement:[{position:1,name:'Home',item:'https://peninsulainsider.com.au/'},{position:2,name:'Eat & Drink',item:'https://peninsulainsider.com.au/eat/'},{position:3,name:'Family-Friendly',item:'https://peninsulainsider.com.au/eat/family-friendly/'}].map(e=>({'@type':'ListItem',...e}))},mainEntity:{'@type':'ItemList',itemListOrder:'https://schema.org/ItemListOrderDescending',numberOfItems:venues.length,itemListElement:venues.map((v,i)=>({'@type':'ListItem',position:i+1,name:v.data.name,url:`https://peninsulainsider.com.au/eat/${routeSlug(v)}/`}))}};
const faqSchema={'@context':'https://schema.org','@type':'FAQPage',mainEntity:[{'@type':'Question',name:'Where are the best family-friendly restaurants on the Mornington Peninsula?',acceptedAnswer:{'@type':'Answer',text:'Red Gum BBQ (Red Hill) is consistently the strongest family option — BBQ format, outdoor tables, relaxed service, and food kids actually want to eat. Montalto Piazza (Red Hill South) is the best family-friendly winery option: walk-in daily, outdoor setting, sculpture trail to explore before or after eating. Green Olive at Red Hill (garden, outdoor, dog-friendly) works well for families who want a winery stop without the pressure of a hatted room.'}},{'@type':'Question',name:'Which restaurants on the Mornington Peninsula are good for young children?',acceptedAnswer:{'@type': 'Answer',text:'Red Gum BBQ (Red Hill) for BBQ in an outdoor setting — kids do not need to sit still. Montalto Piazza for walk-in winery dining with a sculpture trail. Flinders General Store for a relaxed village stop with outdoor tables. Most hatted and fine dining rooms on the Peninsula are not suited to young children.'}},{'@type':'Question',name:'Are there family-friendly winery restaurants on the Mornington Peninsula?',acceptedAnswer:{'@type':'Answer',text:'Montalto Piazza (walk-in, daily, outdoor, sculpture trail) is the clearest family-friendly winery option. Green Olive at Red Hill (garden, relaxed format, dog-friendly) is a good second. Merricks General Wine Store has outdoor seating and a casual format.'}}]};
---
<BaseLayout title="Family-Friendly Restaurants Mornington Peninsula · Peninsula Insider" description="Family-friendly dining on the Mornington Peninsula — Red Gum BBQ, Montalto Piazza, and the venues where bringing kids does not require an apology." section="eat" canonical="https://peninsulainsider.com.au/eat/family-friendly/" modifiedTime="2026-04-24">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Breadcrumbs items={breadcrumbItems} />
  <article class="article"><div class="container"><h1 class="article__title">Family-Friendly Dining on the Mornington Peninsula</h1><div class="prose"><p>Family-friendly dining on the Peninsula means outdoor seating, formats that do not require children to sit completely still for two hours, and venues where the staff have seen a high chair before. The list is shorter than the general dining list, but it is honest: these are the places that work with kids rather than merely tolerating them.</p><p>Red Gum BBQ in Red Hill is the clearest call — BBQ format, outdoor tables, and food that children actually want to eat. Montalto Piazza is the best family-friendly winery option: walk-in daily, sculpture trail on the property, outdoor seating, and a kitchen that does not require advance planning. Village cafes and pub beer gardens fill in the practical gaps.</p><p style="font-size:0.8rem;color:var(--soft)">Last fact-verified: 23 April 2026</p></div></div></article>
  <section class="venues" id="rankings"><div class="container"><div class="venues__header"><div><p class="label label--accent">Family-friendly shortlist</p><h2 class="venues__title">{venues.length} venues that work with kids</h2><p class="venues__sub">The outdoor, relaxed-format venues first. Hatted rooms are generally not on this list.</p></div><a href="/eat/" class="venues__link">All dining venues →</a></div><div class="venues__grid">{venues.map(v=><VenueCard venue={v} hrefPrefix="/eat" />)}</div></div></section>
  <section class="faq-section"><div class="container"><div class="prose"><h2>Frequently asked questions</h2><h3>Best family-friendly restaurants on the Peninsula?</h3><p>Red Gum BBQ (Red Hill): BBQ, outdoor tables, food kids want. Montalto Piazza: walk-in daily, sculpture trail, outdoor. Green Olive at Red Hill: garden, relaxed, dog-friendly.</p><h3>Best for young children?</h3><p>Red Gum BBQ and Montalto Piazza. Flinders General Store for a casual village stop. Most hatted rooms are not suited to young children.</p><h3>Family-friendly winery restaurants?</h3><p>Montalto Piazza (walk-in, sculpture trail) is the clearest. Green Olive at Red Hill (garden, relaxed). Merricks General Wine Store (outdoor seating, casual).</p></div></div></section>
  <section class="venues venues--plain"><div class="container"><div class="venues__header"><div><p class="label label--accent">Related guides</p><h2 class="venues__title">More Peninsula family content</h2></div></div><div class="venues__grid venues__grid--links"><div class="venue-card"><h3 class="venue-card__name"><a href="/eat/brunch/">Best Brunch</a></h3><p class="venue-card__signature">Cafes and morning-friendly venues across the Peninsula.</p><a href="/eat/brunch/" class="venue-card__cta">See the list →</a></div><div class="venue-card"><h3 class="venue-card__name"><a href="/eat/dog-friendly/">Dog-Friendly Dining</a></h3><p class="venue-card__signature">Outdoor dining with dogs confirmed as of April 2026.</p><a href="/eat/dog-friendly/" class="venue-card__cta">See the list →</a></div><div class="venue-card"><h3 class="venue-card__name"><a href="/eat/">All Eat & Drink</a></h3><p class="venue-card__signature">The full Peninsula dining guide.</p><a href="/eat/" class="venue-card__cta">Explore all →</a></div></div></div></section>
  <NewsletterBlock />
</BaseLayout>
