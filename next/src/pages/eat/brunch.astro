---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import VenueCard from '../../components/VenueCard.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { routeSlug } from '../../lib/editorial';

const allVenues = await getCollection('venues');

const brunchSlugs = [
  'commonfolk-coffee', 'many-little', 'martha-s-table', 'stringers-mornington',
  'merricks-general-wine-store', 'small-stone-pantry', 'somers-general',
  'store-ten', 'flinders-general-store'
];

const venues = brunchSlugs
  .map(s => allVenues.find(v => routeSlug(v) === s))
  .filter((v): v is NonNullable<typeof v> => Boolean(v));

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Eat & Drink', href: '/eat/' },
  { label: 'Best Brunch' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Best Brunch Mornington Peninsula',
  description: 'The best brunch spots on the Mornington Peninsula — specialty coffee, village cafes, and the rooms worth planning a morning around.',
  url: 'https://peninsulainsider.com.au/eat/brunch/',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://peninsulainsider.com.au/' },
      { '@type': 'ListItem', position: 2, name: 'Eat & Drink', item: 'https://peninsulainsider.com.au/eat/' },
      { '@type': 'ListItem', position: 3, name: 'Best Brunch', item: 'https://peninsulainsider.com.au/eat/brunch/' },
    ],
  },
  mainEntity: {
    '@type': 'ItemList',
    itemListOrder: 'https://schema.org/ItemListOrderDescending',
    numberOfItems: venues.length,
    itemListElement: venues.map((v, i) => ({
      '@type': 'ListItem', position: i + 1, name: v.data.name,
      url: `https://peninsulainsider.com.au/eat/${routeSlug(v)}/`,
    })),
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Where is the best brunch on the Mornington Peninsula?',
      acceptedAnswer: { '@type': 'Answer', text: 'Commonfolk Coffee (Mornington) is the Peninsula\'s best specialty coffee and runs a serious brunch menu daily. For a more elevated brunch experience, Many Little Bar & Dining (Red Hill South) offers hatted-restaurant quality in a cafe-daytime setting. Merricks General Wine Store is the most beautiful brunch setting on the Peninsula.' },
    },
    {
      '@type': 'Question',
      name: 'Which brunch spots on the Mornington Peninsula are dog-friendly?',
      acceptedAnswer: { '@type': 'Answer', text: 'Commonfolk Coffee (back courtyard), Somers General Store, and Flinders General Store all have confirmed dog-friendly outdoor seating. Check directly with venues as policies can change seasonally.' },
    },
    {
      '@type': 'Question',
      name: 'Do I need to book brunch on the Mornington Peninsula?',
      acceptedAnswer: { '@type': 'Answer', text: 'Many Little Bar & Dining takes bookings and can fill quickly on weekends. Commonfolk Coffee operates walk-in. Most village cafes on this list are walk-in. Arriving before 9:30am on weekends avoids the main queues at popular spots.' },
    },
  ],
};
---

<BaseLayout
  title="Best Brunch Mornington Peninsula · Peninsula Insider"
  description="The best brunch on the Mornington Peninsula — Commonfolk Coffee in Mornington, Many Little in Red Hill, and the village cafes worth planning a morning around."
  section="eat"
  canonical="https://peninsulainsider.com.au/eat/brunch/"
  modifiedTime="2026-04-24"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Breadcrumbs items={breadcrumbItems} />

  <article class="article">
    <div class="container">
      <h1 class="article__title">Best Brunch on the Mornington Peninsula</h1>
      <div class="prose">
        <p>Brunch on the Mornington Peninsula means either a specialty coffee destination in Mornington or a village cafe you would drive forty minutes for if you were not already nearby. The Peninsula's brunch scene is not a destination category in itself — it is the first half of a Peninsula day, the thing you do before the cellar door or the beach walk.</p>
        <p>Commonfolk Coffee (Mornington) is the benchmark. Everything else organises around it by geography. Somers General for the southern Mornington Shire bayside corridor. Merricks General for the ridge. Flinders General for the ocean coast. Many Little if you want something that reads more as a proper restaurant with a daytime offer.</p>
        <p>The weekend queues are real at the popular spots. Arriving before 9:30am solves most of them.</p>
        <p class="venues__sub" style="font-size:0.8rem;color:var(--soft)">Last fact-verified: 23 April 2026</p>
      </div>
    </div>
  </article>

  <section class="venues" id="rankings">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Brunch shortlist</p>
          <h2 class="venues__title">{venues.length} brunch spots worth knowing about</h2>
          <p class="venues__sub">The specialty coffee benchmark first, then the village cafes organised by where they are on the Peninsula.</p>
        </div>
        <a href="/eat/" class="venues__link">All dining venues →</a>
      </div>
      <div class="venues__grid">
        {venues.map((venue) => <VenueCard venue={venue} hrefPrefix="/eat" />)}
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <div class="prose">
        <h2>Frequently asked questions</h2>
        <h3>Where is the best brunch on the Mornington Peninsula?</h3>
        <p>Commonfolk Coffee (Mornington, 16 Progress Street) is the specialty coffee benchmark. For a more elevated daytime offer, Many Little Bar & Dining (Red Hill South) is the hatted-restaurant alternative. Merricks General Wine Store is the most beautiful setting on the Peninsula for a morning meal.</p>
        <h3>Which brunch spots are dog-friendly?</h3>
        <p>Commonfolk Coffee (back courtyard), Somers General Store, and Flinders General Store all have confirmed dog-friendly outdoor seating. Check directly with venues as policies can change.</p>
        <h3>Do I need to book?</h3>
        <p>Many Little takes bookings and can fill on weekends. Most village cafes on this list are walk-in. Arriving before 9:30am avoids the main weekend queues.</p>
      </div>
    </div>
  </section>

  <section class="venues venues--plain">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Related guides</p>
          <h2 class="venues__title">More ways to eat on the Peninsula</h2>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card"><h3 class="venue-card__name"><a href="/eat/cafes/">Best Cafes</a></h3><p class="venue-card__signature">The specialty coffee destination and the village cafes — from Commonfolk to Flinders General.</p><a href="/eat/cafes/" class="venue-card__cta">See the list →</a></div>
        <div class="venue-card"><h3 class="venue-card__name"><a href="/eat/bakeries/">Best Bakeries</a></h3><p class="venue-card__signature">Six Peninsula bakeries — where each is and what makes each one worth knowing.</p><a href="/eat/bakeries/" class="venue-card__cta">See the list →</a></div>
        <div class="venue-card"><h3 class="venue-card__name"><a href="/eat/long-lunch/">Long Lunch</a></h3><p class="venue-card__signature">If brunch is only the start — the rooms worth building an afternoon around afterwards.</p><a href="/eat/long-lunch/" class="venue-card__cta">See the list →</a></div>
      </div>
    </div>
  </section>

  <NewsletterBlock />
</BaseLayout>
