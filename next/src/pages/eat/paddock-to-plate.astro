---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import VenueCard from '../../components/VenueCard.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { routeSlug } from '../../lib/editorial';

const allVenues = await getCollection('venues');
const slugs=['tedesca-osteria','barragunda-dining','green-olive-red-hill','montalto','paringa-estate','kerri-greens','la-baracca-tgallant','red-gum-bbq','foxeys-hangout','merricks-general-wine-store','barmah-park'];
const venues=slugs.map(s=>allVenues.find(v=>routeSlug(v)===s)).filter((v):v is NonNullable<typeof v>=>Boolean(v)).sort((a,b)=>Number(b.data.authority?.hats??0)-Number(a.data.authority?.hats??0));

const breadcrumbItems=[{label:'Home',href:'/'},{label:'Eat & Drink',href:'/eat/'},{label:'Paddock to Plate'}];
const schema={'@context':'https://schema.org','@type':'CollectionPage',name:'Paddock to Plate Restaurants Mornington Peninsula',description:'Farm-to-table and paddock-to-plate restaurants on the Mornington Peninsula — kitchens growing their own produce, sourcing from nearby farms, and cooking with what the landscape actually provides.',url:'https://peninsulainsider.com.au/eat/paddock-to-plate/',breadcrumb:{'@type':'BreadcrumbList',itemListElement:[{position:1,name:'Home',item:'https://peninsulainsider.com.au/'},{position:2,name:'Eat & Drink',item:'https://peninsulainsider.com.au/eat/'},{position:3,name:'Paddock to Plate',item:'https://peninsulainsider.com.au/eat/paddock-to-plate/'}].map(e=>({'@type':'ListItem',...e}))},mainEntity:{'@type':'ItemList',itemListOrder:'https://schema.org/ItemListOrderDescending',numberOfItems:venues.length,itemListElement:venues.map((v,i)=>({'@type':'ListItem',position:i+1,name:v.data.name,url:`https://peninsulainsider.com.au/eat/${routeSlug(v)}/`}))}};
const faqSchema={'@context':'https://schema.org','@type':'FAQPage',mainEntity:[{'@type':'Question',name:'Which Mornington Peninsula restaurants grow their own produce?',acceptedAnswer:{'@type':'Answer',text:'Tedesca Osteria (Red Hill) runs a biodynamic property with chickens, beehives, sheep, and an on-site kitchen garden — the most fully realised farm-to-table operation on the Peninsula. Barragunda Dining (Cape Schanck) grows its own organic vegetables on a 1000-acre estate and sources hyper-locally. Green Olive at Red Hill (Red Hill South) is built around an organic olive grove, orchard, and kitchen garden.'}},{'@type':'Question',name:'What does paddock to plate mean in a restaurant context?',acceptedAnswer:{'@type':'Answer',text:'Paddock to plate means the restaurant sources its produce from its own farm or from nearby farms, with a short, traceable supply chain from paddock to kitchen. On the Peninsula, this means estate-grown vegetables, local seafood, and regional producers rather than wholesale distributors. The strongest examples are Tedesca Osteria, Barragunda, and Green Olive — all of which grow some or most of their produce on-site.'}},{'@type':'Question',name:'Is paddock to plate just marketing or does it mean something on the Mornington Peninsula?',acceptedAnswer:{'@type':'Answer',text:'On the Peninsula, it means something real at the best restaurants. Tedesca Osteria\'s biodynamic property, Barragunda\'s estate garden, and Green Olive\'s olive grove all genuinely supply their kitchens. Some venues use the term more loosely. As a filter, look for restaurants that name their farms and producers on the menu — not just claim the concept.'}}]};
---
<BaseLayout title="Paddock to Plate Restaurants Mornington Peninsula · Peninsula Insider" description="Farm-to-table restaurants on the Mornington Peninsula — Tedesca Osteria's biodynamic farm, Barragunda's estate garden, and the kitchens that actually grow what they serve." section="eat" canonical="https://peninsulainsider.com.au/eat/paddock-to-plate/" modifiedTime="2026-04-24">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Breadcrumbs items={breadcrumbItems} />
  <article class="article"><div class="container"><h1 class="article__title">Paddock to Plate on the Mornington Peninsula</h1><div class="prose"><p>The Peninsula has more genuine farm-to-table dining than almost any other regional destination in Victoria. The landscape produces it: the cool plateau grows some of Australia's best cool-climate produce, the Bass Strait coast supplies exceptional seafood, and the farm density in the Red Hill hinterland means short supply chains are the rule rather than the exception.</p><p>The strongest example is Tedesca Osteria — a biodynamic property in Red Hill where Brigitte Hafner keeps chickens, beehives, and Wiltshire Horn sheep that supply the kitchen alongside an on-site garden. It is the most fully realised farm restaurant on the Peninsula and one of the most serious in Victoria. Below it, Barragunda (estate-grown organic vegetables, hibachi-charred proteins), Green Olive (olive grove, orchard, kitchen garden), and a set of cellar door restaurants where the wine and food share the same landscape.</p><p style="font-size:0.8rem;color:var(--soft)">Last fact-verified: 23 April 2026</p></div></div></article>
  <section class="venues" id="rankings"><div class="container"><div class="venues__header"><div><p class="label label--accent">Farm-to-table shortlist</p><h2 class="venues__title">{venues.length} kitchens cooking with what the Peninsula actually grows</h2><p class="venues__sub">Hatted farm restaurants first, then the venues where the supply chain is visibly short.</p></div><a href="/eat/" class="venues__link">All dining venues →</a></div><div class="venues__grid venues__grid--ranked">{venues.map(v=><VenueCard venue={v} hrefPrefix="/eat" />)}</div></div></section>
  <section class="faq-section"><div class="container"><div class="prose"><h2>Frequently asked questions</h2><h3>Which restaurants grow their own produce?</h3><p>Tedesca Osteria: biodynamic property, chickens, beehives, sheep, kitchen garden. Barragunda: estate-grown organic vegetables on a 1000-acre property. Green Olive at Red Hill: olive grove, orchard, kitchen garden.</p><h3>Does paddock to plate mean something real here?</h3><p>At the best venues, yes. Tedesca, Barragunda, and Green Olive genuinely supply their kitchens from on-site or nearby farms. Look for menus that name producers — that's the real signal.</p></div></div></section>
  <section class="venues venues--plain"><div class="container"><div class="venues__header"><div><p class="label label--accent">Related guides</p><h2 class="venues__title">More ways to eat on the Peninsula</h2></div></div><div class="venues__grid venues__grid--links"><div class="venue-card"><h3 class="venue-card__name"><a href="/eat/fine-dining/">Fine Dining</a></h3><p class="venue-card__signature">The destination dining rooms — most of the serious farm-restaurant kitchens are also hatted.</p><a href="/eat/fine-dining/" class="venue-card__cta">See the list →</a></div><div class="venue-card"><h3 class="venue-card__name"><a href="/eat/cellar-door-lunch/">Cellar Door Lunch</a></h3><p class="venue-card__signature">Winery restaurants where the kitchen shares the landscape with the vines.</p><a href="/eat/cellar-door-lunch/" class="venue-card__cta">See the list →</a></div><div class="venue-card"><h3 class="venue-card__name"><a href="/eat/">All Eat & Drink</a></h3><p class="venue-card__signature">The full Peninsula dining guide.</p><a href="/eat/" class="venue-card__cta">Explore all →</a></div></div></div></section>
  <NewsletterBlock />
</BaseLayout>
