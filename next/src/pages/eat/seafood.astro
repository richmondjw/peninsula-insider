---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import VenueCard from '../../components/VenueCard.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { routeSlug } from '../../lib/editorial';

const allVenues = await getCollection('venues');
const slugs = ['pier-street-flinders','the-baths-sorrento','the-rocks-mornington','afloat-mornington','ocean-eight','flinders-pier-takeaway','portsea-hotel'];
const venues = slugs.map(s=>allVenues.find(v=>routeSlug(v)===s)).filter((v):v is NonNullable<typeof v>=>Boolean(v));

const breadcrumbItems=[{label:'Home',href:'/'},{label:'Eat & Drink',href:'/eat/'},{label:'Seafood'}];
const schema={'@context':'https://schema.org','@type':'CollectionPage',name:'Best Seafood Restaurants Mornington Peninsula',description:'The best seafood restaurants on the Mornington Peninsula — waterfront bay dining, seafood takeaway, and the cellar-door kitchen doing the category properly.',url:'https://peninsulainsider.com.au/eat/seafood/',breadcrumb:{'@type':'BreadcrumbList',itemListElement:[{position:1,name:'Home',item:'https://peninsulainsider.com.au/'},{position:2,name:'Eat & Drink',item:'https://peninsulainsider.com.au/eat/'},{position:3,name:'Seafood',item:'https://peninsulainsider.com.au/eat/seafood/'}].map(e=>({'@type':'ListItem',...e}))},mainEntity:{'@type':'ItemList',itemListOrder:'https://schema.org/ItemListOrderDescending',numberOfItems:venues.length,itemListElement:venues.map((v,i)=>({'@type':'ListItem',position:i+1,name:v.data.name,url:`https://peninsulainsider.com.au/eat/${routeSlug(v)}/`}))}};
const faqSchema={'@context':'https://schema.org','@type':'FAQPage',mainEntity:[{'@type':'Question',name:'Where is the best seafood on the Mornington Peninsula?',acceptedAnswer:{'@type':'Answer',text:'Pier Street Kitchen in Flinders holds one GFG hat and is the strongest all-round seafood dining room on the Peninsula. The Baths at Sorrento is the best waterfront seafood experience. Afloat in Mornington does the best fish and chips in a sit-down setting. For a casual takeaway, Flinders Pier Takeaway is local institution.'}},{'@type':'Question',name:'Where can I get fish and chips on the Mornington Peninsula?',acceptedAnswer:{'@type':'Answer',text:'Flinders Pier Takeaway is the Peninsula benchmark for fish and chips — the pier location, fresh fish, and no-frills format make it a genuinely good stop. Afloat in Mornington is the better sit-down version. Both are cash-friendly and suited to a beach day.'}},{'@type':'Question',name:'Are there dog-friendly seafood restaurants on the Mornington Peninsula?',acceptedAnswer:{'@type':'Answer',text:'The Rocks at Mornington (outdoor deck) and Portsea Hotel (beer garden) are both confirmed dog-friendly and serve seafood menus. Verify directly before visiting as policies can change.'}}]};
---
<BaseLayout title="Best Seafood Mornington Peninsula · Peninsula Insider" description="The best seafood restaurants on the Mornington Peninsula — Pier Street Kitchen's hatted kitchen, The Baths at Sorrento, waterfront fish and chips, and local oysters." section="eat" canonical="https://peninsulainsider.com.au/eat/seafood/" modifiedTime="2026-04-24">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Breadcrumbs items={breadcrumbItems} />
  <article class="article"><div class="container"><h1 class="article__title">Best Seafood on the Mornington Peninsula</h1><div class="prose"><p>The Peninsula's seafood scene is concentrated around its waterfront towns and fishing piers. Pier Street Kitchen in Flinders is the strongest all-round seafood dining room — one GFG hat, a proper kitchen, and a setting that justifies the southern drive. The Baths at Sorrento is the waterfront experience, and Flinders Pier Takeaway is the benchmark for a genuinely good casual stop that does not pretend to be anything else.</p><p>The Peninsula's fish is primarily sourced locally or from the southern Victorian coast — king george whiting, calamari, abalone in season, and Mornington Peninsula oysters when available. The category rewards finding the right venue for the right kind of afternoon.</p><p style="font-size:0.8rem;color:var(--soft)">Last fact-verified: 23 April 2026</p></div></div></article>
  <section class="venues" id="rankings"><div class="container"><div class="venues__header"><div><p class="label label--accent">Seafood shortlist</p><h2 class="venues__title">{venues.length} seafood venues ranked</h2><p class="venues__sub">The hatted kitchen first, then the waterfront dining options, then the best casual stops.</p></div><a href="/eat/" class="venues__link">All dining venues →</a></div><div class="venues__grid venues__grid--ranked">{venues.map(v=><VenueCard venue={v} hrefPrefix="/eat" />)}</div></div></section>
  <section class="faq-section"><div class="container"><div class="prose"><h2>Frequently asked questions</h2><h3>Where is the best seafood on the Mornington Peninsula?</h3><p>Pier Street Kitchen (Flinders) holds one GFG hat and is the strongest all-round seafood dining room. The Baths at Sorrento is the best waterfront seafood experience. Flinders Pier Takeaway is the local institution for fish and chips.</p><h3>Where can I get fish and chips?</h3><p>Flinders Pier Takeaway — the pier location, fresh fish, no-frills format. Afloat in Mornington is the better sit-down version.</p><h3>Are there dog-friendly seafood venues?</h3><p>The Rocks at Mornington (outdoor deck) and Portsea Hotel (beer garden) are confirmed dog-friendly and serve seafood menus. Verify before visiting.</p></div></div></section>
  <section class="venues venues--plain"><div class="container"><div class="venues__header"><div><p class="label label--accent">Related guides</p><h2 class="venues__title">More ways to eat on the Peninsula</h2></div></div><div class="venues__grid venues__grid--links"><div class="venue-card"><h3 class="venue-card__name"><a href="/eat/waterfront/">Waterfront Dining</a></h3><p class="venue-card__signature">Bay-facing positions at Sorrento, Mornington, and Portsea — compared honestly.</p><a href="/eat/waterfront/" class="venue-card__cta">See the list →</a></div><div class="venue-card"><h3 class="venue-card__name"><a href="/eat/fine-dining/">Fine Dining</a></h3><p class="venue-card__signature">The destination dining rooms worth planning a whole Peninsula day around.</p><a href="/eat/fine-dining/" class="venue-card__cta">See the list →</a></div><div class="venue-card"><h3 class="venue-card__name"><a href="/eat/">All Eat & Drink</a></h3><p class="venue-card__signature">The full Peninsula dining guide — restaurants, cellar doors, cafes, bakeries, and pubs.</p><a href="/eat/" class="venue-card__cta">Explore all →</a></div></div></div></section>
  <NewsletterBlock />
</BaseLayout>
