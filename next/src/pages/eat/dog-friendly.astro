---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import VenueCard from '../../components/VenueCard.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { routeSlug } from '../../lib/editorial';

const allVenues = await getCollection('venues');

const dogFriendlySlugs = [
  'commonfolk-coffee', 'somers-general', 'merricks-general-wine-store',
  'green-olive-red-hill', 'flinders-general-store', 'balnarring-pub',
  'rye-hotel', 'sorrento-gelato', 'the-rocks-mornington', 'portsea-hotel'
];

const venues = dogFriendlySlugs
  .map(s => allVenues.find(v => routeSlug(v) === s))
  .filter((v): v is NonNullable<typeof v> => Boolean(v));

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Eat & Drink', href: '/eat/' },
  { label: 'Dog-Friendly Dining' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Dog-Friendly Restaurants Mornington Peninsula',
  description: 'Dog-friendly dining on the Mornington Peninsula — outdoor seating at cafes, village pubs with beer gardens, and a few winery options where dogs are welcome.',
  url: 'https://peninsulainsider.com.au/eat/dog-friendly/',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://peninsulainsider.com.au/' },
      { '@type': 'ListItem', position: 2, name: 'Eat & Drink', item: 'https://peninsulainsider.com.au/eat/' },
      { '@type': 'ListItem', position: 3, name: 'Dog-Friendly Dining', item: 'https://peninsulainsider.com.au/eat/dog-friendly/' },
    ],
  },
  mainEntity: {
    '@type': 'ItemList',
    itemListOrder: 'https://schema.org/ItemListOrderDescending',
    numberOfItems: venues.length,
    itemListElement: venues.map((v, i) => ({
      '@type': 'ListItem', position: i + 1, name: v.data.name,
      url: `https://peninsulainsider.com.au/eat/${routeSlug(v)}/`,
    })),
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Which restaurants on the Mornington Peninsula are dog-friendly?',
      acceptedAnswer: { '@type': 'Answer', text: 'Dog-friendly dining on the Peninsula concentrates at outdoor-seating cafes, village pub beer gardens, and a small number of winery casual areas. Confirmed dog-friendly as of April 2026: Commonfolk Coffee (back courtyard), Somers General Store (outdoor), Merricks General Wine Store (outdoor), Green Olive at Red Hill (garden), Flinders General Store (outdoor), The Rocks Mornington (outdoor deck), Portsea Hotel (beer garden), Balnarring Pub (beer garden), and Rye Hotel (outdoor area). Dog policies change — verify directly before visiting.' },
    },
    {
      '@type': 'Question',
      name: 'Can I take my dog to wineries on the Mornington Peninsula?',
      acceptedAnswer: { '@type': 'Answer', text: 'A small number of wineries allow dogs in outdoor areas. Green Olive at Red Hill (garden area) and Merricks General Wine Store (outdoor seating) are confirmed. Most cellar door restaurants do not permit dogs — including Foxeys Hangout, Montalto, Quealy Winemakers, and most others. Confirm directly with any winery before visiting with a dog.' },
    },
    {
      '@type': 'Question',
      name: 'What is the best dog-friendly pub on the Mornington Peninsula?',
      acceptedAnswer: { '@type': 'Answer', text: 'The Portsea Hotel has the best dog-friendly beer garden with sweeping Port Phillip Bay views. Balnarring Pub is the most relaxed and local-feeling dog-friendly pub on the Peninsula. Both confirm dogs are welcome in outdoor areas.' },
    },
  ],
};
---

<BaseLayout
  title="Dog-Friendly Restaurants Mornington Peninsula · Peninsula Insider"
  description="Dog-friendly dining on the Mornington Peninsula — confirmed outdoor seating at cafes, pubs with beer gardens, and winery casual areas where dogs are welcome. Verified April 2026."
  section="eat"
  canonical="https://peninsulainsider.com.au/eat/dog-friendly/"
  modifiedTime="2026-04-24"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Breadcrumbs items={breadcrumbItems} />

  <article class="article">
    <div class="container">
      <h1 class="article__title">Dog-Friendly Dining on the Mornington Peninsula</h1>
      <div class="prose">
        <p style="background:rgba(180,100,40,0.08);border-left:3px solid var(--accent);padding:1rem 1.25rem;border-radius:0 4px 4px 0"><strong>Dog policies change.</strong> This list is based on outdoor-seating policies as of April 2026. Verify directly with the venue before you visit with a dog.</p>
        <p>Dog-friendly dining on the Peninsula concentrates at three types of venue: outdoor-seating specialty cafes, village pub beer gardens, and a small number of winery casual dining areas. Most Peninsula restaurants, cellar door dining rooms, and hatted venues do not permit dogs.</p>
        <p>The clearest options: Commonfolk Coffee in Mornington has a proper back courtyard. The Portsea Hotel and Balnarring Pub both have dog-friendly beer gardens with outdoor dining. Green Olive at Red Hill and Merricks General Wine Store are the best winery-adjacent options.</p>
        <p class="venues__sub" style="font-size:0.8rem;color:var(--soft)">Last fact-verified: 23 April 2026</p>
      </div>
    </div>
  </article>

  <section class="venues" id="rankings">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Dog-friendly venues confirmed April 2026</p>
          <h2 class="venues__title">{venues.length} venues confirmed for outdoor dining with dogs</h2>
          <p class="venues__sub">Always verify directly with the venue before visiting with a dog — policies change seasonally.</p>
        </div>
        <a href="/eat/" class="venues__link">All dining venues →</a>
      </div>
      <div class="venues__grid">
        {venues.map((venue) => <VenueCard venue={venue} hrefPrefix="/eat" />)}
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <div class="prose">
        <h2>Frequently asked questions</h2>
        <h3>Which restaurants are dog-friendly on the Mornington Peninsula?</h3>
        <p>Confirmed as of April 2026: Commonfolk Coffee (back courtyard), Somers General, Merricks General Wine Store, Green Olive at Red Hill, Flinders General Store, The Rocks Mornington (outdoor deck), Portsea Hotel (beer garden), Balnarring Pub, Rye Hotel (outdoor). Dog policies change — verify before visiting.</p>
        <h3>Can I take my dog to a winery?</h3>
        <p>A small number of wineries allow dogs in outdoor areas: Green Olive at Red Hill and Merricks General Wine Store are confirmed. Most cellar door restaurants do not permit dogs. Confirm directly with any winery before arriving with a dog.</p>
        <h3>What is the best dog-friendly pub on the Peninsula?</h3>
        <p>The Portsea Hotel has the best beer garden with bay views. Balnarring Pub is the most relaxed and local-feeling dog-friendly pub. Both confirm dogs welcome in outdoor areas.</p>
      </div>
    </div>
  </section>

  <section class="venues venues--plain">
    <div class="container">
      <div class="venues__header">
        <div>
          <p class="label label--accent">Related guides</p>
          <h2 class="venues__title">More dog-friendly Peninsula content</h2>
        </div>
      </div>
      <div class="venues__grid venues__grid--links">
        <div class="venue-card"><h3 class="venue-card__name"><a href="/journal/dog-friendly-cafes-pubs-wineries-mornington-peninsula/">Dog-Friendly Cafes, Pubs & Wineries</a></h3><p class="venue-card__signature">The full guide — where dogs are welcome, the rules that apply, and how to plan a dog-friendly Peninsula day.</p><a href="/journal/dog-friendly-cafes-pubs-wineries-mornington-peninsula/" class="venue-card__cta">Read the guide →</a></div>
        <div class="venue-card"><h3 class="venue-card__name"><a href="/dog-friendly/">Dog-Friendly Peninsula</a></h3><p class="venue-card__signature">Beaches, walks, cafes, and accommodation — the complete guide to the Peninsula with a dog.</p><a href="/dog-friendly/" class="venue-card__cta">Explore →</a></div>
        <div class="venue-card"><h3 class="venue-card__name"><a href="/eat/">All Eat & Drink</a></h3><p class="venue-card__signature">The full Peninsula dining guide — restaurants, cellar doors, cafes, bakeries, and pubs.</p><a href="/eat/" class="venue-card__cta">Explore all →</a></div>
      </div>
    </div>
  </section>

  <NewsletterBlock />
</BaseLayout>
