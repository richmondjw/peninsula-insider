---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import VenueCard from '../../components/VenueCard.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { routeSlug } from '../../lib/editorial';

const allVenues = await getCollection('venues');
// Dog-friendly wineries confirmed as of April 2026
const slugs = ['stonier-wines','main-ridge-estate','kerri-greens','green-olive-red-hill','montalto','foxeys-hangout','paringa-estate'];
const venues = slugs.map(s=>allVenues.find(v=>routeSlug(v)===s)).filter((v):v is NonNullable<typeof v>=>Boolean(v));

const breadcrumbItems=[{label:'Home',href:'/'},{label:'Wine Country',href:'/wine/'},{label:'Dog-Friendly Wineries'}];
const schema={'@context':'https://schema.org','@type':'CollectionPage',name:'Dog-Friendly Wineries Mornington Peninsula',description:'Wineries on the Mornington Peninsula that welcome dogs — confirmed outdoor areas and policies as of April 2026.',url:'https://peninsulainsider.com.au/wine/dog-friendly/',breadcrumb:{'@type':'BreadcrumbList',itemListElement:[{position:1,name:'Home',item:'https://peninsulainsider.com.au/'},{position:2,name:'Wine Country',item:'https://peninsulainsider.com.au/wine/'},{position:3,name:'Dog-Friendly Wineries',item:'https://peninsulainsider.com.au/wine/dog-friendly/'}].map(e=>({'@type':'ListItem',...e}))},mainEntity:{'@type':'ItemList',itemListOrder:'https://schema.org/ItemListOrderDescending',numberOfItems:venues.length,itemListElement:venues.map((v,i)=>({'@type':'ListItem',position:i+1,name:v.data.name,url:`https://peninsulainsider.com.au/wine/${routeSlug(v)}/`}))}};
const faqSchema={'@context':'https://schema.org','@type':'FAQPage',mainEntity:[{'@type':'Question',name:'Which wineries on the Mornington Peninsula allow dogs?',acceptedAnswer:{'@type':'Answer',text:'Confirmed dog-friendly as of April 2026: Stonier Wines (lawn area), Main Ridge Estate (on-lead, must pre-book), Kerri Greens (outdoor area), Green Olive at Red Hill (garden, dog-friendly, also a restaurant). Most Peninsula cellar doors do not permit dogs — Foxeys Hangout and Quealy Winemakers explicitly do not. Always confirm directly before visiting.'}},{'@type':'Question',name:'Do any hatted winery restaurants allow dogs?',acceptedAnswer:{'@type':'Answer',text:'Montalto Piazza (walk-in, outdoor) is the closest — confirmed dog-friendly in the casual outdoor dining area. Most hatted restaurants including Montalto\'s main restaurant, Polperro, and Ten Minutes by Tractor do not permit dogs.'}},{'@type':'Question',name:'Do I need to call ahead to bring a dog to a winery on the Mornington Peninsula?',acceptedAnswer:{'@type':'Answer',text:'Yes — Main Ridge Estate explicitly requires pre-booking before arriving with a dog. For all other venues, calling or emailing ahead is strongly recommended as dog policies can change seasonally or with events.'}}]};
---
<BaseLayout title="Dog-Friendly Wineries Mornington Peninsula · Peninsula Insider" description="Wineries on the Mornington Peninsula that welcome dogs — confirmed outdoor areas at Stonier, Main Ridge Estate, Kerri Greens, Green Olive, and Montalto Piazza. Verified April 2026." section="wine" canonical="https://peninsulainsider.com.au/wine/dog-friendly/" modifiedTime="2026-04-24">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Breadcrumbs items={breadcrumbItems} />
  <article class="article"><div class="container"><h1 class="article__title">Dog-Friendly Wineries on the Mornington Peninsula</h1><div class="prose">
    <p style="background:rgba(180,100,40,0.08);border-left:3px solid var(--accent);padding:1rem 1.25rem;border-radius:0 4px 4px 0"><strong>Dog policies change.</strong> This list is based on confirmed outdoor-area policies as of April 2026. Call or email ahead before visiting with a dog.</p>
    <p>Dog-friendly winery visits on the Peninsula are genuinely possible but limited. Most cellar doors and winery restaurants do not permit dogs. The exceptions are outdoor garden areas and casual dining spaces at a small number of estates. Main Ridge Estate requires pre-booking before arriving with a dog — do not assume you can walk in.</p>
    <p>The clearest options: Stonier Wines (lawn), Kerri Greens (outdoor), Green Olive at Red Hill (garden and restaurant), and Montalto Piazza (casual outdoor dining, walk-in). For confirmed non-dog-friendly venues: Foxeys Hangout and Quealy Winemakers explicitly do not permit dogs.</p>
    <p style="font-size:0.8rem;color:var(--soft)">Last fact-verified: 23 April 2026</p>
  </div></div></article>
  <section class="venues" id="rankings"><div class="container"><div class="venues__header"><div><p class="label label--accent">Dog-friendly wineries — confirmed April 2026</p><h2 class="venues__title">{venues.length} wineries with confirmed outdoor dog areas</h2><p class="venues__sub">Call ahead. Policies change. Main Ridge Estate requires pre-booking before arriving with a dog.</p></div><a href="/wine/" class="venues__link">All wineries →</a></div><div class="venues__grid">{venues.map(v=><VenueCard venue={v} hrefPrefix="/wine" />)}</div></div></section>
  <section class="faq-section"><div class="container"><div class="prose"><h2>Frequently asked questions</h2><h3>Which wineries allow dogs?</h3><p>Confirmed as of April 2026: Stonier (lawn), Main Ridge Estate (on-lead, pre-book required), Kerri Greens (outdoor), Green Olive at Red Hill (garden). Most Peninsula cellar doors do not permit dogs. Foxeys Hangout and Quealy Winemakers explicitly exclude dogs.</p><h3>Do I need to call ahead?</h3><p>Yes, always. Main Ridge Estate explicitly requires pre-booking before arriving with a dog. For all other venues, call or email ahead as policies change seasonally.</p></div></div></section>
  <section class="venues venues--plain"><div class="container"><div class="venues__header"><div><p class="label label--accent">Related guides</p><h2 class="venues__title">More dog-friendly Peninsula content</h2></div></div><div class="venues__grid venues__grid--links"><div class="venue-card"><h3 class="venue-card__name"><a href="/journal/dog-friendly-wineries-mornington-peninsula/">Dog-Friendly Wineries Guide</a></h3><p class="venue-card__signature">The full guide to dog-friendly winery visits — policies, pre-booking rules, and where dogs are genuinely welcome.</p><a href="/journal/dog-friendly-wineries-mornington-peninsula/" class="venue-card__cta">Read the guide →</a></div><div class="venue-card"><h3 class="venue-card__name"><a href="/eat/dog-friendly/">Dog-Friendly Dining</a></h3><p class="venue-card__signature">Dog-friendly restaurants, cafes, and pubs on the Peninsula — confirmed April 2026.</p><a href="/eat/dog-friendly/" class="venue-card__cta">See the list →</a></div><div class="venue-card"><h3 class="venue-card__name"><a href="/wine/">All Wine Country</a></h3><p class="venue-card__signature">All Peninsula cellar doors, producers, and winery restaurants.</p><a href="/wine/" class="venue-card__cta">Explore →</a></div></div></div></section>
  <NewsletterBlock />
</BaseLayout>
