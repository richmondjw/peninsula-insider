---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import VenueCard from '../../components/VenueCard.astro';
import NewsletterBlock from '../../components/NewsletterBlock.astro';
import { routeSlug } from '../../lib/editorial';

const allVenues = await getCollection('venues');
// Top cellar doors - walk-in first, appointment-recommended second
const walkInSlugs = ['montalto','foxeys-hangout','paringa-estate','polperro','t-gallant','red-hill-estate','green-olive-red-hill','ocean-eight','crittenden-estate'];
const appointmentSlugs = ['ten-minutes-by-tractor','pt-leo-estate','kooyong','yabby-lake','main-ridge-estate','eldridge-estate','dexter-wines','garagiste'];
const allSlugs = [...walkInSlugs,...appointmentSlugs];
const venues = allSlugs.map(s=>allVenues.find(v=>routeSlug(v)===s)).filter((v):v is NonNullable<typeof v>=>Boolean(v));
const walkIns = walkInSlugs.map(s=>allVenues.find(v=>routeSlug(v)===s)).filter((v):v is NonNullable<typeof v>=>Boolean(v));
const appointments = appointmentSlugs.map(s=>allVenues.find(v=>routeSlug(v)===s)).filter((v):v is NonNullable<typeof v>=>Boolean(v));

const breadcrumbItems=[{label:'Home',href:'/'},{label:'Wine Country',href:'/wine/'},{label:'Cellar Doors'}];
const schema={'@context':'https://schema.org','@type':'CollectionPage',name:'Best Cellar Doors Mornington Peninsula',description:'The best cellar doors on the Mornington Peninsula — walk-in and appointment-only tastings, ranked by editorial authority.',url:'https://peninsulainsider.com.au/wine/cellar-doors/',breadcrumb:{'@type':'BreadcrumbList',itemListElement:[{position:1,name:'Home',item:'https://peninsulainsider.com.au/'},{position:2,name:'Wine Country',item:'https://peninsulainsider.com.au/wine/'},{position:3,name:'Cellar Doors',item:'https://peninsulainsider.com.au/wine/cellar-doors/'}].map(e=>({'@type':'ListItem',...e}))},mainEntity:{'@type':'ItemList',itemListOrder:'https://schema.org/ItemListOrderDescending',numberOfItems:venues.length,itemListElement:venues.map((v,i)=>({'@type':'ListItem',position:i+1,name:v.data.name,url:`https://peninsulainsider.com.au/wine/${routeSlug(v)}/`}))}};
const faqSchema={'@context':'https://schema.org','@type':'FAQPage',mainEntity:[{'@type':'Question',name:'Which Mornington Peninsula cellar doors can I visit without a booking?',acceptedAnswer:{'@type':'Answer',text:'Walk-in (no booking required for groups of 1–8): Montalto, Foxeys Hangout (no bookings accepted at all), Paringa Estate, T\'Gallant, Red Hill Estate, Polperro, Green Olive at Red Hill, Ocean Eight, Crittenden Estate. Most others welcome walk-ins but recommend booking ahead on weekends.'}},{'@type': 'Question',name:'Which Mornington Peninsula wineries are best for a first visit?',acceptedAnswer:{'@type':'Answer',text:'Montalto is the most complete first-visit cellar door — sculpture trail, kitchen, walk-in Piazza, tasting room, and wine shop in one place. Paringa Estate and Foxeys Hangout are good entry points for a more intimate single-focus visit.'}},{'@type':'Question',name:'What is a tasting fee at Peninsula cellar doors?',acceptedAnswer:{'@type':'Answer',text:'Typically $15–$25 per person, usually redeemable on a purchase. Some cellar doors charge for premium tastings. Ten Minutes by Tractor and Pt. Leo Estate have formal tasting experiences at higher price points. Foxeys Hangout charges no tasting fee.'}}]};
---
<BaseLayout title="Best Cellar Doors Mornington Peninsula · Peninsula Insider" description="The best cellar doors on the Mornington Peninsula — walk-in and appointment-only tastings ranked by editorial authority. Montalto, Foxeys, Paringa, Ten Minutes by Tractor, and more." section="wine" canonical="https://peninsulainsider.com.au/wine/cellar-doors/" modifiedTime="2026-04-24">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Breadcrumbs items={breadcrumbItems} />
  <article class="article"><div class="container"><h1 class="article__title">Best Cellar Doors on the Mornington Peninsula</h1><div class="prose"><p>The Peninsula has more than forty cellar doors. Not all of them are worth the stop, and the ones worth visiting have different formats — some are walk-in, some work better with a booking, and a handful are appointment-only operations where the wines are good enough that you should plan around them rather than drop in.</p><p>The walk-in group is the easiest entry point. Montalto is the most complete estate: tasting room, Piazza dining, kitchen garden, and a sculpture trail. Foxeys Hangout is the most genuinely informal and biodynamically committed. Paringa Estate is the clearest value-for-tasting stop on the ridge.</p><p>The appointment wineries — Ten Minutes by Tractor, Pt. Leo Estate, Kooyong, Yabby Lake — require more planning but produce the Peninsula's most serious wines. If you are interested in what the region's best terroir-driven production actually tastes like, build a trip around at least one of them.</p><p style="font-size:0.8rem;color:var(--soft)">Last fact-verified: 23 April 2026</p></div></div></article>
  <section class="venues"><div class="container"><div class="venues__header"><div><p class="label label--accent">Walk-in cellar doors</p><h2 class="venues__title">{walkIns.length} cellar doors you can visit without a booking</h2><p class="venues__sub">For groups of 1–8. Weekend mornings still fill — arrive before noon for the best experience.</p></div><a href="/wine/" class="venues__link">All wineries →</a></div><div class="venues__grid">{walkIns.map(v=><VenueCard venue={v} hrefPrefix="/wine" />)}</div></div></section>
  <section class="venues venues--plain"><div class="container"><div class="venues__header"><div><p class="label label--accent">Appointment-recommended wineries</p><h2 class="venues__title">{appointments.length} serious estates that reward planning</h2><p class="venues__sub">Book ahead. The tasting experience at these properties is calibrated for visitors who made the effort.</p></div></div><div class="venues__grid">{appointments.map(v=><VenueCard venue={v} hrefPrefix="/wine" />)}</div></div></section>
  <section class="faq-section"><div class="container"><div class="prose"><h2>Frequently asked questions</h2><h3>Which cellar doors can I visit without a booking?</h3><p>Montalto, Foxeys Hangout (no bookings taken at all), Paringa Estate, T'Gallant, Red Hill Estate, Polperro, Green Olive at Red Hill, Ocean Eight, Crittenden Estate all welcome walk-ins for groups of 1–8.</p><h3>Best for a first visit?</h3><p>Montalto — the most complete first-visit estate. Paringa Estate and Foxeys Hangout for a more focused single-estate experience.</p><h3>What is a typical tasting fee?</h3><p>$15–$25 per person, usually redeemable on a purchase. Foxeys Hangout charges no tasting fee. Ten Minutes by Tractor and Pt. Leo Estate have formal tasting experiences at higher price points.</p></div></div></section>
  <section class="venues venues--plain"><div class="container"><div class="venues__header"><div><p class="label label--accent">Related guides</p><h2 class="venues__title">More wine country content</h2></div></div><div class="venues__grid venues__grid--links"><div class="venue-card"><h3 class="venue-card__name"><a href="/eat/cellar-door-lunch/">Cellar Door Lunch</a></h3><p class="venue-card__signature">Winery restaurants worth building a whole afternoon around.</p><a href="/eat/cellar-door-lunch/" class="venue-card__cta">See the list →</a></div><div class="venue-card"><h3 class="venue-card__name"><a href="/wine/red-hill/">Red Hill Wineries</a></h3><p class="venue-card__signature">The Peninsula's highest-concentration wine sub-region.</p><a href="/wine/red-hill/" class="venue-card__cta">Explore →</a></div><div class="venue-card"><h3 class="venue-card__name"><a href="/wine/">All Wine Country</a></h3><p class="venue-card__signature">All Peninsula cellar doors — by sub-region, style, and opening hours.</p><a href="/wine/" class="venue-card__cta">Explore →</a></div></div></div></section>
  <NewsletterBlock />
</BaseLayout>
