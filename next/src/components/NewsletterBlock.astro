---
/**
 * NewsletterBlock  -  the dark CTA block that closes most pages.
 * Exposes an id="newsletter" anchor so the masthead CTA works from any page.
 *
 * Layout: stacked  -  headline → body → embed → proof points.
 * Centred, single-column flow for a clean editorial feel.
 */

export interface Props {
  title?: string;
  body?: string;
}

const {
  title = 'The Peninsula in your inbox, every fortnight.',
  body = "New openings, cellar-door dispatches, weekend-picker verdicts, and the places we're quietly recommending this season. Written by editors who live here.",
} = Astro.props;
---

<section class="newsletter" id="newsletter" aria-label="Newsletter signup">
  <div class="container">
    <div class="newsletter__stack">
      <p class="newsletter__label">The Insider's Dispatch</p>
      <h2 class="newsletter__title" set:html={title.replace(', ', ',<br />')} />
      <p class="newsletter__body">{body}</p>

      <div class="newsletter__embed-wrap" aria-label="Email signup">
        <iframe
          src="https://subscribe-forms.beehiiv.com/4d3b47c5-1958-4372-be0d-aa3d28710a1c"
          class="newsletter__embed beehiiv-embed"
          data-test-id="beehiiv-embed"
          frameborder="0"
          scrolling="no"
          title="Subscribe to The Insider's Dispatch"
        ></iframe>
        <p class="newsletter__disclaimer">
          No spam. Unsubscribe any time. Fortnightly in autumn and winter,
          weekly from October through March.
        </p>
      </div>

      <div class="newsletter__proofs">
        <div class="proof">
          <span class="proof__icon" aria-hidden="true">◆</span>
          <p class="proof__text">
            <strong>Independent editorial</strong>
            Zero advertiser relationships. Zero sponsored listings. Every recommendation unprompted.
          </p>
        </div>
        <div class="proof">
          <span class="proof__icon" aria-hidden="true">◆</span>
          <p class="proof__text">
            <strong>Written by locals</strong>
            Every venue visited by a named editor who lives on the Peninsula year-round.
          </p>
        </div>
        <div class="proof">
          <span class="proof__icon" aria-hidden="true">◆</span>
          <p class="proof__text">
            <strong>Wednesday 6 pm dispatch</strong>
            The <em>Peninsula This Weekend</em> picker: one event to book, one backup, one thing to skip.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
