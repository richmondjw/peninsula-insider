---
/**
 * NewsletterBlock — the dark CTA block that closes most pages.
 * Exposes an id="newsletter" anchor so the masthead CTA works from any page.
 */

export interface Props {
  title?: string;
  body?: string;
}

const {
  title = 'The Peninsula in your inbox, every fortnight.',
  body = "New openings, cellar door dispatches, and the places we're quietly recommending this season. Written by editors who live here.",
} = Astro.props;
---

<section class="newsletter" id="newsletter" aria-label="Newsletter signup">
  <div class="container">
    <div class="newsletter__inner">
      <div>
        <p class="newsletter__label">The Insider's Dispatch</p>
        <h2 class="newsletter__title" set:html={title.replace(', ', ',<br />')} />
        <p class="newsletter__body">{body}</p>
      </div>
      <div>
        <form class="newsletter__form" aria-label="Email signup">
          <div class="newsletter__field">
            <input
              type="email"
              class="newsletter__input"
              placeholder="your@email.com"
              aria-label="Email address"
              autocomplete="email"
            />
            <button type="submit" class="newsletter__submit">Subscribe</button>
          </div>
          <p class="newsletter__disclaimer">
            No spam. Unsubscribe any time. Fortnightly in autumn and winter,
            weekly from October through March.
          </p>
        </form>
        <div class="newsletter__proofs" style="margin-top: 2rem;">
          <div class="proof">
            <span class="proof__icon" aria-hidden="true">◆</span>
            <p class="proof__text">
              <strong>Independent editorial</strong>
              No advertiser relationships. No sponsored content. Just places worth knowing.
            </p>
          </div>
          <div class="proof">
            <span class="proof__icon" aria-hidden="true">◆</span>
            <p class="proof__text">
              <strong>Written by locals</strong>
              Every recommendation is from someone who lives on the Peninsula.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
