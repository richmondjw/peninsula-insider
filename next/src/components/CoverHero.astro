---
/**
 * CoverHero — homepage-only opening cover module.
 * Seasonal rotation: headline + dek + visual label shift with the
 * Southern-Hemisphere calendar so the front door always reads as current.
 */
import { currentSeason } from '../lib/editorial';

export interface Props {
  issueDate: string;
}

const { issueDate } = Astro.props;
const season = currentSeason();

const seasonalHeadlines: Record<string, { line1: string; line2: string; em: string }> = {
  summer: { line1: 'Where Victoria', line2: 'eats, swims,', em: 'and stays late.' },
  autumn: { line1: 'Where Victoria', line2: 'eats, drinks,', em: 'and slows down.' },
  winter: { line1: 'Where Victoria', line2: 'eats, warms up,', em: 'and stays in.' },
  spring: { line1: 'Where Victoria', line2: 'eats, explores,', em: 'and books ahead.' },
};

const seasonalDeks: Record<string, string> = {
  summer: 'Back beaches at five, vineyard lunches that run until the light goes long, and the places locals actually go when Melbourne empties south. An independent editorial guide — no advertisers, no press trips, just honest coverage.',
  autumn: 'Vintage on the ridge, pinot lunches in low golden light, cellar doors with fires going, and the quieter weekends the Peninsula does best. An independent editorial guide — no advertisers, no press trips, just honest coverage.',
  winter: 'Hot springs without the queue, pub dinners worth the drive, fireplace long lunches, and the coastal walks the crowds have finally left alone. An independent editorial guide — no advertisers, no press trips, just honest coverage.',
  spring: 'New vintage releases, wildflower walks, menus rewritten for the season, and the most generous midweek bookings of the year. An independent editorial guide — no advertisers, no press trips, just honest coverage.',
};

const seasonalVisualLabels: Record<string, string> = {
  summer: 'Back Beach · Late Afternoon Light',
  autumn: 'Cape Schanck · Autumn Dawn',
  winter: 'Hot Springs · Hinterland Fog',
  spring: 'Wildflower Coast · New Season Menus',
};

const hl = seasonalHeadlines[season];

const coverImage = '/images/sourced/home-cover.webp';
const coverCredit = 'Marshlung · Wikimedia Commons (CC-BY-SA-4.0)';
---

<section class="cover" aria-label="Cover story">
  <div class="container">
    <div class="cover__inner">
      <div class="cover__copy">
        <div class="cover__meta">
          <span class="label label--accent">{issueDate}</span>
          <span class="cover__meta-rule" aria-hidden="true"></span>
          <span class="label">The Mornington Peninsula</span>
        </div>
        <h1 class="cover__headline">
          {hl.line1}<br />
          {hl.line2}<br />
          and <em>{hl.em}</em>
        </h1>
        <p class="cover__dek">
          {seasonalDeks[season]}
        </p>
        <div class="cover__promise">
          <p class="cover__promise-line">Every venue visited. Every opinion earned. Every recommendation unprompted.</p>
        </div>
      </div>
      <div class="cover__visual-wrap">
        <div class="cover__visual" aria-hidden="true" style={`background-image: url(${coverImage})`}>
          <div class="cover__visual-fog"></div>
          <span class="cover__visual-label">{seasonalVisualLabels[season]}</span>
        </div>
        <p class="cover__credit">Image: {coverCredit}</p>
      </div>
    </div>
  </div>
</section>
