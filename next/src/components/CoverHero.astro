---
/**
 * CoverHero — homepage-only opening cover module.
 * Full-bleed immersive cover. Seasonal rotation of headline + dek.
 */
import { currentSeason } from '../lib/editorial';

export interface Props {
  issueDate: string;
}

const { issueDate } = Astro.props;
const season = currentSeason();

const seasonalHeadlines: Record<string, { line1: string; line2: string; em: string }> = {
  summer: { line1: 'Where Victoria', line2: 'eats, swims,', em: 'stays late.' },
  autumn: { line1: 'Where Victoria', line2: 'eats, drinks,', em: 'slows down.' },
  winter: { line1: 'Where Victoria', line2: 'eats, warms up,', em: 'stays in.' },
  spring: { line1: 'Where Victoria', line2: 'eats, explores,', em: 'books ahead.' },
};

const seasonalDeks: Record<string, string> = {
  summer: 'Back beaches at five, vineyard lunches that run until the light goes long, and the places locals actually go when Melbourne empties south.',
  autumn: 'Vintage on the ridge, pinot lunches in low golden light, cellar doors with fires going, and the quieter weekends the Peninsula does best.',
  winter: 'Hot springs without the queue, pub dinners worth the drive, fireplace long lunches, and the coastal walks the crowds have finally left alone.',
  spring: 'New vintage releases, wildflower walks, menus rewritten for the season, and the most generous midweek bookings of the year.',
};

const hl = seasonalHeadlines[season];

// Images and time boundaries are set client-side so rotation works for every
// visitor regardless of when the static build ran. See <script is:inline> below.
---

<section class="hero-v2" aria-label="Cover">
  <div class="hero-v2__bg" id="hero-bg"></div>
  <script is:inline>
    (function () {
      var images = [
        { src: '/images/sourced/explore-cape-schanck-boardwalk-01.webp', pos: 'center center' },
        { src: '/images/sourced/article-vineyard-villa-01.webp',         pos: 'center center' },
        { src: '/images/sourced/explore-mornington-foreshore-01.webp',   pos: 'center center' },
        { src: '/images/sourced/article-sunset-01.webp',                 pos: 'center center' },
        { src: '/images/sourced/article-long-lunch-01.webp',             pos: 'center center' },
      ];
      var h = new Date().getUTCHours();
      var i = h < 5 ? 0 : h < 10 ? 1 : h < 15 ? 2 : h < 20 ? 3 : 4;
      var bg = document.getElementById('hero-bg');
      if (bg) {
        bg.style.backgroundImage = 'url(' + images[i].src + ')';
        bg.style.backgroundPosition = images[i].pos;
      }
    })();
  </script>
  <div class="hero-v2__scrim"></div>
  <div class="hero-v2__grain"></div>
  <div class="hero-v2__content">
    <div class="hero-v2__eyebrow">
      <span class="hero-v2__eyebrow-label hero-v2__eyebrow-label--issue">{issueDate} Issue</span>
      <span class="hero-v2__eyebrow-rule" aria-hidden="true"></span>
      <span class="hero-v2__eyebrow-label">The Mornington Peninsula</span>
    </div>
    <h1 class="hero-v2__headline">
      {hl.line1}<br />
      {hl.line2}<br />
      and <em>{hl.em}</em>
    </h1>
    <p class="hero-v2__dek">{seasonalDeks[season]}</p>
    <div class="hero-v2__ctas">
      <a href="/eat" class="hero-v2__cta-primary">Start with the restaurants</a>
      <a href="#newsletter" class="hero-v2__cta-secondary">Get the weekly dispatch</a>
    </div>
    <p class="hero-v2__journal-link"><a href="/journal">Or start reading the Journal →</a></p>
  </div>
  <div class="hero-v2__scroll-hint" aria-hidden="true">
    <span class="hero-v2__scroll-label">Scroll</span>
    <div class="hero-v2__scroll-line"></div>
  </div>
</section>

<style>
  .hero-v2 { position: relative; min-height: 92vh; display: flex; align-items: flex-end; overflow: hidden; background-color: var(--dark); }
  .hero-v2__bg { position: absolute; inset: 0; background-image: url(/images/sourced/home-cover.webp); background-size: cover; background-position: center 40%; background-attachment: fixed; }
  .hero-v2__scrim { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(30,27,24,0.08) 0%, rgba(30,27,24,0.15) 25%, rgba(30,27,24,0.5) 55%, rgba(30,27,24,0.82) 75%, rgba(30,27,24,0.95) 100%); }
  .hero-v2__grain { position: absolute; inset: 0; opacity: 0.04; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"); background-size: 128px; pointer-events: none; }
  .hero-v2__content { position: relative; z-index: 2; width: 100%; padding: 0 clamp(1.25rem,4vw,3rem); padding-bottom: clamp(3.5rem,8vw,6rem); max-width: var(--max-w); margin: 0 auto; }
  .hero-v2__eyebrow { display: flex; align-items: center; gap: 1.25rem; margin-bottom: 2rem; padding-bottom: 1.25rem; border-bottom: 1px solid rgba(253,252,250,0.15); }
  .hero-v2__eyebrow-label { font-family: Outfit,system-ui,sans-serif; font-size: 0.82rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--white); text-shadow: 0 1px 20px rgba(30,27,24,0.4); }
  .hero-v2__eyebrow-label--issue { color: var(--white); }
  .hero-v2__eyebrow-rule { width: 1px; height: 18px; background: rgba(253,252,250,0.3); flex-shrink: 0; }
  .hero-v2__headline { font-family: 'Cormorant Garamond',Georgia,serif; font-size: clamp(3.2rem,7.5vw,6.5rem); font-weight: 600; line-height: 0.95; letter-spacing: -0.03em; color: var(--white); margin-bottom: 1.5rem; max-width: 16ch; text-shadow: 0 2px 30px rgba(30,27,24,0.4); }
  .hero-v2__headline em { font-style: italic; color: var(--gold); font-size: 1.1em; display: inline-block; text-shadow: 0 2px 40px rgba(182,154,107,0.25); }
  .hero-v2__dek { font-family: Outfit,system-ui,sans-serif; font-size: 1.05rem; line-height: 1.7; color: rgba(253,252,250,0.7); max-width: 44ch; font-weight: 300; margin-bottom: 2rem; }
  .hero-v2__ctas { display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; }
  .hero-v2__cta-primary { display: inline-flex; align-items: center; padding: 0.9rem 2rem; background: var(--accent); color: var(--white); font-family: Outfit,system-ui,sans-serif; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; transition: background 0.25s ease; min-height: 44px; }
  .hero-v2__cta-primary:hover { background: var(--acc-h); }
  .hero-v2__cta-secondary { display: inline-flex; align-items: center; padding: 0.9rem 2rem; background: transparent; color: rgba(253,252,250,0.7); border: 1px solid rgba(253,252,250,0.2); font-family: Outfit,system-ui,sans-serif; font-size: 0.72rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; transition: border-color 0.25s ease, color 0.25s ease; min-height: 44px; }
  .hero-v2__cta-secondary:hover { border-color: rgba(253,252,250,0.5); color: var(--white); }
  .hero-v2__journal-link { margin-top: 1rem; }
  .hero-v2__journal-link a { font-family: Outfit,system-ui,sans-serif; font-size: 0.78rem; font-weight: 400; color: rgba(253,252,250,0.45); text-decoration: none; transition: color 0.2s ease; }
  .hero-v2__journal-link a:hover { color: rgba(253,252,250,0.75); }
  .hero-v2__scroll-hint { position: absolute; bottom: 1.5rem; right: clamp(1.25rem,4vw,3rem); z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .hero-v2__scroll-label { font-family: Outfit,system-ui,sans-serif; font-size: 0.55rem; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(253,252,250,0.3); writing-mode: vertical-rl; }
  .hero-v2__scroll-line { width: 1px; height: 40px; background: rgba(253,252,250,0.35); }

  @media (prefers-reduced-motion: no-preference) {
    @keyframes riseIn {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes scrollTravel {
      0%   { transform: scaleY(0); transform-origin: top; opacity: 0.8; }
      50%  { transform: scaleY(1); transform-origin: top; opacity: 0.8; }
      51%  { transform-origin: bottom; }
      100% { transform: scaleY(0); transform-origin: bottom; opacity: 0.2; }
    }
    .hero-v2__eyebrow {
      animation: fadeIn 0.6s var(--ease) 0.15s both;
    }
    .hero-v2__headline {
      animation: riseIn 0.75s var(--ease) 0.35s both;
    }
    .hero-v2__dek {
      animation: fadeIn 0.6s var(--ease) 0.65s both;
    }
    .hero-v2__ctas {
      animation: fadeIn 0.5s var(--ease) 0.85s both;
    }
    .hero-v2__journal-link {
      animation: fadeIn 0.5s var(--ease) 1.0s both;
    }
    .hero-v2__scroll-line {
      animation: scrollTravel 2.2s var(--ease) 1.5s infinite;
    }
  }
  @media (max-width: 768px) {
    .hero-v2 { min-height: 85vh; }
    .hero-v2__bg { background-position: center 30%; background-attachment: scroll; }
    /* Heavier scrim on mobile — image is bright and text needs to float cleanly */
    .hero-v2__scrim { background: linear-gradient(to bottom,
      rgba(30,27,24,0.45) 0%,
      rgba(30,27,24,0.45) 20%,
      rgba(30,27,24,0.6)  45%,
      rgba(30,27,24,0.88) 70%,
      rgba(30,27,24,0.97) 100%
    ); }
    .hero-v2__eyebrow { border-bottom-color: rgba(253,252,250,0.25); }
    .hero-v2__eyebrow-label { text-shadow: 0 1px 12px rgba(0,0,0,0.8); }
    .hero-v2__headline { font-size: clamp(2.6rem,10vw,4rem); max-width: 100%; text-shadow: 0 2px 20px rgba(0,0,0,0.6); }
    .hero-v2__dek { font-size: 0.95rem; max-width: 100%; color: rgba(253,252,250,0.88); }
    .hero-v2__ctas { flex-direction: column; align-items: stretch; }
    .hero-v2__cta-primary, .hero-v2__cta-secondary { text-align: center; justify-content: center; }
    .hero-v2__cta-secondary { color: rgba(253,252,250,0.88); border-color: rgba(253,252,250,0.35); }
    .hero-v2__journal-link a { color: rgba(253,252,250,0.6); }
    .hero-v2__scroll-hint { display: none; }
  }
</style>
