---
/**
 * EventCard  -  the primary card for the What's On index.
 *
 * Designed to carry the Peninsula Insider editorial wedge up front:
 * date, category, editor verdict, badges. No plain directory rows  - 
 * every event carries at least one sentence of opinion.
 */
import EventBadges from './EventBadges.astro';
import { eventCategoryLabel, eventDateLabel, routeSlug, heroBackgroundStyle } from '../lib/editorial';

export interface Props {
  event: any;
  featured?: boolean;
}

const { event, featured = false } = Astro.props;
const slug = routeSlug(event);
const category = event.data.category;
const placeLabel =
  typeof event.data.place === 'string' ? event.data.place : event.data.place?.id;
---

<article class={`event-card ${featured ? 'event-card--featured' : ''}`}>
  {event.data.heroImage && (
    <div class="event-card__hero" style={heroBackgroundStyle(event.data)} aria-hidden="true"></div>
  )}
  <div class="event-card__top">
    <span class="event-card__date">{eventDateLabel(event.data.startDate, event.data.endDate)}</span>
    <span class="event-card__category">{eventCategoryLabel[category] ?? category}</span>
  </div>
  <h3 class="event-card__name">
    <a href={`/whats-on/${slug}`}>{event.data.title}</a>
  </h3>
  {placeLabel && (
    <p class="event-card__place">{String(placeLabel).replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase())}</p>
  )}
  <p class="event-card__summary">{event.data.summary}</p>
  {event.data.editorVerdict && (
    <blockquote class="event-card__verdict">
      <span class="event-card__verdict-label">Editor's verdict</span>
      <p>{event.data.editorVerdict}</p>
    </blockquote>
  )}
  <EventBadges
    worthTheDrive={event.data.worthTheDrive}
    firstTimer={event.data.firstTimer}
    kidsGrade={event.data.kidsGrade}
    weather={event.data.weather}
    skipThis={event.data.skipThis}
  />
  <a href={`/whats-on/${slug}`} class="event-card__cta">Read the full guide -></a>
</article>
