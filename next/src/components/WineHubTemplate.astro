---
import Breadcrumbs from './Breadcrumbs.astro';
import VenueCard from './VenueCard.astro';
import NewsletterBlock from './NewsletterBlock.astro';
import { routeSlug } from '../lib/editorial';

export interface Props {
  h1: string;
  badgeLabel: string;
  introText: string;
  venues: any[];
  breadcrumbs: Array<{ label: string; href?: string }>;
  faqItems?: Array<{ q: string; a: string }>;
}

const { h1, badgeLabel, introText, venues, breadcrumbs, faqItems = [] } = Astro.props;
---

<Breadcrumbs items={breadcrumbs} />

<article class="article">
  <div class="container">
    <p class="label label--accent">{badgeLabel}</p>
    <h1 class="article__title">{h1}</h1>
    <div class="prose">
      {introText.split('\n\n').map((p) => <p>{p}</p>)}
    </div>
  </div>
</article>

<section class="venues" id="producers">
  <div class="container">
    <div class="venues__header">
      <div>
        <p class="label label--accent">Editorial ranking · {new Date().getFullYear()}</p>
        <h2 class="venues__title">{venues.length} producer{venues.length !== 1 ? 's' : ''}</h2>
        <p class="venues__sub">Ordered by editorial authority and Halliday score.</p>
      </div>
      <a href="/wine" class="venues__link">All producers →</a>
    </div>
    <div class="venues__grid">
      {venues.map((venue) => <VenueCard venue={venue} hrefPrefix="/wine" />)}
    </div>
  </div>
</section>

{faqItems.length > 0 && (
  <section class="faq-section">
    <div class="container">
      <div class="prose">
        <h2>Frequently asked questions</h2>
        {faqItems.map((item) => (
          <>
            <h3>{item.q}</h3>
            <p>{item.a}</p>
          </>
        ))}
      </div>
    </div>
  </section>
)}

<NewsletterBlock />
