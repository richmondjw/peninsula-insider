---
/**
 * EventBadges \u2014 the editorial differentiators rendered as a small
 * badge strip on event cards and event detail pages.
 *
 * These are the Peninsula Insider wedge against the DMO:
 * Worth The Drive, Kids Grade, First Timer, Weather flag,
 * and the explicit "Skip this" warning when set.
 */
import { kidsGradeCopy, weatherCopy } from '../lib/editorial';

export interface Props {
  worthTheDrive?: boolean;
  firstTimer?: boolean;
  kidsGrade?: 'A' | 'B' | 'C' | 'not-for-kids';
  weather?: 'all-weather' | 'sunny-only' | 'rainy-day-rescue' | 'weather-proof' | 'mixed';
  skipThis?: boolean;
  size?: 'sm' | 'md';
}

const {
  worthTheDrive = false,
  firstTimer = false,
  kidsGrade,
  weather,
  skipThis = false,
  size = 'sm',
} = Astro.props;

const kidsLabel = kidsGrade ? kidsGradeCopy[kidsGrade]?.label : undefined;
const weatherLabel = weather && weather !== 'mixed' ? weatherCopy[weather] : undefined;
---

<div class={`event-badges event-badges--${size}`}>
  {skipThis && (
    <span class="event-badge event-badge--skip" title="Editor says skip this">Skip this</span>
  )}
  {worthTheDrive && (
    <span class="event-badge event-badge--drive" title="Worth the 90-minute drive from Melbourne">Worth the drive</span>
  )}
  {firstTimer && (
    <span class="event-badge event-badge--first" title="If you've never been \u2014 start here">First timer</span>
  )}
  {kidsLabel && (
    <span class={`event-badge event-badge--kids event-badge--kids-${(kidsGrade ?? 'B').toLowerCase()}`}>{kidsLabel}</span>
  )}
  {weatherLabel && (
    <span class="event-badge event-badge--weather">{weatherLabel}</span>
  )}
</div>
