---
/**
 * Peninsula Insider  -  BaseLayout
 *
 * Single wrapping layout for every page in the rebuild.
 * Handles <head>, fonts, global styles, masthead, footer.
 * Content slots through <slot />.
 */

import '../styles/global.css';
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  section?: 'home' | 'eat' | 'stay' | 'wine' | 'explore' | 'journal' | 'places' | 'escape' | 'whats-on';
  preview?: boolean;
}

const {
  title,
  description = 'The independent editorial guide to the Mornington Peninsula  -  no advertisers, no press trips, just honest coverage.',
  section = 'home',
  preview = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Outfit:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />
  <title>{title}</title>
  <meta name="description" content={description} />
  <script async src="https://subscribe-forms.beehiiv.com/embed.js"></script>
  <script async src="https://subscribe-forms.beehiiv.com/attribution.js"></script>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-0MR9YVZ9NW"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-0MR9YVZ9NW');
  </script>
</head>
<body>

  <Masthead section={section} />

  <main>
    <slot />
  </main>

  <Footer />

  <!-- Password gate -->
  <div id="siteLock" style="position:fixed;inset:0;z-index:10000;background:#1E1B18;display:flex;align-items:center;justify-content:center;font-family:'Outfit',system-ui,sans-serif;">
    <div style="text-align:center;color:#FDFCFA;max-width:360px;padding:2rem;">
      <p style="font-family:Georgia,serif;font-size:22px;font-weight:700;margin:0 0 4px;">Peninsula <span style="font-style:italic;color:#B69A6B;">Insider</span></p>
      <p style="font-size:13px;color:rgba(253,252,250,0.4);margin:0 0 24px;">This site is currently private.</p>
      <form id="siteLockForm" style="display:flex;gap:0;">
        <input type="password" id="siteLockPassword" placeholder="Password" autocomplete="current-password" style="flex:1;padding:10px 14px;border:1px solid rgba(253,252,250,0.15);border-right:none;background:rgba(253,252,250,0.06);color:#FDFCFA;font-size:14px;border-radius:2px 0 0 2px;outline:none;" />
        <button type="submit" style="padding:10px 20px;background:#8B4E3B;color:#FDFCFA;border:1px solid #8B4E3B;font-size:12px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;border-radius:0 2px 2px 0;">Enter</button>
      </form>
      <div id="siteLockError" style="color:#c0392b;font-size:12px;margin-top:8px;"></div>
    </div>
  </div>
  <script is:inline>
    (function () {
      var PASSWORD = '1xlx1';
      var STORAGE_KEY = 'peninsula-insider-unlocked';
      var lock = document.getElementById('siteLock');
      if (sessionStorage.getItem(STORAGE_KEY) === 'true') {
        lock.style.display = 'none';
        return;
      }
      document.body.style.overflow = 'hidden';
      document.getElementById('siteLockForm').addEventListener('submit', function (e) {
        e.preventDefault();
        var input = document.getElementById('siteLockPassword');
        if (input.value === PASSWORD) {
          sessionStorage.setItem(STORAGE_KEY, 'true');
          lock.style.display = 'none';
          document.body.style.overflow = '';
        } else {
          document.getElementById('siteLockError').textContent = 'Incorrect password.';
          input.value = '';
          input.focus();
        }
      });
    })();
  </script>

</body>
</html>
