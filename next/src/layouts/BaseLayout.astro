---
/**
 * Peninsula Insider — BaseLayout
 *
 * Single wrapping layout for every page in the rebuild.
 * Handles <head>, fonts, global styles, masthead, footer.
 * Content slots through <slot />.
 */

import '../styles/global.css';
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  section?: 'home' | 'eat' | 'stay' | 'wine' | 'explore' | 'journal' | 'places' | 'escape' | 'whats-on';
  preview?: boolean;
}

const {
  title,
  description = 'The independent editorial guide to the Mornington Peninsula — no advertisers, no press trips, just honest coverage.',
  section = 'home',
  preview = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Outfit:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex, nofollow" />
  <script async src="https://subscribe-forms.beehiiv.com/embed.js"></script>
  <script async src="https://subscribe-forms.beehiiv.com/attribution.js"></script>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-0MR9YVZ9NW"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-0MR9YVZ9NW');
  </script>
</head>
<body>
  {preview && (
    <div class="preview-banner">
      <strong>Preview Build</strong> &nbsp;·&nbsp; Phase 1 Astro rebuild
      &nbsp;·&nbsp; Not production &nbsp;·&nbsp;
      <a href="https://peninsulainsider.com.au">Live site →</a>
    </div>
  )}

  <Masthead section={section} />

  <main>
    <slot />
  </main>

  <Footer />
</body>
</html>
